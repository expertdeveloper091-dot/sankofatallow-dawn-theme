</style>

<collection-component
  view-event-payload="{{ collection | standard_event_data: 'view' | escape }}"
  data-collection-id="{{ collection.id }}"
>
  <div class="section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}">
    {%- paginate collection.products by section.settings.products_per_page -%}

      <!-- RENDER FACETS & FILTER DRAWER -->
      {% render 'facets',
        results: collection,
        enable_filtering: true,
        enable_sorting: section.settings.enable_sorting,
        filter_type: 'drawer',
        paginate: paginate
      %}

      <div
        class="product-grid-container page-width{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        id="ProductGridContainer"
        {% if settings.animations_reveal_on_scroll %}
          data-cascade
        {% endif %}
      >
        {%- if collection.products.size == 0 -%}
          <div class="collection collection--empty" id="product-grid" data-id="{{ section.id }}">
            <div class="loading-overlay gradient"></div>
            <div class="title-wrapper center">
              <h2 class="title title--primary">
                {{ 'sections.collection_template.empty' | t -}}
                <br>
                {{
                  'sections.collection_template.use_fewer_filters_html'
                  | t: link: collection.url, class: 'underlined-link link'
                }}
              </h2>
            </div>
          </div>
        {%- else -%}
          <div class="collection">
            <div class="loading-overlay gradient"></div>

            <!-- LUXURY COLLECTION TOOLBAR (EXACT CODE MATCH) -->
            <div class="ml-collection-toolbar">
              <!-- LEFT: FILTER BUTTON + PRODUCT COUNT -->
              <div class="ml-toolbar__left">
                <button
                  type="button"
                  class="ml-filter-open-btn"
                  id="mlFilterOpenBtn"
                  aria-expanded="false"
                  aria-controls="mlFilterDrawer"
                >
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="4" y1="21" x2="4" y2="14"></line>
                    <line x1="4" y1="10" x2="4" y2="3"></line>
                    <line x1="12" y1="21" x2="12" y2="12"></line>
                    <line x1="12" y1="8" x2="12" y2="3"></line>
                    <line x1="20" y1="21" x2="20" y2="16"></line>
                    <line x1="20" y1="12" x2="20" y2="3"></line>
                    <line x1="1" y1="14" x2="7" y2="14"></line>
                    <line x1="9" y1="8" x2="15" y2="8"></line>
                    <line x1="17" y1="16" x2="23" y2="16"></line>
                  </svg>
                  <span>FILTERS</span>
                </button>

                <div class="ml-results-count">
                  {%- if collection.results_count -%}
                    {{ collection.results_count }} Products
                  {%- elsif collection.products_count == collection.all_products_count -%}
                    {{ collection.products_count }} Products
                  {%- else -%}
                    {{ collection.products_count }} Products
                  {%- endif -%}
                </div>
              </div>

              <!-- CENTER: GRID VIEW SWITCHER (DEFAULT 2 CARDS PER ROW) -->
              <div class="ml-toolbar__center">
                <!-- DESKTOP SWITCHER (1 CARD PER ROW / 2 CARDS PER ROW) -->
                <div class="ml-grid-switcher ml-grid-switcher--desktop">
                  <button type="button" class="ml-grid-btn" data-cols-desktop="1" aria-label="1 Card per Row">
                    <svg width="20" height="20" viewBox="0 0 24 24">
                      <rect x="3" y="3" width="18" height="18" rx="2" />
                    </svg>
                  </button>

                  <span class="ml-grid-divider"></span>

                  <button type="button" class="ml-grid-btn active" data-cols-desktop="2" aria-label="2 Cards per Row">
                    <svg width="20" height="20" viewBox="0 0 24 24">
                      <rect x="3" y="3" width="7" height="18" rx="1" />
                      <rect x="14" y="3" width="7" height="18" rx="1" />
                    </svg>
                  </button>
                </div>

                <!-- MOBILE SWITCHER (1 CARD PER ROW / 2 CARDS PER ROW) -->
                <div class="ml-grid-switcher ml-grid-switcher--mobile">
                  <button type="button" class="ml-grid-btn" data-cols-mobile="1" aria-label="1 Product per row">
                    <svg width="20" height="20" viewBox="0 0 24 24">
                      <rect x="3" y="3" width="18" height="18" rx="2" />
                    </svg>
                  </button>
                  <span class="ml-grid-divider"></span>
                  <button type="button" class="ml-grid-btn active" data-cols-mobile="2" aria-label="2 Products per row">
                    <svg width="20" height="20" viewBox="0 0 24 24">
                      <rect x="3" y="3" width="7" height="18" rx="1" />
                      <rect x="14" y="3" width="7" height="18" rx="1" />
                    </svg>
                  </button>
                </div>
              </div>

              <!-- RIGHT: SORT BY LABEL + SELECT BUTTON BOX -->
              <div class="ml-toolbar__right">
                <span class="ml-sort-label">Sort by:</span>
                {%- if section.settings.enable_sorting -%}
                  <facet-filters-form class="ml-desktop-sort-form">
                    <form id="mlDesktopSortForm">
                      <div class="ml-sort-select-box">
                        {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
                        <select name="sort_by" class="ml-desktop-sort-select" id="mlDesktopSortBy">
                          {%- for option in collection.sort_options -%}
                            <option value="{{ option.value | escape }}" {% if option.value == sort_by %}selected="selected"{% endif %}>
                              {{ option.name | escape }}
                            </option>
                          {%- endfor -%}
                        </select>
                        <svg class="ml-sort-box-caret" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                          <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                      </div>
                    </form>
                  </facet-filters-form>
                {%- endif -%}
              </div>
            </div>

            <!-- PRODUCT GRID (DEFAULT 2 CARDS PER ROW ON DESKTOP) -->
            <ul
              id="product-grid"
              data-id="{{ section.id }}"
              class="
                grid product-grid ml-product-grid
                grid--1-col-tablet-down
                grid--2-col-desktop
                {% if section.settings.quick_add == 'bulk' %} collection-quick-add-bulk{% endif %}
              "
            >
              {% assign skip_card_product_styles = false %}
              {%- for product in collection.products -%}
                {% assign lazy_load = false %}
                {%- if forloop.index > 2 -%}
                  {%- assign lazy_load = true -%}
                {%- endif -%}
                <li
                  class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                  {% if settings.animations_reveal_on_scroll %}
                    data-cascade
                    style="--animation-order: {{ forloop.index }};"
                  {% endif %}
                >
                  {% render 'card-product',
                    card_product: product,
                    media_aspect_ratio: section.settings.image_ratio,
                    image_shape: section.settings.image_shape,
                    show_secondary_image: section.settings.show_secondary_image,
                    show_vendor: section.settings.show_vendor,
                    show_rating: section.settings.show_rating,
                    lazy_load: lazy_load,
                    skip_styles: skip_card_product_styles,
                    quick_add: section.settings.quick_add,
                    section_id: section.id,
                    product_view_context: 'collection'
                  %}
                </li>
                {%- assign skip_card_product_styles = true -%}
              {%- endfor -%}
            </ul>

            {%- if paginate.pages > 1 -%}
              {% render 'pagination', paginate: paginate, anchor: '' %}
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endpaginate -%}
  </div>
</collection-component>

<script>
  if (typeof mlCollectionToolbarInit === 'undefined') {
    window.mlCollectionToolbarInit = true;

    window.mlApplyGridCols = function(colsDesktop, colsMobile) {
      const grid = document.getElementById('product-grid');
      if (!grid) return;

      if (colsDesktop) {
        grid.classList.remove('grid--1-col-desktop', 'grid--2-col-desktop', 'grid--3-col-desktop', 'grid--4-col-desktop');
        grid.classList.add('grid--' + colsDesktop + '-col-desktop');
        localStorage.setItem('ml-grid-desktop', colsDesktop);

        document.querySelectorAll('[data-cols-desktop]').forEach(btn => {
          btn.classList.toggle('active', btn.getAttribute('data-cols-desktop') === colsDesktop);
        });
      }

      if (colsMobile) {
        grid.classList.remove('grid--1-col-tablet-down', 'grid--2-col-tablet-down');
        grid.classList.add('grid--' + colsMobile + '-col-tablet-down');
        localStorage.setItem('ml-grid-mobile', colsMobile);

        document.querySelectorAll('[data-cols-mobile]').forEach(btn => {
          btn.classList.toggle('active', btn.getAttribute('data-cols-mobile') === colsMobile);
        });
      }
    };

    document.addEventListener('click', function(e) {
      const desktopBtn = e.target.closest('[data-cols-desktop]');
      if (desktopBtn) {
        window.mlApplyGridCols(desktopBtn.getAttribute('data-cols-desktop'), null);
      }
      const mobileBtn = e.target.closest('[data-cols-mobile]');
      if (mobileBtn) {
        window.mlApplyGridCols(null, mobileBtn.getAttribute('data-cols-mobile'));
      }
    });

    const initGrid = () => {
      let savedDesktop = localStorage.getItem('ml-grid-desktop');
      if (!savedDesktop || (savedDesktop !== '1' && savedDesktop !== '2')) {
        savedDesktop = '2';
        localStorage.setItem('ml-grid-desktop', '2');
      }
      const savedMobile = localStorage.getItem('ml-grid-mobile') || '2';
      window.mlApplyGridCols(savedDesktop, savedMobile);
    };

    initGrid();

    // Re-apply layout on AJAX grid update
    const observer = new MutationObserver(() => {
      let savedDesktop = localStorage.getItem('ml-grid-desktop');
      if (!savedDesktop || (savedDesktop !== '1' && savedDesktop !== '2')) {
        savedDesktop = '2';
      }
      const savedMobile = localStorage.getItem('ml-grid-mobile') || '2';
      const grid = document.getElementById('product-grid');
      if (grid && (!grid.classList.contains('grid--' + savedDesktop + '-col-desktop') || !grid.classList.contains('grid--' + savedMobile + '-col-tablet-down'))) {
        window.mlApplyGridCols(savedDesktop, savedMobile);
      }
    });

    const targetNode = document.getElementById('ProductGridContainer');
    if (targetNode) {
      observer.observe(targetNode, { childList: true, subtree: true });
    }
  }
</script>

{% schema %}
{
  "name": "t:sections.main-collection-product-grid.name",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 36,
      "step": 4,
      "default": 16,
      "label": "t:sections.main-collection-product-grid.settings.products_per_page.label"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 2,
