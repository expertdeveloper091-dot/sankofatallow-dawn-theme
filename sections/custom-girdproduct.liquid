<!-- sections/custom-girdproduct.liquid -->
{{ 'https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css' | stylesheet_tag }}

{%- style -%}
  .custom-gridproduct-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | default: 60 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 60 }}px;
    background-color: {{ section.settings.bg_color | default: '#FAF7EF' }};
  }

  .custom-gridproduct-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    box-sizing: border-box;
  }

  /* Header */
  .custom-gridproduct-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .custom-gridproduct-subtitle {
    color: {{ section.settings.subtitle_color | default: '#E63946' }};
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 8px;
    font-family: 'Poppins', sans-serif;
  }

  .custom-gridproduct-heading {
    color: {{ section.settings.heading_color | default: '#111111' }};
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 900;
    text-transform: uppercase;
    margin: 0 0 14px 0;
    line-height: 1.15;
    font-family: 'Poppins', sans-serif;
  }

  .custom-gridproduct-desc {
    color: {{ section.settings.text_color | default: '#333333' }};
    font-size: 15px;
    line-height: 1.6;
    max-width: 750px;
    margin: 0 auto 24px auto;
    font-family: 'Poppins', sans-serif;
  }

  /* Trust Badges */
  .custom-gridproduct-trust {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
    margin-bottom: 10px;
  }

  .custom-gridproduct-trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 700;
    color: {{ section.settings.heading_color | default: '#111111' }};
    font-family: 'Poppins', sans-serif;
  }

  .custom-gridproduct-trust-item svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  /* Grid Layout */
  .custom-gridproduct-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 30px;
  }

  @media (max-width: 900px) {
    .custom-gridproduct-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  /* Card Container */
  .c-prod-card {
    border: 1.5px solid {{ section.settings.card_border_color | default: '#111111' }};
    border-radius: 12px;
    background-color: {{ section.settings.card_bg | default: '#FFFDF5' }};
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .c-prod-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.06);
  }

  .c-prod-card-body {
    padding: 24px;
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }

  @media (max-width: 576px) {
    .c-prod-card-body {
      flex-direction: column;
      align-items: center;
      gap: 16px;
      padding: 18px;
    }
  }

  /* Card Image */
  .c-prod-card-img-wrap {
    width: 42%;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 576px) {
    .c-prod-card-img-wrap {
      width: 100%;
      max-width: 240px;
    }
  }

  .c-prod-card-img-wrap img {
    width: 100%;
    height: auto;
    max-height: 230px;
    object-fit: contain;
    display: block;
  }

  .c-prod-card-content {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .c-prod-card-title {
    font-size: 20px;
    font-weight: 900;
    text-transform: uppercase;
    color: {{ section.settings.heading_color | default: '#111111' }};
    margin: 0 0 10px 0;
    line-height: 1.2;
    font-family: 'Poppins', sans-serif;
  }

  .c-prod-card-description {
    font-size: 13.5px;
    line-height: 1.5;
    color: #444444;
    margin-bottom: 14px;
    font-family: 'Poppins', sans-serif;
  }

  .c-prod-card-description strong,
  .c-prod-card-description b {
    font-weight: 700;
    color: #111111;
  }

  /* Feature Bullets */
  .c-prod-card-features {
    list-style: none;
    padding: 0;
    margin: 0 0 16px 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .c-prod-card-feature-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 700;
    color: {{ section.settings.heading_color | default: '#111111' }};
    font-family: 'Poppins', sans-serif;
  }

  .c-prod-card-feature-icon {
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: currentColor;
    flex-shrink: 0;
  }

  .c-prod-card-price {
    font-size: 18px;
    font-weight: 800;
    color: {{ section.settings.heading_color | default: '#111111' }};
    margin-top: auto;
    font-family: 'Poppins', sans-serif;
  }

  /* Card Bottom Action Bar */
  .c-prod-card-actions {
    display: flex;
    border-top: 1.5px solid {{ section.settings.card_border_color | default: '#111111' }};
  }

  .c-prod-btn-learn {
    width: 50%;
    background-color: #ffffff;
    color: #111111;
    border: none;
    border-right: 1.5px solid {{ section.settings.card_border_color | default: '#111111' }};
    font-size: 14px;
    font-weight: 700;
    font-family: 'Poppins', sans-serif;
    padding: 14px 10px;
    text-align: center;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    transition: background 0.2s;
  }

  .c-prod-btn-learn:hover {
    background-color: #f2f2f2;
    color: #000;
  }

  .c-prod-btn-cart {
    width: 50%;
    background-color: {{ section.settings.btn_cart_bg | default: '#F3AD12' }};
    color: {{ section.settings.btn_cart_text_color | default: '#111111' }};
    border: none;
    font-size: 14px;
    font-weight: 700;
    font-family: 'Poppins', sans-serif;
    padding: 14px 10px;
    text-align: center;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    cursor: pointer;
    transition: filter 0.2s;
  }

  .c-prod-btn-cart:hover {
    filter: brightness(0.95);
  }
{%- endstyle -%}

<div class="custom-gridproduct-{{ section.id }}">
  <div class="custom-gridproduct-container">

    <!-- Header Section -->
    <div class="custom-gridproduct-header">
      {%- if section.settings.subtitle != blank -%}
        <div class="custom-gridproduct-subtitle">{{ section.settings.subtitle | escape }}</div>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="custom-gridproduct-heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <div class="custom-gridproduct-desc">{{ section.settings.description }}</div>
      {%- endif -%}

      {%- if section.settings.show_trust_badges -%}
        <div class="custom-gridproduct-trust">
          {%- if section.settings.badge_1_text != blank -%}
            <div class="custom-gridproduct-trust-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="#F3AD12" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              <span>{{ section.settings.badge_1_text | escape }}</span>
            </div>
          {%- endif -%}

          {%- if section.settings.badge_2_text != blank -%}
            <div class="custom-gridproduct-trust-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="#F3AD12" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              <span>{{ section.settings.badge_2_text | escape }}</span>
            </div>
          {%- endif -%}

          {%- if section.settings.badge_3_text != blank -%}
            <div class="custom-gridproduct-trust-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="#F3AD12" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              <span>{{ section.settings.badge_3_text | escape }}</span>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Product Grid (Pure Collection Driven) -->
    <div class="custom-gridproduct-grid">
      {%- assign selected_collection = section.settings.collection -%}
      {%- if selected_collection == blank -%}
        {%- assign selected_collection = collections['all'] -%}
      {%- endif -%}

      {%- if selected_collection != blank and selected_collection.products_count > 0 -%}
        {%- for product in selected_collection.products limit: section.settings.products_to_show -%}
          <div class="c-prod-card">
            <div class="c-prod-card-body">
              
              <!-- Image -->
              <div class="c-prod-card-img-wrap">
                {%- if product.featured_media != blank -%}
                  <img src="{{ product.featured_media | image_url: width: 600 }}"
                       alt="{{ product.title | escape }}"
                       loading="lazy">
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>

              <!-- Content -->
              <div class="c-prod-card-content">
                <h3 class="c-prod-card-title">
                  {{ product.title | escape }}
                </h3>

                <div class="c-prod-card-description">
                  {%- if product.description != blank -%}
                    {{ product.description | strip_html | truncatewords: 22 }}
                  {%- else -%}
                    Organic multipurpose balm that <strong>deeply moisturizes</strong> and nourishes skin.
                  {%- endif -%}
                </div>

                <ul class="c-prod-card-features">
                  {%- if section.settings.default_feature_1 != blank -%}
                    <li class="c-prod-card-feature-item">
                      <span class="c-prod-card-feature-icon">
                        {%- if section.settings.default_feature_1_icon == 'star' -%}
                          <i class="fa-regular fa-star"></i>
                        {%- elsif section.settings.default_feature_1_icon == 'leaf' -%}
                          <i class="fa-solid fa-leaf"></i>
                        {%- elsif section.settings.default_feature_1_icon == 'shield' -%}
                          <i class="fa-solid fa-shield-halved"></i>
                        {%- else -%}
                          <i class="fa-solid fa-check"></i>
                        {%- endif -%}
                      </span>
                      <span>{{ section.settings.default_feature_1 | escape }}</span>
                    </li>
                  {%- endif -%}

                  {%- if section.settings.default_feature_2 != blank -%}
                    <li class="c-prod-card-feature-item">
                      <span class="c-prod-card-feature-icon">
                        {%- if section.settings.default_feature_2_icon == 'star' -%}
                          <i class="fa-regular fa-star"></i>
                        {%- elsif section.settings.default_feature_2_icon == 'leaf' -%}
                          <i class="fa-solid fa-leaf"></i>
                        {%- elsif section.settings.default_feature_2_icon == 'shield' -%}
                          <i class="fa-solid fa-shield-halved"></i>
                        {%- else -%}
                          <i class="fa-solid fa-check"></i>
                        {%- endif -%}
                      </span>
                      <span>{{ section.settings.default_feature_2 | escape }}</span>
                    </li>
                  {%- endif -%}

                  {%- if section.settings.default_feature_3 != blank -%}
                    <li class="c-prod-card-feature-item">
                      <span class="c-prod-card-feature-icon">
                        {%- if section.settings.default_feature_3_icon == 'star' -%}
                          <i class="fa-regular fa-star"></i>
                        {%- elsif section.settings.default_feature_3_icon == 'leaf' -%}
                          <i class="fa-solid fa-leaf"></i>
                        {%- elsif section.settings.default_feature_3_icon == 'shield' -%}
                          <i class="fa-solid fa-shield-halved"></i>
                        {%- else -%}
                          <i class="fa-solid fa-check"></i>
                        {%- endif -%}
                      </span>
                      <span>{{ section.settings.default_feature_3 | escape }}</span>
                    </li>
                  {%- endif -%}
                </ul>

                <div class="c-prod-card-price">
                  {{ product.price | money }}
                </div>
              </div>

            </div>

            <!-- Bottom Actions Bar -->
            <div class="c-prod-card-actions">
              <a href="{{ product.url }}" class="c-prod-btn-learn">
                <span>{{ section.settings.default_learn_text | default: 'Learn More' | escape }}</span>
                <span>&rarr;</span>
              </a>

              {%- if product.available -%}
                <form method="post" action="/cart/add" style="width: 50%; display: flex;">
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  <button type="submit" class="c-prod-btn-cart" style="width: 100%;">
                    <span>{{ section.settings.default_cart_text | default: 'Add To Cart' | escape }}</span>
                    <i class="fa-solid fa-cart-shopping"></i>
                  </button>
                </form>
              {%- else -%}
                <a href="{{ product.url }}" class="c-prod-btn-cart">
                  <span>Sold Out</span>
                </a>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..2) -%}
          <div class="c-prod-card">
            <div class="c-prod-card-body">
              <div class="c-prod-card-img-wrap">
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
              <div class="c-prod-card-content">
                <h3 class="c-prod-card-title">Sample Product {{ i }}</h3>
                <div class="c-prod-card-description">
                  Organic multipurpose balm that <strong>deeply moisturizes</strong> and nourishes skin.
                </div>
                <div class="c-prod-card-price">$49.99</div>
              </div>
            </div>
            <div class="c-prod-card-actions">
              <a href="#" class="c-prod-btn-learn"><span>Learn More</span> <span>&rarr;</span></a>
              <a href="#" class="c-prod-btn-cart"><span>Add To Cart</span> <i class="fa-solid fa-cart-shopping"></i></a>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Custom Product Grid",
  "settings": [
    {
      "type": "header",
      "content": "Collection Source"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 24,
      "step": 1,
      "default": 8,
      "label": "Maximum Products to Show"
    },
    {
      "type": "header",
      "content": "Product Card Bullet Features"
    },
    {
      "type": "text",
      "id": "default_feature_1",
      "label": "Feature 1 Bullet Text",
      "default": "Skin Barrier Support"
    },
    {
      "type": "select",
      "id": "default_feature_1_icon",
      "label": "Feature 1 Icon",
      "options": [
        { "value": "star", "label": "Star" },
        { "value": "check", "label": "Checkmark" },
        { "value": "leaf", "label": "Leaf" },
        { "value": "shield", "label": "Shield" }
      ],
      "default": "star"
    },
    {
      "type": "text",
      "id": "default_feature_2",
      "label": "Feature 2 Bullet Text",
      "default": "Fast Absorption"
    },
    {
      "type": "select",
      "id": "default_feature_2_icon",
      "label": "Feature 2 Icon",
      "options": [
        { "value": "star", "label": "Star" },
        { "value": "check", "label": "Checkmark" },
        { "value": "leaf", "label": "Leaf" },
        { "value": "shield", "label": "Shield" }
      ],
      "default": "check"
    },
    {
      "type": "text",
      "id": "default_feature_3",
      "label": "Feature 3 Bullet Text",
      "default": "Zero Toxins"
    },
    {
      "type": "select",
      "id": "default_feature_3_icon",
      "label": "Feature 3 Icon",
      "options": [
        { "value": "star", "label": "Star" },
        { "value": "check", "label": "Checkmark" },
        { "value": "leaf", "label": "Leaf" },
        { "value": "shield", "label": "Shield" }
      ],
      "default": "shield"
    },
    {
      "type": "text",
      "id": "default_learn_text",
      "label": "Learn More Button Text",
      "default": "Learn More"
    },
    {
      "type": "text",
      "id": "default_cart_text",
      "label": "Add to Cart Button Text",
      "default": "Add To Cart"
    },

    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "MEET THE WHIPPED TALLOW HONEY BALM"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "NO FLUFF - JUST RESULTS!"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Section Description",
      "default": "Choose the balm that fits your needs — each formula is packed with healing fats, soothing botanicals, and zero BS. Built for glow-ups, not gimmicks."
    },
    {
      "type": "checkbox",
      "id": "show_trust_badges",
      "label": "Show Trust Badges",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_1_text",
      "label": "Badge 1 Text",
      "default": "Made in USA"
    },
    {
      "type": "text",
      "id": "badge_2_text",
      "label": "Badge 2 Text",
      "default": "100% Natural Ingredients"
    },
    {
      "type": "text",
      "id": "badge_3_text",
      "label": "Badge 3 Text",
      "default": "30-Day Money-Back Guarantee"
    },

    {
      "type": "header",
      "content": "Colors & Styling"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#FAF7EF"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle Color",
      "default": "#E63946"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Description Text Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#FFFDF5"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card Border Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "btn_cart_bg",
      "label": "Add to Cart Button Background",
      "default": "#F3AD12"
    },
    {
      "type": "color",
      "id": "btn_cart_text_color",
      "label": "Add to Cart Button Text Color",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Custom Product Grid"
    }
  ]
}
{% endschema %}
