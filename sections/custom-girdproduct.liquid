<!-- sections/custom-girdproduct.liquid -->
<link href="https://cdn.jsdelivr.net/npm/remixicon@4.3.0/fonts/remixicon.css" rel="stylesheet" media="print" onload="this.media='all'">

{%- style -%}
  .maison_commerce_product_cards_eg-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color | default: '#ffffff' }};
  }

  /* Rich Text Header */
  .maison-grid-header {
    text-align: center;
    margin-bottom: 40px;
    padding: 0 15px;
  }
  
  .maison-grid-header__caption {
    color: {{ section.settings.accent_color | default: '#ffa004' }};
    font-size: 14px;
    font-weight: 700;
    line-height: 24px;
    text-transform: uppercase;
    margin-bottom: 12px;
    letter-spacing: 0.05em;
    font-family: var(--font-body-family), 'Poppins', sans-serif;
  }
  
  @media (max-width: 768px) {
    .maison-grid-header__caption {
      font-size: 12px;
    }
  }
  
  .maison-grid-header__title {
    font-family: var(--font-heading-family), 'Poppins', sans-serif;
    font-size: 48px;
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 20px 0;
    color: {{ section.settings.border_color | default: '#2c2609' }};
    text-transform: uppercase;
  }
  
  @media (max-width: 768px) {
    .maison-grid-header__title {
      font-size: 32px;
    }
  }
  
  .maison-grid-header__text {
    font-size: 16px;
    line-height: 1.5;
    max-width: 800px;
    margin: 0 auto 30px auto;
    color: {{ section.settings.text_color | default: '#555555' }};
    font-family: var(--font-body-family), 'Poppins', sans-serif;
  }
  
  .maison__inline-benefits {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  
  .maison__inline-benefit {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  
  .maison__inline-benefit svg {
    width: 21px;
    height: 20px;
    display: block;
  }
  
  .maison__inline-benefit-text {
    font-size: 14px;
    font-weight: 700;
    color: {{ section.settings.border_color | default: '#2c2609' }};
    font-family: var(--font-body-family), 'Poppins', sans-serif;
  }

  /* Grid Container */
  .ml-grid-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    box-sizing: border-box;
  }

  /* Grid Layout */
  .ml-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
  }

  @media (max-width: 1200px) {
    .ml-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 25px;
    }
  }

  @media (max-width: 992px) {
    .ml-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }

  @media (max-width: 576px) {
    .ml-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }

  /* Card Styles */
  .ml-card {
    border: 1.5px solid {{ section.settings.border_color | default: '#2C2609' }};
    border-radius: 16px;
    background-color: {{ section.settings.card_bg | default: '#ffffff' }};
    padding: 24px;
    display: flex;
    flex-direction: column;
    height: 100%;
    box-sizing: border-box;
    box-shadow: 0px 4px 0px 0px {{ section.settings.border_color | default: '#2C2609' }};
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    position: relative;
    top: 0;
  }

  .ml-card:hover {
    transform: translateY(2px);
    box-shadow: 0px 2px 0px 0px {{ section.settings.border_color | default: '#2C2609' }};
  }

  .ml-card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    width: 100%;
    box-sizing: border-box;
    min-height: 28px;
  }

  .ml-badge-new {
    background-color: {{ section.settings.accent_color | default: '#ffa004' }};
    color: {{ section.settings.border_color | default: '#2c2609' }};
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 6px 12px;
    border-radius: 20px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .ml-rating {
    border: 1.5px solid #e2e2e2;
    border-radius: 20px;
    padding: 4px 12px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    font-weight: 700;
    color: {{ section.settings.border_color | default: '#2c2609' }};
    background-color: #ffffff;
  }

  .ml-rating .sep {
    color: #e2e2e2;
    margin: 0 2px;
  }

  .ml-rating .count {
    color: #666666;
  }

  .ml-image-wrap {
    background-color: #f6f6f6;
    border-radius: 12px;
    padding: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    min-height: 220px;
    width: 100%;
    box-sizing: border-box;
    overflow: hidden;
  }

  .ml-image-link {
    display: block;
    width: 100%;
    text-align: center;
  }

  .ml-img-primary {
    max-width: 100%;
    max-height: 180px;
    height: auto;
    object-fit: contain;
    display: inline-block;
    transition: transform 0.3s ease;
  }

  .ml-card:hover .ml-img-primary {
    transform: scale(1.04);
  }

  .ml-title {
    font-size: 20px;
    font-weight: 800;
    margin: 0 0 10px 0;
    color: {{ section.settings.border_color | default: '#2c2609' }};
    line-height: 1.25;
    font-family: var(--font-heading-family), inherit;
    text-transform: none;
    flex-grow: 0;
  }

  .ml-title-link {
    color: inherit;
    text-decoration: none;
  }

  .ml-title-link:hover {
    text-decoration: none;
  }

  .ml-desc {
    font-size: 13px;
    line-height: 1.5;
    color: #555555;
    margin: 0 0 16px 0;
    flex-grow: 1;
  }

  .ml-desc strong {
    color: {{ section.settings.border_color | default: '#2c2609' }};
  }

  .ml-price-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .ml-price-current {
    font-size: 22px;
    font-weight: 900;
    color: {{ section.settings.border_color | default: '#2c2609' }};
  }

  .ml-price-old {
    font-size: 15px;
    text-decoration: line-through;
    color: #888888;
  }

  .ml-discount {
    background-color: #000000;
    color: {{ section.settings.active_tab_bg | default: '#fedb36' }};
    font-size: 11px;
    font-weight: 700;
    padding: 4px 8px;
    border-radius: 6px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    display: inline-block;
  }

  .ml-variant-wrap {
    margin-bottom: 16px;
    width: 100%;
    box-sizing: border-box;
  }

  .ml-variant-select {
    width: 100%;
    height: 48px;
    padding: 0 36px 0 16px;
    border-radius: 8px;
    border: 1.5px solid {{ section.settings.border_color | default: '#2C2609' }};
    background-color: #ffffff;
    font-size: 12px;
    font-weight: 700;
    color: {{ section.settings.border_color | default: '#2c2609' }};
    letter-spacing: 0.02em;
    text-transform: uppercase;
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    cursor: pointer;
    box-sizing: border-box;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='24' height='24' viewBox='0 0 24 24' fill='none' stroke='%232C2609' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polyline points='6 9 12 15 18 9'/></svg>");
    background-repeat: no-repeat;
    background-position: right 14px center;
    background-size: 16px;
  }

  .ml-variant-select:focus {
    outline: none;
    border-color: {{ section.settings.accent_color | default: '#ffa004' }};
  }

  .ml-atc {
    width: 100%;
    height: 48px;
    background-color: #000000;
    color: #ffffff;
    border: none;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.1s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 0 20px;
    box-sizing: border-box;
  }

  .ml-atc:hover {
    background-color: #222222;
  }

  .ml-atc:active {
    transform: scale(0.98);
  }

  .ml-preorder-notice {
    font-size: 11px;
    color: #f63208;
    margin-top: 8px;
    font-weight: 600;
    line-height: 1.4;
  }
{%- endstyle -%}

{%- assign show_placeholders = true -%}
{%- if section.settings.collection != blank -%}
  {%- assign show_placeholders = false -%}
{%- else -%}
  {%- for block in section.blocks -%}
    {%- if block.settings.product != blank -%}
      {%- assign show_placeholders = false -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

<div class="maison_commerce_product_cards_eg-{{ section.id }}">
  <div class="ml-grid-container">
    
    <!-- Rich Text Header -->
    <div class="maison-grid-header">
      {%- if section.settings.caption != blank -%}
        <p class="maison-grid-header__caption">{{ section.settings.caption }}</p>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="maison-grid-header__title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <div class="maison-grid-header__text">
          {{ section.settings.description }}
        </div>
      {%- endif -%}
      
      <!-- Top Benefits Inline List -->
      <div class="maison__inline-benefits">
        {%- if section.settings.benefit_1 != blank -%}
          <div class="maison__inline-benefit">
            <svg width="21" height="20" viewBox="0 0 21 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <g>
                <path d="M10.5006 19.2857C15.629 19.2857 19.7863 15.1284 19.7863 10C19.7863 4.87165 15.629 0.714294 10.5006 0.714294C5.3722 0.714294 1.21484 4.87165 1.21484 10C1.21484 15.1284 5.3722 19.2857 10.5006 19.2857Z" fill="#fedb36"></path>
                <path d="M10.5006 19.2857C15.629 19.2857 19.7863 15.1284 19.7863 10C19.7863 4.87165 15.629 0.714294 10.5006 0.714294C5.3722 0.714294 1.21484 4.87165 1.21484 10C1.21484 15.1284 5.3722 19.2857 10.5006 19.2857Z" stroke="#2c2609" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"></path>
                <path d="M14.6671 6.78574L8.95285 13.9286L6.0957 11.7857" stroke="#2c2609" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"></path>
              </g>
            </svg>
            <span class="maison__inline-benefit-text"><strong>{{ section.settings.benefit_1 }}</strong></span>
          </div>
        {%- endif -%}

        {%- if section.settings.benefit_2 != blank -%}
          <div class="maison__inline-benefit">
            <svg width="21" height="20" viewBox="0 0 21 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <g>
                <path d="M10.5006 19.2857C15.629 19.2857 19.7863 15.1284 19.7863 10C19.7863 4.87165 15.629 0.714294 10.5006 0.714294C5.3722 0.714294 1.21484 4.87165 1.21484 10C1.21484 15.1284 5.3722 19.2857 10.5006 19.2857Z" fill="#fedb36"></path>
                <path d="M10.5006 19.2857C15.629 19.2857 19.7863 15.1284 19.7863 10C19.7863 4.87165 15.629 0.714294 10.5006 0.714294C5.3722 0.714294 1.21484 4.87165 1.21484 10C1.21484 15.1284 5.3722 19.2857 10.5006 19.2857Z" stroke="#2c2609" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"></path>
                <path d="M14.6671 6.78574L8.95285 13.9286L6.0957 11.7857" stroke="#2c2609" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"></path>
              </g>
            </svg>
            <span class="maison__inline-benefit-text"><strong>{{ section.settings.benefit_2 }}</strong></span>
          </div>
        {%- endif -%}

        {%- if section.settings.benefit_3 != blank -%}
          <div class="maison__inline-benefit">
            <svg width="21" height="20" viewBox="0 0 21 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <g>
                <path d="M10.5006 19.2857C15.629 19.2857 19.7863 15.1284 19.7863 10C19.7863 4.87165 15.629 0.714294 10.5006 0.714294C5.3722 0.714294 1.21484 4.87165 1.21484 10C1.21484 15.1284 5.3722 19.2857 10.5006 19.2857Z" fill="#fedb36"></path>
                <path d="M10.5006 19.2857C15.629 19.2857 19.7863 15.1284 19.7863 10C19.7863 4.87165 15.629 0.714294 10.5006 0.714294C5.3722 0.714294 1.21484 4.87165 1.21484 10C1.21484 15.1284 5.3722 19.2857 10.5006 19.2857Z" stroke="#2c2609" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"></path>
                <path d="M14.6671 6.78574L8.95285 13.9286L6.0957 11.7857" stroke="#2c2609" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"></path>
              </g>
            </svg>
            <span class="maison__inline-benefit-text"><strong>{{ section.settings.benefit_3 }}</strong></span>
          </div>
        {%- endif -%}
      </div>
    </div>

    <!-- Products Cards Grid -->
    <div class="ml-grid">
      {%- if show_placeholders -%}
        
        {%- comment -%} ==========================================
           RENDER STATIC PLACEHOLDER MOCKUPS (Works out-of-the-box)
           ========================================== {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'product_card' -%}
            {%- assign has_card_image = false -%}
            {%- assign card_image_url = "" -%}
            {%- if block.settings.image != blank -%}
              {%- assign card_image_url = block.settings.image | image_url: width: 400 -%}
              {%- assign has_card_image = true -%}
            {%- elsif block.settings.image_fallback != blank -%}
              {%- assign card_image_url = block.settings.image_fallback -%}
              {%- assign has_card_image = true -%}
            {%- endif -%}

            <article class="ml-card" itemscope="" itemtype="http://schema.org/Product" {{ block.shopify_attributes }}>
              <!-- Top bar with badges -->
              <div class="ml-card-top">
                {%- assign badge = block.settings.badge_text | default: "Best Seller" -%}
                {%- if badge != blank -%}
                  <div class="ml-badge-new">{{ badge }}</div>
                {%- endif -%}
                
                {%- assign rat_val = block.settings.rating_value | default: "4.5" -%}
                {%- assign rev_cnt = block.settings.review_count | default: "28" -%}
                <div class="ml-rating">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="#FFA004" style="display:inline-block; vertical-align:middle; margin-right:2px;">
                    <path d="M12 .587l3.668 7.431 8.2 1.192-5.934 5.787 1.4 8.168L12 18.896l-7.334 3.857 1.4-8.168L.132 9.21l8.2-1.192z"/>
                  </svg>
                  <span>{{ rat_val }}</span>
                  <span class="sep">|</span>
                  <span class="count">{{ rev_cnt }}</span>
                  <span style="font-size: 11px; margin-left: 2px;">Reviews</span>
                </div>
              </div>
              
              <!-- Image -->
              <div class="ml-image-wrap">
                {%- if has_card_image -%}
                  <a href="{{ block.settings.learn_more_url | default: '#' }}" class="ml-image-link" aria-label="{{ block.settings.title | escape }}">
                    <img class="ml-img-primary" itemprop="image" src="{{ card_image_url }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="300">
                  </a>
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
              
              <!-- Title -->
              <h3 class="ml-title" itemprop="name">
                <a href="{{ block.settings.learn_more_url | default: '#' }}" class="ml-title-link">{{ block.settings.title }}</a>
              </h3>
              
              <!-- Description -->
              {%- if block.settings.description != blank -%}
                <div class="ml-desc">{{ block.settings.description }}</div>
              {%- endif -%}
              
              <!-- Price wrap -->
              <div class="ml-price-wrap">
                <span class="ml-price-current">{{ block.settings.price }}</span>
                {%- if block.settings.compare_price != blank -%}
                  <span class="ml-price-old">{{ block.settings.compare_price }}</span>
                  {%- assign v_discount = "" -%}
                  {%- assign p_val = block.settings.price | replace: "$", "" | replace: "£", "" | replace: "€", "" | plus: 0.0 -%}
                  {%- assign c_val = block.settings.compare_price | replace: "$", "" | replace: "£", "" | replace: "€", "" | plus: 0.0 -%}
                  {%- if c_val > p_val -%}
                    {%- assign diff = c_val | minus: p_val -%}
                    {%- assign pct = diff | times: 100.0 | divided_by: c_val | round -%}
                    {%- assign v_discount = pct | append: "% OFF" -%}
                  {%- endif -%}
                  {%- if v_discount != blank -%}
                    <span class="ml-discount">{{ v_discount }}</span>
                  {%- endif -%}
                {%- else -%}
                  <span class="ml-price-old" style="display: none;"></span>
                  <span class="ml-discount" style="display: none;"></span>
                {%- endif -%}
              </div>
              
              <!-- Form -->
              <form method="post" action="/cart/add" class="form" enctype="multipart/form-data">
                <input type="hidden" name="quantity" value="1">
                
                <!-- Variant select -->
                {%- if block.settings.show_variants -%}
                  <div class="ml-variant-wrap">
                    <select name="id" class="ml-variant-select">
                      {%- if block.settings.variant_1_name != blank -%}
                        {%- assign v_discount = "" -%}
                        {%- if block.settings.variant_1_compare != blank and block.settings.variant_1_price != blank -%}
                          {%- assign p_val = block.settings.variant_1_price | replace: "$", "" | replace: "£", "" | replace: "€", "" | plus: 0.0 -%}
                          {%- assign c_val = block.settings.variant_1_compare | replace: "$", "" | replace: "£", "" | replace: "€", "" | plus: 0.0 -%}
                          {%- if c_val > p_val -%}
                            {%- assign diff = c_val | minus: p_val -%}
                            {%- assign pct = diff | times: 100.0 | divided_by: c_val | round -%}
                            {%- assign v_discount = pct | append: "% OFF" -%}
                          {%- endif -%}
                        {%- endif -%}
                        <option value="{{ block.settings.variant_1_id }}" 
                          data-price="{{ block.settings.variant_1_price }}" 
                          data-compare="{{ block.settings.variant_1_compare }}" 
                          data-discount="{{ v_discount }}"
                          selected="selected">
                          {{ block.settings.variant_1_name | uppercase }}
                        </option>
                      {%- endif -%}
                      {%- if block.settings.variant_2_name != blank -%}
                        {%- assign v_discount = "" -%}
                        {%- if block.settings.variant_2_compare != blank and block.settings.variant_2_price != blank -%}
                          {%- assign p_val = block.settings.variant_2_price | replace: "$", "" | replace: "£", "" | replace: "€", "" | plus: 0.0 -%}
                          {%- assign c_val = block.settings.variant_2_compare | replace: "$", "" | replace: "£", "" | replace: "€", "" | plus: 0.0 -%}
                          {%- if c_val > p_val -%}
                            {%- assign diff = c_val | minus: p_val -%}
                            {%- assign pct = diff | times: 100.0 | divided_by: c_val | round -%}
                            {%- assign v_discount = pct | append: "% OFF" -%}
                          {%- endif -%}
                        {%- endif -%}
                        <option value="{{ block.settings.variant_2_id }}" 
                          data-price="{{ block.settings.variant_2_price }}" 
                          data-compare="{{ block.settings.variant_2_compare }}" 
                          data-discount="{{ v_discount }}">
                          {{ block.settings.variant_2_name | uppercase }}
                        </option>
                      {%- endif -%}
                      {%- if block.settings.variant_3_name != blank -%}
                        {%- assign v_discount = "" -%}
                        {%- if block.settings.variant_3_compare != blank and block.settings.variant_3_price != blank -%}
                          {%- assign p_val = block.settings.variant_3_price | replace: "$", "" | replace: "£", "" | replace: "€", "" | plus: 0.0 -%}
                          {%- assign c_val = block.settings.variant_3_compare | replace: "$", "" | replace: "£", "" | replace: "€", "" | plus: 0.0 -%}
                          {%- if c_val > p_val -%}
                            {%- assign diff = c_val | minus: p_val -%}
                            {%- assign pct = diff | times: 100.0 | divided_by: c_val | round -%}
                            {%- assign v_discount = pct | append: "% OFF" -%}
                          {%- endif -%}
                        {%- endif -%}
                        <option value="{{ block.settings.variant_3_id }}" 
                          data-price="{{ block.settings.variant_3_price }}" 
                          data-compare="{{ block.settings.variant_3_compare }}" 
                          data-discount="{{ v_discount }}">
                          {{ block.settings.variant_3_name | uppercase }}
                        </option>
                      {%- endif -%}
                      {%- if block.settings.variant_4_name != blank -%}
                        {%- assign v_discount = "" -%}
                        {%- if block.settings.variant_4_compare != blank and block.settings.variant_4_price != blank -%}
                          {%- assign p_val = block.settings.variant_4_price | replace: "$", "" | replace: "£", "" | replace: "€", "" | plus: 0.0 -%}
                          {%- assign c_val = block.settings.variant_4_compare | replace: "$", "" | replace: "£", "" | replace: "€", "" | plus: 0.0 -%}
                          {%- if c_val > p_val -%}
                            {%- assign diff = c_val | minus: p_val -%}
                            {%- assign pct = diff | times: 100.0 | divided_by: c_val | round -%}
                            {%- assign v_discount = pct | append: "% OFF" -%}
                          {%- endif -%}
                        {%- endif -%}
                        <option value="{{ block.settings.variant_4_id }}" 
                          data-price="{{ block.settings.variant_4_price }}" 
                          data-compare="{{ block.settings.variant_4_compare }}" 
                          data-discount="{{ v_discount }}">
                          {{ block.settings.variant_4_name | uppercase }}
