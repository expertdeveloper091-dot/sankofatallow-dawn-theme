                  </a>
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
              
              <!-- Title -->
              <h3 class="ml-title" itemprop="name">
                <a href="{{ product.url }}" class="ml-title-link">{{ product_title }}</a>
              </h3>
              
              <!-- Description -->
              {%- if product_desc != blank -%}
                <div class="ml-desc">{{ product_desc }}</div>
              {%- endif -%}
              
              <!-- Price wrap -->
              <div class="ml-price-wrap">
                <span class="ml-price-current">{{ product.price | money }}</span>
                {%- if product.compare_at_price > product.price -%}
                  <span class="ml-price-old">{{ product.compare_at_price | money }}</span>
                  {%- assign diff = product.compare_at_price | minus: product.price -%}
                  {%- assign pct = diff | times: 100.0 | divided_by: product.compare_at_price | round -%}
                  <span class="ml-discount">{{ pct }}% OFF</span>
                {%- else -%}
                  <span class="ml-price-old" style="display: none;"></span>
                  <span class="ml-discount" style="display: none;"></span>
                {%- endif -%}
              </div>
              
              <!-- Form -->
              <form method="post" action="/cart/add" class="form" enctype="multipart/form-data">
                <input type="hidden" name="quantity" value="1">
                
                <!-- Variant select -->
                {%- if product.variants.size > 0 -%}
                  <div class="ml-variant-wrap">
                    <select name="id" class="ml-variant-select">
                      {%- for variant in product.variants -%}
                        {%- assign var_discount = "" -%}
                        {%- if variant.compare_at_price > variant.price -%}
                          {%- assign diff = variant.compare_at_price | minus: variant.price -%}
                          {%- assign pct = diff | times: 100.0 | divided_by: variant.compare_at_price | round -%}
                          {%- assign var_discount = pct | append: "% OFF" -%}
                        {%- endif -%}
                        <option value="{{ variant.id }}" 
                          data-price="{{ variant.price | money }}" 
                          data-compare="{% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money }}{% endif %}"
                          data-discount="{{ var_discount }}"
                          {% if variant.id == product.selected_or_first_available_variant.id %}selected="selected"{% endif %}>
                          {{ variant.title | uppercase }}
                        </option>
                      {%- endfor -%}
                    </select>
                  </div>
                {%- else -%}
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                {%- endif -%}
                
                <button type="submit" class="ml-atc">{{ button_label }}</button>
              </form>
              
              {%- if pre_notice != blank -%}
                <div class="ml-preorder-notice">{{ pre_notice }}</div>
              {%- endif -%}
            </article>

          {%- endfor -%}
        {%- else -%}
          
          {%- comment -%} ==========================================
             RENDER DYNAMICALLY ADDED INDIVIDUAL PRODUCT BLOCKS
             ========================================== {%- endcomment -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'product_card' and block.settings.product != blank -%}
              {%- assign product = block.settings.product -%}

              {%- assign product_title = product.title -%}
              {%- if block.settings.title != blank -%}
                {%- assign product_title = block.settings.title -%}
