<!-- sections/custom-girdproduct.liquid -->
{{ 'https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css' | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .custom-gridproduct-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | default: 60 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 60 }}px;
    background-color: {{ section.settings.bg_color | default: '#FAF7EF' }};
  }

  .custom-gridproduct-container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 40px;
    box-sizing: border-box;
  }

  @media (max-width: 768px) {
    .custom-gridproduct-container {
      padding: 0 20px;
    }
  }

  .custom-gridproduct-{{ section.id }} .ml-product-card {
    background-color: rgb(255 248 237) !important;
  }

  .custom-gridproduct-{{ section.id }} .ml-card-btn--atc {
    width: 100%;
    height: 100%;
    background: #fe9d01 !important;
    color: #000000 !important;
    border: none !important;
    cursor: pointer;
  }

  /* Header */
  .custom-gridproduct-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .custom-gridproduct-subtitle {
    color: {{ section.settings.subtitle_color | default: '#E63946' }};
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 8px;
    font-family: 'Poppins', sans-serif;
  }

  .custom-gridproduct-heading {
    color: {{ section.settings.heading_color | default: '#111111' }};
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 900;
    text-transform: uppercase;
    margin: 0 0 14px 0;
    line-height: 1.15;
    font-family: 'Poppins', sans-serif;
  }

  .custom-gridproduct-desc {
    color: {{ section.settings.text_color | default: '#333333' }};
    font-size: 15px;
    line-height: 1.6;
    max-width: 750px;
    margin: 0 auto 24px auto;
    font-family: 'Poppins', sans-serif;
  }

  /* Trust Badges */
  .custom-gridproduct-trust {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
    margin-bottom: 10px;
  }

  .custom-gridproduct-trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 700;
    color: {{ section.settings.heading_color | default: '#111111' }};
    font-family: 'Poppins', sans-serif;
  }

  .custom-gridproduct-trust-item svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  /* Grid Layout - Matching Shop Page 2-Column Grid */
  .custom-gridproduct-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 30px;
    align-items: stretch;
  }

  @media (max-width: 768px) {
    .custom-gridproduct-grid {
      grid-template-columns: 1fr !important;
      gap: 20px !important;
    }
  }
{%- endstyle -%}

<div class="custom-gridproduct-{{ section.id }}">
  <div class="custom-gridproduct-container">

    <!-- Header Section -->
    <div class="custom-gridproduct-header">
      {%- if section.settings.subtitle != blank -%}
        <div class="custom-gridproduct-subtitle">{{ section.settings.subtitle | escape }}</div>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="custom-gridproduct-heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <div class="custom-gridproduct-desc">{{ section.settings.description }}</div>
      {%- endif -%}

      {%- if section.settings.show_trust_badges -%}
        <div class="custom-gridproduct-trust">
          {%- if section.settings.badge_1_text != blank -%}
            <div class="custom-gridproduct-trust-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="#F3AD12" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              <span>{{ section.settings.badge_1_text | escape }}</span>
            </div>
          {%- endif -%}

          {%- if section.settings.badge_2_text != blank -%}
            <div class="custom-gridproduct-trust-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="#F3AD12" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              <span>{{ section.settings.badge_2_text | escape }}</span>
            </div>
          {%- endif -%}

          {%- if section.settings.badge_3_text != blank -%}
            <div class="custom-gridproduct-trust-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="#F3AD12" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              <span>{{ section.settings.badge_3_text | escape }}</span>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Product Grid (Renders Exact Shop Page 'card-product' Component) -->
    <div class="custom-gridproduct-grid">
      {%- assign selected_collection = section.settings.collection -%}
      {%- if selected_collection == blank -%}
        {%- assign selected_collection = collections['all'] -%}
      {%- endif -%}

      {%- if selected_collection != blank and selected_collection.products_count > 0 -%}
        {%- for product in selected_collection.products limit: section.settings.products_to_show -%}
          {% render 'card-product',
            card_product: product,
            section_id: section.id,
            product_view_context: 'collection'
          %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..2) -%}
          {% render 'card-product', section_id: section.id %}
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Custom Product Grid",
  "settings": [
    {
      "type": "header",
      "content": "Collection Source"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 24,
      "step": 1,
      "default": 8,
      "label": "Maximum Products to Show"
    },

    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "MEET THE WHIPPED TALLOW HONEY BALM"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "NO FLUFF - JUST RESULTS!"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Section Description",
      "default": "Choose the balm that fits your needs — each formula is packed with healing fats, soothing botanicals, and zero BS. Built for glow-ups, not gimmicks."
    },
    {
      "type": "checkbox",
      "id": "show_trust_badges",
      "label": "Show Trust Badges",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_1_text",
      "label": "Badge 1 Text",
      "default": "Made in USA"
    },
    {
      "type": "text",
      "id": "badge_2_text",
      "label": "Badge 2 Text",
      "default": "100% Natural Ingredients"
    },
    {
      "type": "text",
      "id": "badge_3_text",
      "label": "Badge 3 Text",
      "default": "30-Day Money-Back Guarantee"
    },

    {
      "type": "header",
      "content": "Colors & Styling"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#FAF7EF"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle Color",
      "default": "#E63946"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Description Text Color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Custom Product Grid"
    }
  ]
}
{% endschema %}
