  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const selectElements = document.querySelectorAll('.ml-variant-select');
    selectElements.forEach(select => {
      select.addEventListener('change', function() {
        const selectedOption = this.options[this.selectedIndex];
        const price = selectedOption.getAttribute('data-price');
        const comparePrice = selectedOption.getAttribute('data-compare');
        const discount = selectedOption.getAttribute('data-discount');
        
        const card = this.closest('.ml-card');
        if (!card) return;
        
        // Update current price
        const currentPriceEl = card.querySelector('.ml-price-current');
        if (currentPriceEl) currentPriceEl.textContent = price;
        
        // Update compare-at price
        const oldPriceEl = card.querySelector('.ml-price-old');
        if (oldPriceEl) {
          if (comparePrice && comparePrice !== '') {
            oldPriceEl.textContent = comparePrice;
            oldPriceEl.style.display = '';
          } else {
            oldPriceEl.style.display = 'none';
          }
        }
        
        // Update discount badge
        const discountEl = card.querySelector('.ml-discount');
        if (discountEl) {
          if (discount && discount !== '') {
            discountEl.textContent = discount;
            discountEl.style.display = '';
          } else {
            discountEl.style.display = 'none';
          }
        }
      });
    });
  });
</script>

