              {%- assign product_desc = override_block.settings.description -%}
            {%- endif -%}

            {%- assign button_label = override_block.settings.button_text | default: "Add To Cart" -%}
            {%- assign pre_notice = override_block.settings.pre_order_notice -%}

            <article class="ml-card" itemscope="" itemtype="http://schema.org/Product">
              <!-- Top bar with badges -->
              <div class="ml-card-top">
                {%- assign badge = "Best Seller" -%}
                {%- if override_block != blank and override_block.settings.badge_text != blank -%}
