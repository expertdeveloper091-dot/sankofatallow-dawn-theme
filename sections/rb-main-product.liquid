{% comment %}
  rb-main-product.liquid
  100% Dynamic Shopify OS 2.0 Product Section
  Namespace: rb-*
{% endcomment %}

{{ 'rb-product.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
-%}

<script>
  window.__rbProductData = {
    id: {{ product.id | json }},
    handle: {{ product.handle | json }},
    url: {{ product.url | json }},
    currentVariantId: {{ current_variant.id | json }},
    variants: {{ product.variants | json }},
    media: [
      {%- for media in product.media -%}
        { "id": {{ media.id }}, "src": {{ media | img_url: '800x800' | json }}, "thumb": {{ media | img_url: '120x120', crop: 'center' | json }}, "alt": {{ media.alt | default: product.title | json }}, "type": {{ media.media_type | json }} }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  };
</script>

<div class="rb-product-wrapper" id="rb-product-root" data-section-id="{{ section.id }}" data-product-id="{{ product.id }}">

  {%- comment %} Breadcrumb {%- endcomment %}
  <nav class="rb-breadcrumb" aria-label="breadcrumb">
    <a href="{{ routes.root_url }}">Home</a>
    <span aria-hidden="true">›</span>
    {%- if collection -%}
      <a href="{{ collection.url }}">{{ collection.title }}</a>
      <span aria-hidden="true">›</span>
    {%- endif -%}
    <span>{{ product.title }}</span>
  </nav>

  <div class="rb-product-grid">

    {%- comment %} Media Gallery Snippet {%- endcomment %}
    {% render 'rb-product-gallery', product: product %}

    {%- comment %} Product Info Column Snippet {%- endcomment %}
    {% render 'rb-product-info', product: product, section: section %}

  </div>
</div>

{%- comment %} Fake Orders Toast Snippet {%- endcomment %}
{% render 'rb-fake-orders', product: product %}

{%- comment %} Sticky ATC Bar Snippet {%- endcomment %}
{% render 'rb-sticky-atc', product: product, current_variant: current_variant, section: section %}

<script src="{{ 'rb-product.js' | asset_url }}" defer></script>
<script src="{{ 'rb-gallery.js' | asset_url }}" defer></script>
<script src="{{ 'rb-fake-orders.js' | asset_url }}" defer></script>
<script src="{{ 'rb-sticky-atc.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "RB Product (Clay Design)",
  "tag": "section",
  "class": "rb-main-product-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_save_badge",
      "label": "Show discount % badge",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sold_count",
      "label": "Show sold counter",
      "default": true
    },
    {
      "type": "number",
      "id": "sold_count",
      "label": "Sold count number",
      "default": 12
    },
    {
      "type": "text",
      "id": "sold_text",
      "label": "Sold counter suffix",
      "default": "sold in last 20 hours"
    }
  ],
  "blocks": [
    {
      "type": "delivery_box",
      "name": "📦 Delivery Info Box",
      "limit": 1,
      "settings": [
        { "type": "checkbox", "id": "show_row1", "label": "Show row 1", "default": true },
        { "type": "image_picker", "id": "row1_icon_image", "label": "Row 1 icon (optional PNG/SVG)" },
        { "type": "richtext", "id": "row1_text", "label": "Row 1 text", "default": "<p><strong>Estimate delivery time:</strong> Delivery within <strong>3–7 working days.</strong> You'll be updated along the way.</p>" },
        { "type": "checkbox", "id": "show_row2", "label": "Show row 2", "default": true },
        { "type": "image_picker", "id": "row2_icon_image", "label": "Row 2 icon (optional PNG/SVG)" },
        { "type": "richtext", "id": "row2_text", "label": "Row 2 text", "default": "<p><strong>Cash on Delivery (COD) only.</strong> Please <strong>check your parcel before payment.</strong></p>" },
        { "type": "checkbox", "id": "show_row3", "label": "Show row 3", "default": true },
        { "type": "image_picker", "id": "row3_icon_image", "label": "Row 3 icon (optional PNG/SVG)" },
        { "type": "richtext", "id": "row3_text", "label": "Row 3 text", "default": "<p><strong>Shipping charges:</strong> Flat <strong>Rs.199</strong> on all orders — <strong>FREE shipping above Rs.10,000.</strong></p>" }
      ]
    },
    {
      "type": "live_visitors",
      "name": "👁 Live Visitor Counter",
      "limit": 1,
      "settings": [
        { "type": "number", "id": "min_count", "label": "Minimum visitors", "default": 8 },
        { "type": "number", "id": "max_count", "label": "Maximum visitors", "default": 40 },
        { "type": "text", "id": "suffix_text", "label": "Suffix text", "default": "peoples are viewing this right now" }
      ]
    },
    {
      "type": "variant_picker",
      "name": "🎨 Variant Picker",
      "limit": 1,
      "settings": []
    },
    {
      "type": "ask_question",
      "name": "❓ Ask a Question",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "link_text", "label": "Link text", "default": "Ask a question" },
        { "type": "select", "id": "contact_type", "label": "Contact via", "options": [{ "value": "email", "label": "Email" }, { "value": "whatsapp", "label": "WhatsApp" }], "default": "whatsapp" },
        { "type": "text", "id": "contact_value", "label": "Email or WhatsApp number" }
      ]
    },
    {
      "type": "stock_countdown",
      "name": "⏳ Stock Countdown",
      "limit": 1,
      "settings": [
        { "type": "checkbox", "id": "use_real_inventory", "label": "Use real Shopify inventory", "default": true },
        { "type": "number", "id": "low_stock_threshold", "label": "Show only when qty is below", "default": 10 },
        { "type": "text", "id": "prefix_text", "label": "Prefix text", "default": "Hurry up! Only" },
        { "type": "number", "id": "display_qty", "label": "Display qty", "default": 1 },
        { "type": "text", "id": "suffix_text", "label": "Suffix text", "default": "items left in stock" },
        { "type": "range", "id": "bar_percent", "label": "Stock bar fill %", "min": 1, "max": 100, "step": 1, "default": 8 },
        { "type": "text", "id": "sold_out_text", "label": "Sold out message", "default": "This product is currently sold out" }
      ]
    },
    {
      "type": "buy_buttons",
      "name": "🛒 Buy Buttons",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "atc_text", "label": "Add to Cart text", "default": "Add to Cart" },
        { "type": "text", "id": "sold_out_text", "label": "Sold out button text", "default": "Sold Out" },
        { "type": "checkbox", "id": "show_buy_now", "label": "Show Buy it now", "default": true },
        { "type": "text", "id": "buy_now_text", "label": "Buy it now text", "default": "Buy it now" },
        { "type": "checkbox", "id": "show_wishlist", "label": "Show Wishlist icon", "default": true },
        { "type": "checkbox", "id": "show_compare", "label": "Show Compare icon", "default": true }
      ]
    },
    {
      "type": "accordion",
      "name": "📄 Accordion Tab",
      "settings": [
        { "type": "text", "id": "heading", "label": "Tab heading", "default": "Description" },
        { "type": "select", "id": "content_source", "label": "Content source", "options": [{ "value": "custom", "label": "Custom text" }, { "value": "description", "label": "Product description" }, { "value": "metafield", "label": "Product metafield" }], "default": "custom" },
        { "type": "text", "id": "metafield_key", "label": "Metafield key (namespace.key)" },
        { "type": "richtext", "id": "content", "label": "Custom content", "default": "<p>Add content here.</p>" }
      ]
    },
    {
      "type": "product_meta",
      "name": "🏷 Product Meta",
      "limit": 1,
      "settings": [
        { "type": "checkbox", "id": "show_sku", "label": "Show SKU", "default": true },
        { "type": "text", "id": "sku_label", "label": "SKU label", "default": "Sku" },
        { "type": "checkbox", "id": "show_availability", "label": "Show availability", "default": true },
        { "type": "text", "id": "avail_label", "label": "Availability label", "default": "Available" },
        { "type": "text", "id": "in_stock_label", "label": "In stock text", "default": "Instock" },
        { "type": "text", "id": "out_of_stock_label", "label": "Out of stock text", "default": "Out of Stock" },
        { "type": "checkbox", "id": "show_collections", "label": "Show collections", "default": true },
        { "type": "text", "id": "collections_label", "label": "Collections label", "default": "Collections" },
        { "type": "checkbox", "id": "show_type", "label": "Show product type", "default": true },
        { "type": "text", "id": "type_label", "label": "Type label", "default": "Type" }
      ]
    },
    {
      "type": "trust_badge",
      "name": "🔒 Trust Badges",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "badge_text", "label": "Heading text", "default": "Guaranteed Safe Checkout" },
        { "type": "image_picker", "id": "badge_image_1", "label": "Custom badge image (optional)" },
        { "type": "text", "id": "badge_1_alt", "label": "Badge image alt text" }
      ]
    },
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "RB Product (Clay Design)"
    }
  ]
}
{% endschema %}
