      "settings": [
        {
          "type": "header",
          "content": "Row 1"
        },
        {
          "type": "checkbox",
          "id": "show_row1",
          "label": "Show row 1",
          "default": true
        },
        {
          "type": "richtext",
          "id": "row1_text",
          "label": "Row 1 text",
          "default": "<p><strong>Estimate delivery time:</strong> Delivery within <strong>3–7 working days.</strong> You'll be updated along the way.</p>"
        },
        {
          "type": "header",
          "content": "Row 2"
        },
        {
          "type": "checkbox",
          "id": "show_row2",
          "label": "Show row 2",
          "default": true
        },
        {
          "type": "richtext",
          "id": "row2_text",
          "label": "Row 2 text",
          "default": "<p><strong>Cash on Delivery (COD) only.</strong> Please <strong>check your parcel before payment.</strong></p>"
        },
        {
          "type": "header",
          "content": "Row 3"
        },
        {
          "type": "checkbox",
          "id": "show_row3",
          "label": "Show row 3",
          "default": true
        },
        {
          "type": "richtext",
          "id": "row3_text",
          "label": "Row 3 text",
          "default": "<p><strong>Shipping charges:</strong> Flat <strong>Rs.199</strong> on all orders — <strong>FREE shipping above Rs.10,000.</strong></p>"
        }
      ]
    },
    {
      "type": "live_visitors",
      "name": "👁 Live Visitor Counter",
      "limit": 1,
      "settings": [
        {
          "type": "number",
          "id": "min_count",
          "label": "Minimum visitors",
          "default": 8
        },
        {
          "type": "number",
          "id": "max_count",
          "label": "Maximum visitors",
          "default": 40
        },
        {
          "type": "text",
          "id": "suffix_text",
          "label": "Suffix text",
          "default": "peoples are viewing this right now"
        }
      ]
    },
    {
      "type": "variant_picker",
      "name": "🎨 Variant Picker",
      "limit": 1,
      "settings": []
    },
    {
      "type": "ask_question",
      "name": "❓ Ask a Question",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "link_text",
          "label": "Link text",
          "default": "Ask a question"
        },
        {
          "type": "select",
          "id": "contact_type",
          "label": "Contact via",
          "options": [
            { "value": "email", "label": "Email" },
            { "value": "whatsapp", "label": "WhatsApp" },
            { "value": "none", "label": "None (scroll to form)" }
