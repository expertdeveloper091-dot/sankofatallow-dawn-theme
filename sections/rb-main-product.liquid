          "default": true
        },
        {
          "type": "text",
          "id": "avail_label",
          "label": "Availability label",
          "default": "Available"
        },
        {
          "type": "text",
          "id": "in_stock_label",
          "label": "In stock text",
          "default": "Instock"
        },
        {
          "type": "text",
          "id": "out_of_stock_label",
          "label": "Out of stock text",
          "default": "Out of Stock"
        },
        {
          "type": "checkbox",
          "id": "show_barcode",
          "label": "Show barcode",
          "default": false
        },
        {
          "type": "text",
          "id": "barcode_label",
          "label": "Barcode label",
          "default": "Barcode"
        },
        {
          "type": "checkbox",
          "id": "show_collections",
          "label": "Show collections",
          "default": true
        },
        {
          "type": "text",
          "id": "collections_label",
          "label": "Collections label",
