      "label": "Sold count number",
      "default": 12
    },
    {
      "type": "text",
      "id": "sold_text",
      "label": "Sold counter suffix",
      "default": "sold in last 20 hours"
    },
    {
      "type": "header",
      "content": "Reviews"
    },
    {
      "type": "checkbox",
      "id": "show_reviews",
