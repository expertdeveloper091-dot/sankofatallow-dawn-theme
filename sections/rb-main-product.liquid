        },
        {
          "type": "text",
          "id": "buy_now_text",
          "label": "Buy it now text",
          "default": "Buy it now"
        },
        {
          "type": "checkbox",
          "id": "show_wishlist",
          "label": "Show Wishlist icon",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_compare",
          "label": "Show Compare icon",
          "default": true
        }
      ]
    },
    {
