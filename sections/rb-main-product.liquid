      ]
    },
    {
      "type": "stock_countdown",
      "name": "⏳ Stock Countdown",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "use_real_inventory",
          "label": "Use real Shopify inventory",
          "default": true,
          "info": "When ON, reads actual inventory quantity from Shopify"
        },
        {
          "type": "number",
          "id": "low_stock_threshold",
          "label": "Show only when qty is below",
          "default": 10,
          "info": "Only shows when real inventory is below this number"
        },
        {
          "type": "text",
          "id": "prefix_text",
          "label": "Prefix text",
          "default": "Hurry up! Only"
        },
        {
          "type": "number",
          "id": "display_qty",
          "label": "Display qty (if not using real inventory)",
          "default": 1
        },
        {
          "type": "text",
          "id": "suffix_text",
          "label": "Suffix text",
          "default": "items left in stock"
        },
        {
          "type": "range",
          "id": "bar_percent",
          "label": "Stock bar fill % (if not using real inventory)",
          "min": 1,
          "max": 100,
          "step": 1,
          "default": 8
        },
        {
          "type": "text",
          "id": "sold_out_text",
