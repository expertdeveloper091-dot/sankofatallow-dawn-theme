          "label": "Show product type",
          "default": true
        },
        {
          "type": "text",
          "id": "type_label",
          "label": "Type label",
          "default": "Type"
        },
        {
          "type": "checkbox",
          "id": "show_tags",
          "label": "Show product tags",
          "default": false
        },
        {
          "type": "text",
          "id": "tags_label",
          "label": "Tags label",
          "default": "Tags"
        }
