<!-- Link Remix Icon Library for fallback icons in case user wants to use classes instead of SVG -->
<link href="https://cdn.jsdelivr.net/npm/remixicon@4.3.0/fonts/remixicon.css" rel="stylesheet" media="print" onload="this.media='all'">

{%- style -%}
  #maison-faq-{{ section.id }} {
    background-color: {{ section.settings.bg_color | default: '#ffffff' }};
    padding-top: {{ section.settings.padding_top | default: 60 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 60 }}px;
    font-family: var(--font-body-family), "Poppins", sans-serif;
    color: {{ section.settings.text_color | default: '#2c2609' }};
  }
  
  #maison-faq-{{ section.id }} .faq__container {
    max-width: {{ section.settings.max_width | default: 1200 }}px;
    margin: 0 auto;
    padding: 0 20px;
    box-sizing: border-box;
  }

  #maison-faq-{{ section.id }} .faq__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: start;
  }

  @media screen and (min-width: 992px) {
    #maison-faq-{{ section.id }} .faq__grid {
      grid-template-columns: 0.45fr 0.55fr;
      gap: 60px;
    }
  }

  #maison-faq-{{ section.id }} .faq__left-col {
    display: flex;
    flex-direction: column;
    position: sticky;
    top: 20px;
  }

  #maison-faq-{{ section.id }} .faq__red-text {
    color: {{ section.settings.accent_color | default: '#ffa004' }};
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 12px;
    display: inline-block;
  }

  #maison-faq-{{ section.id }} .faq__heading {
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 900;
    line-height: 1.1;
    color: {{ section.settings.heading_color | default: '#2c2609' }};
    margin: 0 0 16px 0;
    text-transform: uppercase;
    font-family: var(--font-heading-family), inherit;
  }

  #maison-faq-{{ section.id }} .faq__description {
    font-size: 15px;
    line-height: 1.6;
    color: {{ section.settings.text_color | default: '#555555' }};
    margin: 0 0 30px 0;
  }

  /* Tabs List */
  #maison-faq-{{ section.id }} .faq__tabs-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
    width: 100%;
  }

  @media screen and (min-width: 480px) {
    #maison-faq-{{ section.id }} .faq__tabs-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  #maison-faq-{{ section.id }} .faq__tab-btn {
    display: flex;
    align-items: center;
    text-align: left;
    width: 100%;
    padding: 16px 20px;
    border-radius: 12px;
    border: 1.5px solid {{ section.settings.border_color | default: '#2C2609' }};
    background-color: #ffffff;
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background-color 0.15s ease;
    box-shadow: 0px 4px 0px 0px {{ section.settings.border_color | default: '#2C2609' }};
    position: relative;
    top: 0;
  }

  #maison-faq-{{ section.id }} .faq__tab-btn:hover {
    transform: translateY(2px);
    box-shadow: 0px 2px 0px 0px {{ section.settings.border_color | default: '#2C2609' }};
  }

  #maison-faq-{{ section.id }} .faq__tab-btn.active {
    background-color: {{ section.settings.active_tab_bg | default: '#FEDB36' }};
    transform: translateY(4px);
    box-shadow: 0px 0px 0px 0px {{ section.settings.border_color | default: '#2C2609' }};
  }

  #maison-faq-{{ section.id }} .faq__tab-content {
    display: flex;
    align-items: center;
    gap: 16px;
    width: 100%;
  }

  #maison-faq-{{ section.id }} .faq__tab-icon {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  #maison-faq-{{ section.id }} .faq__tab-icon svg,
  #maison-faq-{{ section.id }} .faq__tab-icon img,
  #maison-faq-{{ section.id }} .faq__tab-icon i {
    width: 100%;
    height: 100%;
    object-fit: contain;
    font-size: 24px;
    color: {{ section.settings.heading_color | default: '#2C2609' }};
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  #maison-faq-{{ section.id }} .faq__tab-text-group {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  #maison-faq-{{ section.id }} .faq__tab-title {
    font-size: 15px;
    font-weight: 700;
    color: {{ section.settings.heading_color | default: '#2C2609' }};
  }

  #maison-faq-{{ section.id }} .faq__tab-count {
    font-size: 12px;
    font-weight: 500;
    color: #666666;
  }

  /* Right Column (Accordion List) */
  #maison-faq-{{ section.id }} .faq__right-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  #maison-faq-{{ section.id }} .faq__category-panel {
    display: none;
    flex-direction: column;
    gap: 16px;
    width: 100%;
  }

  #maison-faq-{{ section.id }} .faq__category-panel.active {
    display: flex;
  }

  #maison-faq-{{ section.id }} .faq__item-card {
    border: 1.5px solid {{ section.settings.border_color | default: '#2C2609' }};
    border-radius: 12px;
    background-color: #ffffff;
    overflow: hidden;
    transition: background-color 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0px 4px 0px 0px {{ section.settings.border_color | default: '#2C2609' }};
    position: relative;
    top: 0;
    margin-bottom: 4px;
  }

  #maison-faq-{{ section.id }} .faq__item-card.active {
    background-color: {{ section.settings.active_faq_bg | default: '#FEF6CF' }};
    box-shadow: 0px 4px 0px 0px {{ section.settings.border_color | default: '#2C2609' }};
  }

  #maison-faq-{{ section.id }} .faq__question-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    cursor: pointer;
    gap: 20px;
    user-select: none;
  }

  #maison-faq-{{ section.id }} .faq__question-text {
    font-size: 16px;
    font-weight: 700;
    line-height: 1.4;
    color: {{ section.settings.heading_color | default: '#2c2609' }};
  }

  #maison-faq-{{ section.id }} .faq__toggle-btn {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1.5px solid {{ section.settings.border_color | default: '#2C2609' }};
    background-color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.2s ease, background-color 0.2s ease;
    color: {{ section.settings.border_color | default: '#2C2609' }};
  }

  #maison-faq-{{ section.id }} .faq__item-card.active .faq__toggle-btn {
    background-color: {{ section.settings.active_tab_bg | default: '#FEDB36' }};
  }

  #maison-faq-{{ section.id }} .faq__toggle-btn svg {
    width: 14px;
    height: 14px;
    display: block;
  }

  #maison-faq-{{ section.id }} .faq__toggle-btn svg path {
    stroke: {{ section.settings.border_color | default: '#2C2609' }};
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  #maison-faq-{{ section.id }} .faq__toggle-btn .minus-icon {
    display: none;
  }

  #maison-faq-{{ section.id }} .faq__toggle-btn .plus-icon {
    display: block;
  }

  #maison-faq-{{ section.id }} .faq__item-card.active .faq__toggle-btn .plus-icon {
    display: none;
  }

  #maison-faq-{{ section.id }} .faq__item-card.active .faq__toggle-btn .minus-icon {
    display: block;
  }

  #maison-faq-{{ section.id }} .faq__answer-panel {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s cubic-bezier(0, 1, 0, 1);
  }

  #maison-faq-{{ section.id }} .faq__item-card.active .faq__answer-panel {
    max-height: 1000px;
    transition: max-height 0.5s cubic-bezier(1, 0, 1, 0);
  }

  #maison-faq-{{ section.id }} .faq__answer-content {
    padding: 0 24px 24px 24px;
    font-size: 14px;
    line-height: 1.6;
    color: {{ section.settings.text_color | default: '#555555' }};
  }

  #maison-faq-{{ section.id }} .faq__answer-content p {
    margin: 0 0 1em 0;
  }
  #maison-faq-{{ section.id }} .faq__answer-content p:last-child {
    margin: 0;
  }
{%- endstyle -%}

<div id="maison-faq-{{ section.id }}" class="faq-section">
  <div class="faq__container">
    <div class="faq__grid">
      
      <!-- Left Column (Headers + Category Tabs) -->
      <div class="faq__left-col">
        {%- if section.settings.red_text != blank -%}
          <span class="faq__red-text">{{ section.settings.red_text }}</span>
        {%- endif -%}
        
        {%- if section.settings.heading != blank -%}
          <h2 class="faq__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        
        {%- if section.settings.description != blank -%}
          <p class="faq__description">{{ section.settings.description }}</p>
        {%- endif -%}
        
        {%- assign category_blocks = section.blocks | where: "type", "category" -%}
        {%- assign faq_items = section.blocks | where: "type", "faq_item" -%}
        
        {%- if category_blocks.size > 0 -%}
          <div class="faq__tabs-list">
            {%- for block in category_blocks -%}
              {%- assign cat_id = block.settings.category_id | downcase | strip -%}
              
              <!-- Calculate dynamic count of questions in this category -->
              {%- assign q_count = 0 -%}
              {%- for item in faq_items -%}
                {%- assign item_cat = item.settings.category_id | downcase | strip -%}
                {%- if item_cat == cat_id -%}
                  {%- assign q_count = q_count | plus: 1 -%}
                {%- endif -%}
              {%- endfor -%}
              
              <button class="faq__tab-btn{% if forloop.first %} active{% endif %}" data-category="{{ cat_id }}" id="block-{{ block.id }}" {{ block.shopify_attributes }}>
                <div class="faq__tab-content">
                  
                  {%- if block.settings.icon_svg != blank or block.settings.icon_class != blank or block.settings.icon_image != blank -%}
                    <div class="faq__tab-icon">
                      {%- if block.settings.icon_svg != blank -%}
                        {{ block.settings.icon_svg }}
                      {%- elsif block.settings.icon_class != blank -%}
                        <i class="{{ block.settings.icon_class }}"></i>
                      {%- elsif block.settings.icon_image != blank -%}
                        <img src="{{ block.settings.icon_image | image_url: width: 64 }}" alt="{{ block.settings.title | escape }}" loading="lazy">
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                  
                  <div class="faq__tab-text-group">
                    <span class="faq__tab-title">{{ block.settings.title }}</span>
                    <span class="faq__tab-count">{{ q_count }} {{ q_count | pluralize: 'question', 'questions' }}</span>
                  </div>
                </div>
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
      
      <!-- Right Column (FAQ Category Accordions) -->
      <div class="faq__right-col">
        {%- if category_blocks.size > 0 -%}
          {%- for category in category_blocks -%}
            {%- assign cat_id = category.settings.category_id | downcase | strip -%}
            
            <div class="faq__category-panel{% if forloop.first %} active{% endif %}" id="{{ cat_id }}">
              {%- assign item_index = 0 -%}
              {%- for item in faq_items -%}
                {%- assign item_cat = item.settings.category_id | downcase | strip -%}
                
                {%- if item_cat == cat_id -%}
                  {%- assign item_index = item_index | plus: 1 -%}
                  
                  <div class="faq__item-card{% if item_index == 1 and category.settings.open_first_faq %} active{% endif %}" id="block-{{ item.id }}" {{ item.shopify_attributes }}>
                    <div class="faq__question-bar">
                      <span class="faq__question-text">{{ item.settings.question }}</span>
                      <button class="faq__toggle-btn" aria-label="Toggle Answer">
                        <svg class="plus-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M10 4V16M4 10H16" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                        </svg>
                        <svg class="minus-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                          <path d="M12 4L4 12M4 4L12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                        </svg>
                      </button>
                    </div>
                    <div class="faq__answer-panel">
                      <div class="faq__answer-content">
                        {{ item.settings.answer }}
                      </div>
                    </div>
                  </div>
                {%- endif -%}
              {%- endfor -%}
              
              {%- if item_index == 0 -%}
                <p style="text-align: center; color: #777; padding: 20px;">No questions added under this category yet.</p>
              {%- endif -%}
            </div>
          {%- endfor -%}
        {%- else -%}
          <p style="text-align: center; color: #777; padding: 20px;">Please add FAQ Categories and FAQ items in the Theme Customizer.</p>
        {%- endif -%}
      </div>
      
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('#maison-faq-{{ section.id }}');
    if (!section) return;

    const tabButtons = section.querySelectorAll('.faq__tab-btn');
    const panels = section.querySelectorAll('.faq__category-panel');
    const faqCards = section.querySelectorAll('.faq__item-card');

    // Tab switching handler
    tabButtons.forEach(button => {
      button.addEventListener('click', function() {
        const categoryId = this.getAttribute('data-category');

        // Toggle active buttons
        tabButtons.forEach(btn => btn.classList.remove('active'));
        this.classList.add('active');

        // Toggle active panels
        panels.forEach(panel => {
          if (panel.id === categoryId) {
            panel.classList.add('active');
          } else {
            panel.classList.remove('active');
          }
        });
      });
    });

    // Accordion toggle handler
    faqCards.forEach(card => {
      const questionBar = card.querySelector('.faq__question-bar');
      questionBar.addEventListener('click', function() {
        const isActive = card.classList.contains('active');
        
        // Collapse other cards in the same active panel
        const parentPanel = card.closest('.faq__category-panel');
        if (parentPanel) {
          const siblingCards = parentPanel.querySelectorAll('.faq__item-card');
          siblingCards.forEach(sibling => {
            if (sibling !== card) {
              sibling.classList.remove('active');
            }
          });
        }

        // Toggle state of current clicked card
        if (!isActive) {
          card.classList.add('active');
        } else {
          card.classList.remove('active');
        }
      });
    });

    // Live Shopify Customizer interactive event listeners
    document.addEventListener('shopify:block:select', function(event) {
      const blockId = event.detail.blockId;
      const blockElement = section.querySelector('#block-' + blockId);
      
      if (blockElement) {
        // If merchant selects a category tab block
        if (blockElement.classList.contains('faq__tab-btn')) {
          blockElement.click();
        } 
        // If merchant selects an individual FAQ card block
        else if (blockElement.classList.contains('faq__item-card')) {
          const parentPanel = blockElement.closest('.faq__category-panel');
          if (parentPanel) {
            // Find tab button that matches this category panel and trigger it
            const categoryId = parentPanel.id;
            const tabButton = section.querySelector(`.faq__tab-btn[data-category="${categoryId}"]`);
            if (tabButton && !tabButton.classList.contains('active')) {
              tabButton.click();
            }
            
            // Open this selected FAQ card
            parentPanel.querySelectorAll('.faq__item-card').forEach(c => {
              if (c !== blockElement) {
                c.classList.remove('active');
              }
            });
            blockElement.classList.add('active');
          }
        }
      }
    });
  });
</script>

