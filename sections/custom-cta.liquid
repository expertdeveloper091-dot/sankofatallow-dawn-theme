{{ 'custom-cta.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #maison-cta-{{ section.id }} {
    background-color: {{ section.settings.bg_color | default: '#feeb94' }};
    border-top: 1px solid #2c2609;
    border-bottom: 1px solid #2c2609;
    padding-top: {{ section.settings.padding_top | default: 64 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 64 }}px;
  }
{%- endstyle -%}

<div id="maison-cta-{{ section.id }}" class="maison-cta_section">
  
  {%- comment -%} Mobile Top Image {%- endcomment -%}
  <div class="maison-cta_image-mobile">
    {%- if section.settings.mobile_image != blank -%}
      <img src="{{ section.settings.mobile_image | image_url: width: 800 }}" alt="Product Image" loading="lazy" width="600" height="auto">
    {%- endif -%}
  </div>

  <div class="maison-cta_container">
    <div class="maison-cta_content">
      
      {%- if section.settings.avatar_1 != blank or section.settings.avatar_2 != blank or section.settings.avatar_3 != blank or section.settings.customer_label != blank -%}
        <div class="maison-cta_badge" style="border-color: #2c2609;">
          <div class="maison-cta_avatars">
            {%- if section.settings.avatar_1 != blank -%}
              <img src="{{ section.settings.avatar_1 | image_url: width: 100 }}" alt="Customer" class="maison-cta_avatar" style="border-color: {{ section.settings.bg_color | default: '#feeb94' }};" width="40" height="40">
            {%- endif -%}
            {%- if section.settings.avatar_2 != blank -%}
              <img src="{{ section.settings.avatar_2 | image_url: width: 100 }}" alt="Customer" class="maison-cta_avatar" style="border-color: {{ section.settings.bg_color | default: '#feeb94' }};" width="40" height="40">
            {%- endif -%}
            {%- if section.settings.avatar_3 != blank -%}
              <img src="{{ section.settings.avatar_3 | image_url: width: 100 }}" alt="Customer" class="maison-cta_avatar" style="border-color: {{ section.settings.bg_color | default: '#feeb94' }};" width="40" height="40">
            {%- endif -%}
          </div>
          <span class="maison-cta_badge-text" style="color: {{ section.settings.text_color | default: '#1d211e' }};">
            {%- if section.settings.customer_count != blank -%}
              <strong>{{ section.settings.customer_count }}</strong>
            {%- endif -%}
            {{ section.settings.customer_label }}
          </span>
        </div>
      {%- endif -%}

      <h2 class="maison-cta_heading" style="color: {{ section.settings.text_color | default: '#1d211e' }};">
        {%- if section.settings.title_highlight != blank -%}
          <span class="maison-cta_highlight" style="color: {{ section.settings.accent_color | default: '#f63208' }};">{{ section.settings.title_highlight }}</span>
        {%- endif -%}
        {%- if section.settings.title_main != blank -%}
          {{ section.settings.title_main }}
        {%- endif -%}
      </h2>

      {%- if section.settings.description != blank -%}
        <div class="maison-cta_description" style="color: {{ section.settings.text_color | default: '#1d211e' }};">
          {{ section.settings.description }}
        </div>
      {%- endif -%}

      {%- if section.settings.btn_text != blank -%}
        <a href="{{ section.settings.btn_url | default: '/' }}" class="maison-cta_button" style="
            background-color: {{ section.settings.button_color | default: '#fedb36' }};
            color: {{ section.settings.button_text_color | default: '#1d211e' }};
            border-color: #2c2609;
            box-shadow: 0px 4px 0px 0px #2c2609;
          " {% if section.settings.btn_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
          {{ section.settings.btn_text }}
        </a>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="maison-cta_benefits">
          {%- for block in section.blocks -%}
            {%- if block.settings.enabled -%}
              <div class="maison-cta_benefit" {{ block.shopify_attributes }}>
                <span class="maison-cta_icon" style="background-color: {{ section.settings.button_color | default: '#fedb36' }};">✓</span>
                <span class="maison-cta_text" style="color: {{ section.settings.text_color | default: '#1d211e' }};">{{ block.settings.text | remove: '✔' | remove: '✓' | strip }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>
  </div>

  {%- comment -%} Left Image {%- endcomment -%}
  <div class="maison-cta_image-left">
    {%- assign l_img = section.settings.left_image | default: section.settings.left_image_1 -%}
    {%- if l_img != blank -%}
      <img src="{{ l_img | image_url: width: 800 }}" alt="Product Image" loading="lazy" width="400" height="auto">
    {%- endif -%}
  </div>

  {%- comment -%} Right Image {%- endcomment -%}
  <div class="maison-cta_image-right">
    {%- assign r_img = section.settings.right_image | default: section.settings.right_image_1 -%}
    {%- if r_img != blank -%}
      <img src="{{ r_img | image_url: width: 800 }}" alt="Product Image" loading="lazy" width="400" height="auto">
    {%- endif -%}
  </div>

</div>

{% schema %}
{
  "name": "Custom CTA",
  "tag": "section",
  "class": "section subscription-cta-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Background & Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#feeb94"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1d211e"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Title Highlight Color",
      "default": "#f63208"
    },
    {
      "type": "header",
      "content": "Desktop & Mobile Floating Images"
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Desktop Left Composite Image",
      "info": "Upload single grouped composite image for left side on desktop."
    },
    {
      "type": "image_picker",
      "id": "left_image_1",
      "label": "Left Image Fallback"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Desktop Right Composite Image",
      "info": "Upload single grouped composite image for right side on desktop."
    },
    {
      "type": "image_picker",
      "id": "right_image_1",
      "label": "Right Image Fallback"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Top Composite Image",
      "info": "Upload composite image to show above content on mobile."
    },
    {
      "type": "header",
      "content": "Customer Avatars & Counter"
    },
    {
      "type": "image_picker",
      "id": "avatar_1",
      "label": "Customer Avatar 1"
    },
    {
      "type": "image_picker",
      "id": "avatar_2",
      "label": "Customer Avatar 2"
    },
    {
      "type": "image_picker",
      "id": "avatar_3",
      "label": "Customer Avatar 3"
    },
    {
      "type": "text",
      "id": "customer_count",
      "label": "Customer Count Number",
      "default": "350,000+"
    },
    {
      "type": "text",
      "id": "customer_label",
      "label": "Customer Label",
      "default": "Happy Customers"
    },
    {
      "type": "header",
      "content": "Main Heading & Description"
    },
    {
      "type": "text",
      "id": "title_highlight",
      "label": "Highlighted Text",
      "default": "RISK-FREE"
    },
    {
      "type": "text",
      "id": "title_main",
      "label": "Main Heading",
      "default": "BEAUTY REVOLUTION"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>We believe in our balm because it actually works. If your skin isn't looking better in 30 days, we'll give you your money back — no drama, no hoops. Subscribe now and save 30% on your first order!</p>"
    },
    {
      "type": "header",
      "content": "CTA Button"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "Subscribe & Save 30% Today"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button Link",
      "default": "/"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Background Color",
      "default": "#fedb36"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#1d211e"
    },
    {
      "type": "checkbox",
      "id": "btn_new_tab",
      "label": "Open Button Link in New Tab",
      "default": false
    },
    {
      "type": "header",
      "content": "Section Layout & Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding",
      "min": 20,
      "max": 150,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding",
      "min": 20,
      "max": 150,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Benefit",
      "settings": [
        {
          "type": "checkbox",
          "id": "enabled",
          "label": "Enable Benefit",
          "default": true
        },
        {
          "type": "text",
          "id": "text",
          "label": "Benefit Text",
          "default": "100% Guarantee"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom CTA",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "text": "100% Guarantee",
            "enabled": true
          }
        },
        {
          "type": "feature",
          "settings": {
            "text": "Free Shipping within the US Only",
            "enabled": true
          }
        },
        {
          "type": "feature",
          "settings": {
            "text": "Free & Easy Returns",
            "enabled": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
