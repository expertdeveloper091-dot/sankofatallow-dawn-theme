{{ 'custom-cta.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #ag-cta-{{ section.id }} {
    background-color: {{ section.settings.bg_color | default: '#feeb94' }} !important;
    border-top: 1px solid #2c2609;
    border-bottom: 1px solid #2c2609;
    --ag-cta-bg: {{ section.settings.bg_color | default: '#feeb94' }};
    --ag-cta-text-color: {{ section.settings.text_color | default: '#1d211e' }};
    --ag-cta-accent-color: {{ section.settings.accent_color | default: '#f63208' }};
    --ag-cta-btn-bg: {{ section.settings.button_color | default: '#fedb36' }};
    --ag-cta-btn-hover-bg: {{ section.settings.button_hover_color | default: '#e0c020' }};
    --ag-cta-btn-text-color: {{ section.settings.button_text_color | default: '#1d211e' }};
    --ag-cta-btn-border-radius: {{ section.settings.border_radius | default: 12 }}px;
    --ag-cta-max-width: {{ section.settings.max_width | default: 700 }}px;
    --ag-cta-padding-top: {{ section.settings.padding_top | default: 64 }}px;
    --ag-cta-padding-bottom: {{ section.settings.padding_bottom | default: 64 }}px;
  }
{%- endstyle -%}

<section id="ag-cta-{{ section.id }}" class="ag-cta" aria-labelledby="ag-cta-title-{{ section.id }}">
  
  {%- comment -%} Mobile Composite Image (Shown at top on mobile) {%- endcomment -%}
  {%- if section.settings.mobile_image != blank -%}
    <div class="ag-cta__image-mobile">
      <img
        src="{{ section.settings.mobile_image | image_url: width: 800 }}"
        alt="{{ section.settings.mobile_image.alt | default: 'Product Image Mobile' | escape }}"
        loading="lazy"
        width="600"
        height="auto"
      >
    </div>
  {%- endif -%}

  {%- comment -%} Left Floating Image (1 single composite image wrapper on desktop) {%- endcomment -%}
  <div class="ag-cta__floating-images ag-cta__floating-images--left" aria-hidden="true">
    {%- assign l_img = section.settings.left_image | default: section.settings.left_image_1 -%}
    {%- if l_img != blank -%}
      <div class="ag-cta__img-single">
        <img
          src="{{ l_img | image_url: width: 800 }}"
          alt="{{ l_img.alt | default: 'Floating decorative image left' | escape }}"
          loading="lazy"
          width="400"
          height="auto"
        >
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} Main CTA Content {%- endcomment -%}
  <div class="ag-cta__content">
    {%- if section.settings.avatar_1 != blank or section.settings.avatar_2 != blank or section.settings.avatar_3 != blank or section.settings.customer_count != blank or section.settings.customer_label != blank -%}
      <div class="ag-cta__customers">
        <div class="ag-cta__avatars" aria-hidden="true">
          {%- if section.settings.avatar_1 != blank -%}
            <img
              class="ag-cta__avatar-img"
              src="{{ section.settings.avatar_1 | image_url: width: 100 }}"
              alt="{{ section.settings.avatar_1.alt | default: 'Customer avatar 1' | escape }}"
              loading="lazy"
              width="40"
              height="40"
            >
          {%- endif -%}
          
          {%- if section.settings.avatar_2 != blank -%}
            <img
              class="ag-cta__avatar-img"
              src="{{ section.settings.avatar_2 | image_url: width: 100 }}"
              alt="{{ section.settings.avatar_2.alt | default: 'Customer avatar 2' | escape }}"
              loading="lazy"
              width="40"
              height="40"
            >
          {%- endif -%}
          
          {%- if section.settings.avatar_3 != blank -%}
            <img
              class="ag-cta__avatar-img"
              src="{{ section.settings.avatar_3 | image_url: width: 100 }}"
              alt="{{ section.settings.avatar_3.alt | default: 'Customer avatar 3' | escape }}"
              loading="lazy"
              width="40"
              height="40"
            >
          {%- endif -%}
        </div>

        {%- if section.settings.customer_count != blank or section.settings.customer_label != blank -%}
          <p class="ag-cta__customers-text">
            {%- if section.settings.customer_count != blank -%}
              <strong>{{ section.settings.customer_count }}</strong>
            {%- endif -%}
            {{ section.settings.customer_label }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <h2 id="ag-cta-title-{{ section.id }}" class="ag-cta__title">
      {%- if section.settings.title_highlight != blank -%}
        <span class="ag-cta__title-highlight">{{ section.settings.title_highlight }}</span>
      {%- endif -%}
      {%- if section.settings.title_main != blank -%}
        {%- if section.settings.title_highlight != blank -%}<br>{%- endif -%}
        {{ section.settings.title_main }}
      {%- endif -%}
    </h2>

    {%- if section.settings.description != blank -%}
      <div class="ag-cta__description">
        {{ section.settings.description }}
      </div>
    {%- endif -%}

    {%- if section.settings.btn_text != blank and section.settings.btn_url != blank -%}
      <a
        href="{{ section.settings.btn_url }}"
        class="ag-cta__button"
        {% if section.settings.btn_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
      >
        {{ section.settings.btn_text }}
      </a>
    {%- endif -%}

    {%- comment -%} Features List {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="ag-cta__features">
        {%- for block in section.blocks -%}
          {%- if block.settings.enabled -%}
            <div class="ag-cta__feature-item" {{ block.shopify_attributes }}>
              <span class="ag-cta__feature-icon" aria-hidden="true">✓</span>
              <span>{{ block.settings.text | remove: '✔' | remove: '✓' | strip }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} Right Floating Image (1 single composite image wrapper on desktop) {%- endcomment -%}
  <div class="ag-cta__floating-images ag-cta__floating-images--right" aria-hidden="true">
    {%- assign r_img = section.settings.right_image | default: section.settings.right_image_1 -%}
    {%- if r_img != blank -%}
      <div class="ag-cta__img-single">
        <img
          src="{{ r_img | image_url: width: 800 }}"
          alt="{{ r_img.alt | default: 'Floating decorative image right' | escape }}"
          loading="lazy"
          width="400"
          height="auto"
        >
      </div>
    {%- endif -%}
  </div>

</section>

{% schema %}
{
  "name": "Custom CTA",
  "tag": "section",
  "class": "section subscription-cta-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Background Settings"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#feeb94"
    },
    {
      "type": "header",
      "content": "Desktop & Mobile Floating Images"
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Desktop Left Composite Image",
      "info": "Upload 1 grouped composite image for left side on desktop."
    },
    {
      "type": "image_picker",
      "id": "left_image_1",
      "label": "Left Image Fallback"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Desktop Right Composite Image",
      "info": "Upload 1 grouped composite image for right side on desktop."
    },
    {
      "type": "image_picker",
      "id": "right_image_1",
      "label": "Right Image Fallback"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Top Composite Image",
      "info": "Upload 1 composite image to show above content on mobile."
    },
    {
      "type": "header",
      "content": "Customer Avatars"
    },
    {
      "type": "image_picker",
      "id": "avatar_1",
      "label": "Customer Avatar 1"
    },
    {
      "type": "image_picker",
      "id": "avatar_2",
      "label": "Customer Avatar 2"
    },
    {
      "type": "image_picker",
      "id": "avatar_3",
      "label": "Customer Avatar 3"
    },
    {
      "type": "header",
      "content": "Customer Counter"
    },
    {
      "type": "text",
      "id": "customer_count",
      "label": "Customer Count Number",
      "default": "350,000+"
    },
    {
      "type": "text",
      "id": "customer_label",
      "label": "Customer Label",
      "default": "Happy Customers"
    },
    {
      "type": "header",
      "content": "Main Heading & Description"
    },
    {
      "type": "text",
      "id": "title_highlight",
      "label": "Highlighted Text",
      "default": "RISK-FREE"
    },
    {
      "type": "text",
      "id": "title_main",
      "label": "Main Heading",
      "default": "BEAUTY REVOLUTION"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>We believe in our balm because it actually works. If your skin isn't looking better in 30 days, we'll give you your money back — no drama, no hoops. Subscribe now and save 30% on your first order!</p>"
    },
    {
      "type": "header",
      "content": "CTA Button"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "Subscribe & Save 30% Today"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button Link",
      "default": "/"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Color",
      "default": "#fedb36"
    },
    {
      "type": "checkbox",
      "id": "btn_new_tab",
      "label": "Open Button Link in New Tab",
      "default": false
    },
    {
      "type": "header",
      "content": "Section Layout & Styles"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding",
      "min": 20,
      "max": 150,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding",
      "min": 20,
      "max": 150,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Benefit",
      "settings": [
        {
          "type": "checkbox",
          "id": "enabled",
          "label": "Enable Benefit",
          "default": true
        },
        {
          "type": "text",
          "id": "text",
          "label": "Benefit Text",
          "default": "100% Guarantee"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom CTA",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "text": "100% Guarantee",
            "enabled": true
          }
        },
        {
          "type": "feature",
          "settings": {
            "text": "Free Shipping within the US Only",
            "enabled": true
          }
        },
        {
          "type": "feature",
          "settings": {
            "text": "Free & Easy Returns",
            "enabled": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
