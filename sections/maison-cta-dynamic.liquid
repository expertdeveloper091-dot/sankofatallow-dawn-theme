{%- comment -%}
  Dynamic Subscription CTA Section
  - Photo "group" blocks: add as many polaroid-style photos as you want,
    assign each to Left / Right (desktop). On mobile they all collapse
    into one overlapping row above the trust badge.
  - Avatar blocks: the 3 small round photos inside the trust badge.
  - All colors, padding, border, width, copy and button are theme-editor controlled.
{%- endcomment -%}

{%- liquid
  assign left_photos = section.blocks | where: 'type', 'photo'
  assign avatar_blocks = section.blocks | where: 'type', 'avatar'
-%}

<div class="maison-cta_section-{{ section.id }} maison-cta_section">
  <div class="maison-cta_container">

    {%- comment -%} ===== MOBILE PHOTO GROUP (shown only < 768px) ===== {%- endcomment -%}
    <div class="maison-cta_image-mobile-group">
      {%- for block in section.blocks -%}
        {%- if block.type == 'photo' -%}
          <div class="maison-cta_photo maison-cta_photo-mobile"
               style="
                 --rotate: {{ block.settings.rotate }}deg;
                 --zi: {{ forloop.index }};
               "
               {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 400 }}"
                   alt="{{ block.settings.alt | default: 'Customer photo' | escape }}"
                   loading="lazy" width="200" height="200">
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="maison-cta_content">

      {%- if section.settings.show_badge -%}
        <div class="maison-cta_badge">
          <div class="maison-cta_avatars">
            {%- for block in avatar_blocks -%}
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 80 }}"
                     alt="Customer" class="maison-cta_avatar"
                     width="40" height="40" {{ block.shopify_attributes }}>
              {%- else -%}
                <div class="maison-cta_avatar maison-cta_avatar-placeholder" {{ block.shopify_attributes }}>👤</div>
              {%- endif -%}
            {%- endfor -%}
          </div>
          <span class="maison-cta_badge-text">
            <strong>{{ section.settings.badge_count | default: '350,000+' }}</strong>
            {{ section.settings.badge_text | default: 'Happy Customers' }}
          </span>
        </div>
      {%- endif -%}

      <h2 class="maison-cta_heading">
        <span class="maison-cta_highlight">{{ section.settings.heading_highlight | default: 'RISK-FREE' }}</span>
        {{ section.settings.heading_rest | default: 'BEAUTY REVOLUTION' }}
      </h2>

      {%- if section.settings.description != blank -%}
        <p class="maison-cta_description">{{ section.settings.description }}</p>
      {%- endif -%}

      {%- if section.settings.button_text != blank -%}
        <a href="{{ section.settings.button_link | default: '#' }}" class="maison-cta_button">
          {{ section.settings.button_text }}
        </a>
      {%- endif -%}

      <div class="maison-cta_benefits">
        {%- for i in (1..3) -%}
          {%- assign benefit_key = 'benefit_' | append: i -%}
          {%- assign benefit_text = section.settings[benefit_key] -%}
          {%- if benefit_text != blank -%}
            <div class="maison-cta_benefit">
              <span class="maison-cta_icon">✓</span>
              <span class="maison-cta_text">{{ benefit_text }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- comment -%} ===== DESKTOP LEFT / RIGHT PHOTO GROUPS ===== {%- endcomment -%}
  <div class="maison-cta_image-left">
    {%- for block in left_photos -%}
      {%- if block.settings.side == 'left' -%}
        <div class="maison-cta_photo"
             style="
               --rotate: {{ block.settings.rotate }}deg;
               --size: {{ block.settings.size }}px;
               --top: {{ block.settings.offset_top }}px;
               --left: {{ block.settings.offset_left }}px;
               --zi: {{ forloop.index }};
             "
             {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 600 }}"
                 alt="{{ block.settings.alt | default: 'Customer photo' | escape }}"
                 loading="lazy" width="300" height="300">
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="maison-cta_image-right">
    {%- for block in left_photos -%}
      {%- if block.settings.side == 'right' -%}
        <div class="maison-cta_photo"
             style="
               --rotate: {{ block.settings.rotate }}deg;
               --size: {{ block.settings.size }}px;
               --top: {{ block.settings.offset_top }}px;
               --left: {{ block.settings.offset_left }}px;
               --zi: {{ forloop.index }};
             "
             {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 600 }}"
                 alt="{{ block.settings.alt | default: 'Customer photo' | escape }}"
                 loading="lazy" width="300" height="300">
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% style %}
  .maison-cta_section-{{ section.id }} {
    --bg: {{ section.settings.background_color }};
    --border-color: {{ section.settings.border_color }};
    --heading-color: {{ section.settings.heading_color }};
    --highlight-color: {{ section.settings.highlight_color }};
    --desc-color: {{ section.settings.description_color }};
    --badge-bg: {{ section.settings.badge_bg }};
    --badge-text: {{ section.settings.badge_text_color }};
    --btn-bg: {{ section.settings.button_bg }};
    --btn-text: {{ section.settings.button_text_color }};
    --btn-border: {{ section.settings.button_border }};
    --btn-shadow: {{ section.settings.button_shadow_color }};
    --icon-bg: {{ section.settings.icon_bg }};
    --icon-border: {{ section.settings.icon_border }};
    --icon-text: {{ section.settings.icon_text_color }};
    --benefit-text: {{ section.settings.benefit_text_color }};
    --container-width: {{ section.settings.container_width }}px;
    --content-width: {{ section.settings.content_width }}px;

    position: relative;
    overflow: hidden;
    background-color: var(--bg);
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    font-family: inherit;
  }

  .maison-cta_section-{{ section.id }} .maison-cta_container {
    max-width: var(--container-width);
    margin: 0 auto;
    position: relative;
    padding: 0 1em;
  }

  .maison-cta_section-{{ section.id }} .maison-cta_content {
    text-align: center;
    max-width: var(--content-width);
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .maison-cta_section-{{ section.id }} .maison-cta_badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75em;
    margin-bottom: 1.5em;
    border-radius: 999px;
    border: 1px solid var(--border-color);
    background: var(--badge-bg);
    padding: 4px 12px 4px 4px;
  }

  .maison-cta_section-{{ section.id }} .maison-cta_avatars { display: flex; align-items: center; }

  .maison-cta_section-{{ section.id }} .maison-cta_avatar {
    width: 40px; height: 40px; border-radius: 50%;
    border: 2px solid var(--bg);
    margin-left: -10px; object-fit: cover;
  }
  .maison-cta_section-{{ section.id }} .maison-cta_avatar:first-child { margin-left: 0; }

  .maison-cta_section-{{ section.id }} .maison-cta_badge-text {
    font-size: 14px; color: var(--badge-text); line-height: 150%;
  }

  .maison-cta_section-{{ section.id }} .maison-cta_heading {
    font-size: 2.75em; font-weight: 700; margin-bottom: 0.5em;
    line-height: 1.2; color: var(--heading-color);
  }
  .maison-cta_section-{{ section.id }} .maison-cta_highlight { color: var(--highlight-color); }

  .maison-cta_section-{{ section.id }} .maison-cta_description {
    font-size: 1.125em; line-height: 1.5; margin-bottom: 20px; color: var(--desc-color);
  }

  .maison-cta_section-{{ section.id }} .maison-cta_button {
    display: inline-block; font-weight: 700; font-size: 1em;
    padding: 0.875em 2em; text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
    border-radius: 12px;
    background-color: var(--btn-bg);
    color: var(--btn-text);
    border: 1px solid var(--btn-border);
    box-shadow: 0px 4px 0px 0px var(--btn-shadow);
  }
  .maison-cta_section-{{ section.id }} .maison-cta_button:hover { transform: translateY(-2px); }
  .maison-cta_section-{{ section.id }} .maison-cta_button:active {
    transform: translateY(2px); box-shadow: 0px 2px 0px -1px var(--btn-shadow);
  }

  .maison-cta_section-{{ section.id }} .maison-cta_benefits {
    display: flex; justify-content: center; gap: 2em; margin-top: 2em; flex-wrap: wrap;
  }
  .maison-cta_section-{{ section.id }} .maison-cta_benefit { display: flex; align-items: center; gap: 0.5em; }
  .maison-cta_section-{{ section.id }} .maison-cta_icon {
    display: flex; align-items: center; justify-content: center;
    width: 1.5em; height: 1.5em; border-radius: 50%;
    font-size: 0.875em; font-weight: 700;
    background-color: var(--icon-bg);
    border: 1px solid var(--icon-border);
    color: var(--icon-text);
  }
  .maison-cta_section-{{ section.id }} .maison-cta_text { font-size: 0.875em; font-weight: 500; color: var(--benefit-text); }

  /* ===== Desktop photo groups ===== */
  .maison-cta_section-{{ section.id }} .maison-cta_image-left,
  .maison-cta_section-{{ section.id }} .maison-cta_image-right {
    position: absolute; top: 0; height: 100%;
    display: flex; align-items: center; z-index: 1; pointer-events: none;
  }
  .maison-cta_section-{{ section.id }} .maison-cta_image-left { left: 0; }
  .maison-cta_section-{{ section.id }} .maison-cta_image-right { right: 0; }

  .maison-cta_section-{{ section.id }} .maison-cta_photo {
    position: relative;
    width: var(--size, 280px);
    height: var(--size, 280px);
    top: var(--top, 0px);
    left: var(--left, 0px);
    transform: rotate(var(--rotate, 0deg));
    z-index: var(--zi, 1);
    background: transparent;
    padding: 0;
    border-radius: 12px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.18);
    margin-left: -30px;
  }
  .maison-cta_section-{{ section.id }} .maison-cta_photo img,
  .maison-cta_section-{{ section.id }} .maison-cta_photo svg {
    width: 100%; height: 100%; object-fit: cover; display: block; border-radius: 12px;
  }
  .maison-cta_section-{{ section.id }} .maison-cta_photo svg { background: #e2e8f0; fill: #94a3b8; }
  .maison-cta_section-{{ section.id }} .maison-cta_avatar-placeholder {
    width: 40px; height: 40px; border-radius: 50%;
    background: #e2e8f0; display: flex; align-items: center; justify-content: center;
    border: 2px solid var(--bg); font-size: 18px; margin-left: -10px;
  }
  .maison-cta_section-{{ section.id }} .maison-cta_photo:first-child { margin-left: 0; }

  /* ===== Mobile photo group (hidden on desktop) ===== */
  .maison-cta_section-{{ section.id }} .maison-cta_image-mobile-group {
    display: none;
    justify-content: center;
    align-items: flex-end;
    margin-bottom: 1.5em;
  }
  .maison-cta_section-{{ section.id }} .maison-cta_photo-mobile {
    width: clamp(64px, 20vw, 100px);
    height: clamp(64px, 20vw, 100px);
    margin-left: -18px;
  }
  .maison-cta_section-{{ section.id }} .maison-cta_photo-mobile:first-child { margin-left: 0; }

  @media (max-width: 1300px) {
    .maison-cta_section-{{ section.id }} .maison-cta_image-left { left: -60px; }
    .maison-cta_section-{{ section.id }} .maison-cta_image-right { right: -60px; }
  }

  @media (min-width: 750px) and (max-width: 1415px) {
    .maison-cta_section-{{ section.id }} .maison-cta_content { max-width: 540px; }
  }

  @media (max-width: 1100px) {
    .maison-cta_section-{{ section.id }} .maison-cta_heading { font-size: 2.25em; }
  }

  @media (max-width: 768px) {
    .maison-cta_section-{{ section.id }} { padding-bottom: 2em !important; }
    .maison-cta_section-{{ section.id }} .maison-cta_heading { font-size: 2em; margin-bottom: 12px; }
    .maison-cta_section-{{ section.id }} .maison-cta_description { font-size: 1em; margin-bottom: 12px; }
    .maison-cta_section-{{ section.id }} .maison-cta_image-left,
    .maison-cta_section-{{ section.id }} .maison-cta_image-right { display: none; }
    .maison-cta_section-{{ section.id }} .maison-cta_image-mobile-group {
      display: {% if section.settings.show_mobile_photos %}flex{% else %}none{% endif %} !important;
    }
    .maison-cta_section-{{ section.id }} .maison-cta_benefits { gap: 9px; margin-top: 12px; }
    .maison-cta_section-{{ section.id }} .maison-cta_avatar { width: 30px; height: 30px; }
    .maison-cta_section-{{ section.id }} .maison-cta_badge { gap: 4px; }
  }

  @media (max-width: 480px) {
    .maison-cta_section-{{ section.id }} { padding-block: 20px !important; }
    .maison-cta_section-{{ section.id }} .maison-cta_heading { font-size: 36px; }
    .maison-cta_section-{{ section.id }} .maison-cta_button { width: 100%; padding: 0.75em 1.5em; }
  }
{% endstyle %}

{% schema %}
{
  "name": "Maison CTA (Dynamic Photos)",
  "settings": [
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Background", "default": "#feeb94" },
    { "type": "color", "id": "border_color", "label": "Border", "default": "#2c2609" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#1d211e" },
    { "type": "color", "id": "highlight_color", "label": "Heading highlight color", "default": "#f63208" },
    { "type": "color", "id": "description_color", "label": "Description color", "default": "#1d211e" },
    { "type": "color", "id": "badge_bg", "label": "Badge background", "default": "#ffffff" },
    { "type": "color", "id": "badge_text_color", "label": "Badge text", "default": "#1d211e" },
    { "type": "color", "id": "button_bg", "label": "Button background", "default": "#fedb36" },
    { "type": "color", "id": "button_text_color", "label": "Button text", "default": "#1d211e" },
    { "type": "color", "id": "button_border", "label": "Button border", "default": "#2c2609" },
    { "type": "color", "id": "button_shadow_color", "label": "Button shadow", "default": "#2c2609" },
    { "type": "color", "id": "icon_bg", "label": "Checkmark icon background", "default": "#fedb36" },
    { "type": "color", "id": "icon_border", "label": "Checkmark icon border", "default": "#2c2609" },
    { "type": "color", "id": "icon_text_color", "label": "Checkmark icon color", "default": "#1d211e" },
    { "type": "color", "id": "benefit_text_color", "label": "Benefit text color", "default": "#1d211e" },

    { "type": "header", "content": "Layout" },
    { "type": "checkbox", "id": "show_mobile_photos", "label": "Show photo cluster on mobile", "default": false },
    { "type": "range", "id": "container_width", "label": "Section max width (px)", "min": 900, "max": 1600, "step": 10, "default": 1100 },
    { "type": "range", "id": "content_width", "label": "Text content max width (px)", "min": 400, "max": 900, "step": 10, "default": 700 },
    { "type": "range", "id": "padding_top", "label": "Padding top (px)", "min": 0, "max": 150, "step": 2, "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom (px)", "min": 0, "max": 150, "step": 2, "default": 64 },

    { "type": "header", "content": "Trust badge" },
    { "type": "checkbox", "id": "show_badge", "label": "Show trust badge", "default": true },
    { "type": "text", "id": "badge_count", "label": "Bold count text", "default": "350,000+" },
    { "type": "text", "id": "badge_text", "label": "Badge text", "default": "Happy Customers" },

    { "type": "header", "content": "Heading" },
    { "type": "text", "id": "heading_highlight", "label": "Highlighted words", "default": "RISK-FREE" },
    { "type": "text", "id": "heading_rest", "label": "Rest of heading", "default": "BEAUTY REVOLUTION" },

    { "type": "header", "content": "Description & button" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "We believe in our balm because it actually works. If your skin isn't looking better in 30 days, we'll give you your money back — no drama, no hoops. Subscribe now and save 30% on your first order!" },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Subscribe & Save 30% Today" },
    { "type": "url", "id": "button_link", "label": "Button link" },

    { "type": "header", "content": "Benefits row" },
    { "type": "text", "id": "benefit_1", "label": "Benefit 1", "default": "100% Guarantee" },
    { "type": "text", "id": "benefit_2", "label": "Benefit 2", "default": "Free Shipping within the US Only" },
    { "type": "text", "id": "benefit_3", "label": "Benefit 3", "default": "Free & Easy Returns" }
  ],
  "blocks": [
    {
      "type": "avatar",
      "name": "Badge avatar",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Small avatar image" }
      ]
    },
    {
      "type": "photo",
      "name": "Polaroid photo",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Photo" },
        { "type": "text", "id": "alt", "label": "Alt text" },
        { "type": "select", "id": "side", "label": "Desktop side", "options": [
          { "value": "left", "label": "Left" },
          { "value": "right", "label": "Right" }
        ], "default": "left" },
        { "type": "range", "id": "size", "label": "Desktop size (px)", "min": 100, "max": 500, "step": 10, "default": 280 },
        { "type": "range", "id": "rotate", "label": "Rotation (deg)", "min": -25, "max": 25, "step": 1, "default": 0 },
        { "type": "range", "id": "offset_top", "label": "Vertical offset (px)", "min": -150, "max": 150, "step": 5, "default": 0 },
        { "type": "range", "id": "offset_left", "label": "Horizontal offset (px)", "min": -150, "max": 150, "step": 5, "default": 0 }
      ]
    }
  ],
  "presets": [
    {
      "name": "Maison CTA (Dynamic Photos)",
      "blocks": [
        { "type": "avatar" },
        { "type": "avatar" },
        { "type": "avatar" },
        { "type": "photo", "settings": { "side": "left", "size": 220, "rotate": -8, "offset_top": -60 } },
        { "type": "photo", "settings": { "side": "left", "size": 150, "rotate": 6, "offset_top": 90, "offset_left": -20 } },
        { "type": "photo", "settings": { "side": "left", "size": 150, "rotate": -4, "offset_top": 140, "offset_left": 60 } },
        { "type": "photo", "settings": { "side": "right", "size": 180, "rotate": 6, "offset_top": -80 } },
        { "type": "photo", "settings": { "side": "right", "size": 200, "rotate": -6, "offset_top": 100 } }
      ]
    }
  ]
}
{% endschema %}
