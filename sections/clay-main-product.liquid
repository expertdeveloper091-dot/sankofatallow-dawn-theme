<script>
var clayProductVariants = {{ product.variants | json }};
var clayImagesList = [
  {% for image in product.images %}
    '{{ image | image_url: width: 1000 }}'{% unless forloop.last %},{% endunless %}
  {% else %}
    '{{ product.featured_image | image_url: width: 1000 }}'
  {% endfor %}
];
var clayCurrentImgIndex = 0;

function changeClayMainImage(element, newSrc, index) {
  var mainImg = document.getElementById('ClayMainFeaturedImage');
  if (mainImg && mainImg.src !== newSrc) {
    mainImg.classList.add('sliding-out');
    setTimeout(function() {
      mainImg.src = newSrc;
      mainImg.classList.remove('sliding-out');
    }, 120);
  } else if (mainImg) {
    mainImg.src = newSrc;
  }
  
  if (index !== undefined) {
    clayCurrentImgIndex = index - 1;
  }
  
  document.querySelectorAll('.clay-thumb-item').forEach(function(el) { el.classList.remove('active'); });
  if (element) {
    element.classList.add('active');
  } else {
    var thumbs = document.querySelectorAll('.clay-thumb-item');
    if (thumbs[clayCurrentImgIndex]) thumbs[clayCurrentImgIndex].classList.add('active');
  }

  var zoomImg = document.getElementById('ClayZoomModalImage');
  if (zoomImg) zoomImg.src = newSrc;
  var zoomCounter = document.getElementById('ClayZoomCounterText');
  if (zoomCounter) zoomCounter.textContent = (clayCurrentImgIndex + 1) + ' / ' + (clayImagesList.length || 1);
}

function scrollClayThumbnails(direction) {
  var strip = document.querySelector('.clay-thumbnails-strip');
  if (strip) {
    var scrollAmt = direction === 'up' ? -90 : 90;
    strip.scrollBy({ top: scrollAmt, behavior: 'smooth' });
  }
}

function prevClayImage() {
  if (clayImagesList.length <= 1) return;
  clayCurrentImgIndex = (clayCurrentImgIndex - 1 + clayImagesList.length) % clayImagesList.length;
  changeClayMainImage(null, clayImagesList[clayCurrentImgIndex], clayCurrentImgIndex + 1);
}

function nextClayImage() {
  if (clayImagesList.length <= 1) return;
  clayCurrentImgIndex = (clayCurrentImgIndex + 1) % clayImagesList.length;
  changeClayMainImage(null, clayImagesList[clayCurrentImgIndex], clayCurrentImgIndex + 1);
}

function openClayImageModal() {
  var mainImg = document.getElementById('ClayMainFeaturedImage');
  var zoomImg = document.getElementById('ClayZoomModalImage');
  var zoomModal = document.getElementById('ClayZoomModal');
  var zoomCounter = document.getElementById('ClayZoomCounterText');
  
  if (mainImg && zoomImg && zoomModal) {
    zoomImg.src = mainImg.src;
    if (zoomCounter) zoomCounter.textContent = (clayCurrentImgIndex + 1) + ' / ' + (clayImagesList.length || 1);
    zoomModal.style.display = 'flex';
  }
}

function closeClayZoomModal(e) {
  var zoomModal = document.getElementById('ClayZoomModal');
  if (zoomModal) zoomModal.style.display = 'none';
}

function updateClayQty(delta) {
  var input = document.getElementById('ClayQtyInput');
  var val = parseInt(input.value, 10) || 1;
  val = Math.max(1, val + delta);
  input.value = val;
}

function selectClayVariant(element, optionName, optionVal, optionIndex) {
  var group = element.closest('.clay-option-group');
  if (group) {
    if (element.tagName !== 'SELECT') {
      group.querySelectorAll('.clay-pill-btn, .clay-fragrance-card-btn').forEach(btn => btn.classList.remove('active'));
      element.classList.add('active');
    }
    var labelVal = document.getElementById('ClayOptVal-' + optionIndex);
    if (labelVal) labelVal.textContent = optionVal;
  }

  // Find selected options
  var selectedOptions = [];
  document.querySelectorAll('.clay-option-group').forEach(g => {
    var selectEl = g.querySelector('.clay-option-select');
    if (selectEl) {
      selectedOptions.push(selectEl.value);
    } else {
      var activeBtn = g.querySelector('.clay-pill-btn.active, .clay-fragrance-card-btn.active');
      if (activeBtn) selectedOptions.push(activeBtn.getAttribute('data-option-value') || activeBtn.textContent.trim());
    }
  });

  // Match variant
  var matchedVariant = clayProductVariants.find(function(v) {
    return v.options.every(function(opt, idx) {
      return opt === selectedOptions[idx];
    });
  });

  if (matchedVariant) {
    var varIdInput = document.getElementById('ClayVariantIdInput');
    if (varIdInput) varIdInput.value = matchedVariant.id;
    
    // Update price & compare price
    var priceEl = document.getElementById('ClayProductPrice');
    if (priceEl) priceEl.textContent = formatClayMoney(matchedVariant.price);
    
    var compareEl = document.getElementById('ClayComparePrice');
    var saveBadgeEl = document.getElementById('ClaySaveBadge');
    if (matchedVariant.compare_at_price > matchedVariant.price) {
      if (compareEl) {
        compareEl.textContent = formatClayMoney(matchedVariant.compare_at_price);
        compareEl.style.display = 'inline-block';
      }
      if (saveBadgeEl) {
        var pct = Math.round((matchedVariant.compare_at_price - matchedVariant.price) * 100 / matchedVariant.compare_at_price);
        saveBadgeEl.textContent = 'SAVE ' + pct + '%';
        saveBadgeEl.style.display = 'inline-block';
      }
    } else {
      if (compareEl) compareEl.style.display = 'none';
      if (saveBadgeEl) saveBadgeEl.style.display = 'none';
    }

    // Update SKU
    var skuEl = document.getElementById('ClayProductSku');
    if (skuEl) skuEl.textContent = matchedVariant.sku || 'N/A';

    // Update Availability & Buttons
    var availEl = document.getElementById('ClayProductAvailability');
    var atcBtn = document.getElementById('ClayAddToCartBtn');
    var atcText = document.getElementById('ClayAddToCartText');
    var buyBtn = document.getElementById('ClayBuyNowBtn');

    if (matchedVariant.available) {
      if (availEl) { availEl.textContent = 'In Stock'; availEl.className = 'clay-meta-val clay-in-stock'; }
      if (atcBtn) atcBtn.removeAttribute('disabled');
      if (atcText) atcText.textContent = 'ADD TO CART';
      if (buyBtn) { buyBtn.removeAttribute('disabled'); buyBtn.style.opacity = '1'; buyBtn.style.cursor = 'pointer'; }
    } else {
      if (availEl) { availEl.textContent = 'Out of Stock'; availEl.className = 'clay-meta-val'; }
      if (atcBtn) atcBtn.setAttribute('disabled', 'true');
      if (atcText) atcText.textContent = 'SOLD OUT';
      if (buyBtn) { buyBtn.setAttribute('disabled', 'true'); buyBtn.style.opacity = '0.5'; buyBtn.style.cursor = 'not-allowed'; }
    }

    // Update Featured Image if variant has image
    if (matchedVariant.featured_image && matchedVariant.featured_image.src) {
      var mainImg = document.getElementById('ClayMainFeaturedImage');
      if (mainImg) mainImg.src = matchedVariant.featured_image.src;
    }
  }
}

function formatClayMoney(cents) {
  return (cents / 100).toLocaleString('en-US', { style: 'currency', currency: '{{ cart.currency.iso_code | default: "USD" }}' });
}

document.addEventListener('DOMContentLoaded', function() {
  var askBtn = document.getElementById('ClayAskBtn');
  var askModal = document.getElementById('ClayAskModal');
  if (askBtn && askModal) {
    askBtn.addEventListener('click', function() { askModal.style.display = 'flex'; });
  }

  // AJAX Form Add to Cart & Direct Checkout
  var form = document.getElementById('ClayProductForm');
  if (form) {
    form.addEventListener('submit', function(e) {
      var isBuyNow = e.submitter && (e.submitter.name === 'checkout' || e.submitter.id === 'ClayBuyNowBtn');
      
      if (isBuyNow) {
        e.preventDefault();
        var formData = new FormData(form);
        fetch('/cart/add.js', {
          method: 'POST',
          body: formData
        })
        .then(function() { window.location.href = '/checkout'; })
        .catch(function() { window.location.href = '/checkout'; });
        return;
      }

      e.preventDefault();
      var atcText = document.getElementById('ClayAddToCartText');
      if (atcText) atcText.textContent = 'ADDING...';

      var formData = new FormData(form);
      fetch('/cart/add.js', {
        method: 'POST',
        body: formData
      })
      .then(response => response.json())
      .then(data => {
        if (atcText) atcText.textContent = 'ADDED TO CART!';
        setTimeout(function() {
          var isAvailable = !document.getElementById('ClayAddToCartBtn').hasAttribute('disabled');
          if (atcText) atcText.textContent = isAvailable ? 'ADD TO CART' : 'SOLD OUT';
        }, 2000);
        
        fetch('/cart.js').then(r => r.json()).then(cart => {
          var cartCountEl = document.querySelector('.cart-count-bubble span, .cart-count-bubble');
          if (cartCountEl) cartCountEl.textContent = cart.item_count;
        });
        
        // Open Side Cart Drawer
        var cartDrawer = document.querySelector('cart-drawer');
        if (cartDrawer) {
          if (typeof cartDrawer.open === 'function') {
            cartDrawer.open();
          } else {
            cartDrawer.classList.add('active');
            document.body.classList.add('overflow-hidden');
          }
        } else {
          var cartBubble = document.querySelector('#cart-icon-bubble, .header__icon--cart, [aria-controls="CartDrawer"]');
          if (cartBubble) cartBubble.click();
        }
      })
      .catch(error => {
        console.error('Error adding to cart:', error);
        if (atcText) atcText.textContent = 'ADD TO CART';
      });
    });
  }

  // Live counter simulation
  var liveEl = document.getElementById('ClayLiveCounter');
  if (liveEl) {
    setInterval(function() {
      var curr = parseInt(liveEl.textContent, 10) || 16;
      var diff = Math.floor(Math.random() * 3) - 1;
      liveEl.textContent = Math.max(8, Math.min(35, curr + diff));
    }, 5000);
  }
});

function closeClayAskModal() {
  document.getElementById('ClayAskModal').style.display = 'none';
}
</script>

