{{ 'section-main-product.css' | asset_url | stylesheet_tag }}

<div class="clay-product-section page-width section-{{ section.id }}-padding" id="ClayProduct-{{ section.id }}">
  <div class="clay-product-grid">
    
    <!-- LEFT: PRODUCT GALLERY (EXACT REFERENCE IMAGE MATCH) -->
    <div class="clay-gallery-wrapper">
      <div class="clay-gallery-container" style="display: flex; flex-direction: column; gap: 14px;">
        
        <!-- Main Featured Image -->
        <div class="clay-main-image-box">
          {% assign featured_img = product.featured_image | default: product.images.first %}
          <img id="ClayMainFeaturedImage" src="{{ featured_img | image_url: width: 1000 }}" alt="{{ featured_img.alt | escape }}" width="600" height="600">
          
          <!-- Prev / Next Slider Arrows -->
          <button type="button" class="clay-gallery-nav-btn prev" onclick="prevClayImage()" aria-label="Previous image">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
          </button>
          <button type="button" class="clay-gallery-nav-btn next" onclick="nextClayImage()" aria-label="Next image">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </button>

          <!-- Zoom / Fullscreen Button -->
          <button type="button" class="clay-zoom-btn" onclick="openClayImageModal()" aria-label="Zoom image">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"></path></svg>
          </button>
        </div>

        <!-- Horizontal Thumbnails Strip below Main Image (Matching Image) -->
        {% if product.images.size > 1 %}
          <div class="clay-horizontal-thumbnails" style="display: flex; align-items: center; justify-content: center; gap: 10px;">
            <button type="button" class="clay-thumb-scroll-btn" onclick="prevClayImage()" aria-label="Previous thumbnail" style="width:32px;height:32px;border-radius:50%;border:1.5px solid #111111;background:#ffffff;font-weight:800;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 0 0 #111111;">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </button>

            <div class="clay-thumbnails-strip-h" style="display: flex; gap: 10px; overflow-x: auto; scrollbar-width: none;">
              {% for image in product.images %}
                <div class="clay-thumb-item {% if forloop.first %}active{% endif %}" onclick="changeClayMainImage(this, '{{ image | image_url: width: 1000 }}', {{ forloop.index }})" style="width:64px;height:64px;border-radius:10px;border:1.5px solid #111111;overflow:hidden;cursor:pointer;flex-shrink:0;box-shadow:0 2px 0 0 #111111;">
                  <img src="{{ image | image_url: width: 150 }}" alt="{{ image.alt | escape }}" loading="lazy" width="64" height="64" style="width:100%;height:100%;object-fit:cover;">
                </div>
              {% endfor %}
            </div>

            <button type="button" class="clay-thumb-scroll-btn" onclick="nextClayImage()" aria-label="Next thumbnail" style="width:32px;height:32px;border-radius:50%;border:1.5px solid #111111;background:#ffffff;font-weight:800;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 0 0 #111111;">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>
          </div>
        {% endif %}

      </div>
    </div>

    <div class="clay-info-wrapper">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'product_badges' or 'badges' -%}
            {% render 'product-badges', card_product: product, type: 'price_badges' %}

          {%- when 'product_title' or 'title' -%}
            {% if section.settings.show_vendor and product.vendor != blank %}
              <div class="clay-vendor-tag">{{ product.vendor }}</div>
            {% endif %}
            <h1 class="clay-product-title" {{ block.shopify_attributes }}>{{ product.title }}</h1>

          {%- when 'review_and_sold' -%}
            <div class="clay-rating-sold-row" {{ block.shopify_attributes }}>
              <div class="clay-stars-box">
                <span class="clay-stars">★★★★★</span>
                <span class="clay-rating-text">5.0 ({{ block.settings.reviews_count | default: 4 }} reviews)</span>
              </div>
              <div class="clay-sold-badge">
                🔥 {{ section.settings.sold_count | default: 12 }} {{ section.settings.sold_text | default: 'Sold in last 24 hours' }}
              </div>
            </div>

          {%- when 'price' -%}
            <div class="clay-price-row" {{ block.shopify_attributes }}>
              <span class="clay-price-current" id="ClayProductPrice">{{ product.selected_or_first_available_variant.price | money }}</span>
              <span class="clay-price-compare" id="ClayComparePrice" {% unless product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}style="display:none;"{% endunless %}>
                {{ product.selected_or_first_available_variant.compare_at_price | money }}
              </span>
              <span class="clay-save-badge" id="ClaySaveBadge" {% unless product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}style="display:none;"{% endunless %}>
                {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
                  SAVE {{ product.selected_or_first_available_variant.compare_at_price | minus: product.selected_or_first_available_variant.price | times: 100 | divided_by: product.selected_or_first_available_variant.compare_at_price }}%
                {% endif %}
              </span>
            </div>

          {%- when 'short_description' -%}
            {% if product.description != blank %}
              <div class="clay-short-desc mb-20" {{ block.shopify_attributes }} style="font-size:14px;color:#475467;line-height:1.6;">
                {{ product.description | truncatewords: 35 }}
              </div>
            {% endif %}

          {%- when 'delivery_return' or 'feature_highlights' -%}
            <div class="clay-feature-highlights-box" {{ block.shopify_attributes }}>
              {% if block.settings.row1_text != blank %}
                <div class="clay-feature-item">
                  <div class="clay-feature-icon">🚚</div>
                  <div class="clay-feature-text">{{ block.settings.row1_text }}</div>
                </div>
              {% else %}
                <div class="clay-feature-item">
                  <div class="clay-feature-icon">🚚</div>
                  <div class="clay-feature-text"><strong>Fast Home Delivery:</strong> Delivery within 3 to 5 Working Days nationwide.</div>
                </div>
              {% endif %}

              {% if block.settings.row2_text != blank %}
                <div class="clay-feature-item">
                  <div class="clay-feature-icon">💵</div>
                  <div class="clay-feature-text">{{ block.settings.row2_text }}</div>
                </div>
              {% else %}
                <div class="clay-feature-item">
                  <div class="clay-feature-icon">💵</div>
                  <div class="clay-feature-text"><strong>Cash on Delivery (COD):</strong> Available with 100% inspection before payment.</div>
                </div>
              {% endif %}

              {% if block.settings.row3_text != blank %}
                <div class="clay-feature-item">
                  <div class="clay-feature-icon">📦</div>
                  <div class="clay-feature-text">{{ block.settings.row3_text }}</div>
                </div>
              {% else %}
                <div class="clay-feature-item">
                  <div class="clay-feature-icon">📦</div>
                  <div class="clay-feature-text"><strong>Flat Shipping Rate:</strong> Standard shipping charge flat Rs. 199 on all orders.</div>
                </div>
              {% endif %}
            </div>

          {%- when 'live_view' -%}
            <div class="clay-live-visitors-bar" {{ block.shopify_attributes }} style="display: inline-flex; align-items: center; gap: 10px; margin-bottom: 16px;">
              <div class="clay-live-visitors-icon-box" style="display: flex; align-items: center; justify-content: center; width: 26px; height: 26px; background: #e63946; border-radius: 50%; color: #ffffff; flex-shrink: 0; box-shadow: 0 0 0 3px rgba(230, 57, 70, 0.2);">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                  <circle cx="12" cy="12" r="3"></circle>
                </svg>
              </div>
              <span class="clay-live-visitors-text" style="font-size: 13.5px; font-weight: 700; color: #111111; font-family: 'Poppins', sans-serif;">
                <span id="ClayLiveCounter" style="color: #e63946; font-weight: 800;">{{ block.settings.min_count | default: 29 }}</span> {{ block.settings.suffix_text | default: 'people are viewing this right now' }}
              </span>
            </div>

          {%- when 'addons' or 'ask_share_addons' -%}
            <div class="clay-addons-row" {{ block.shopify_attributes }}>
              <button type="button" class="clay-addon-link" id="ClayAskBtn">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                Ask a question
              </button>
              <button type="button" class="clay-addon-link" onclick="navigator.clipboard.writeText(window.location.href); alert('Product link copied!');">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
                Share
              </button>
            </div>

          {%- when 'variant_picker' -%}
            {% unless product.has_only_default_variant %}
              <div class="clay-variant-picker" {{ block.shopify_attributes }}>
                {% for option in product.options_with_values %}
                  {% assign opt_name_down = option.name | downcase %}
                  <div class="clay-option-group" data-option-index="{{ forloop.index0 }}">
                    <label class="clay-option-label" style="font-size: 14px; font-weight: 800; color: #111111; margin-bottom: 8px; font-family: 'Poppins', sans-serif;">
                      {{ option.name }}: <span class="clay-option-val" id="ClayOptVal-{{ forloop.index0 }}" style="font-weight: 600; color: #555555;">{{ option.selected_value }}</span>
                    </label>

                    {% if opt_name_down contains 'size' %}
                      <!-- SIZE PILL BUTTONS -->
                      <div class="clay-option-pills">
                        {% for value in option.values %}
                          <button type="button" class="clay-pill-btn {% if option.selected_value == value %}active{% endif %}" data-option-name="{{ option.name }}" data-option-value="{{ value | escape }}" onclick="selectClayVariant(this, '{{ option.name }}', '{{ value | escape }}', {{ forloop.parentloop.index0 }})">
                            {{ value }}
                          </button>
                        {% endfor %}
                      </div>

                    {% elsif opt_name_down contains 'fragrance' or opt_name_down contains 'scent' or opt_name_down contains 'flavour' or opt_name_down contains 'flavor' %}
                      <!-- VERTICAL IMAGE+TEXT CARD BUTTONS -->
                      <div class="clay-scent-cards-grid">
                        {% for value in option.values %}
                          {% assign value_variant = null %}
                          {% for v in product.variants %}
                            {% if v.options contains value and v.featured_image %}
                              {% assign value_variant = v %}
                              {% break %}
                            {% endif %}
                          {% endfor %}
                          {% assign sw_img = value_variant.featured_image | default: product.featured_image %}
                          
                          <button type="button" class="clay-scent-card-box {% if option.selected_value == value %}active{% endif %}" data-option-name="{{ option.name }}" data-option-value="{{ value | escape }}" onclick="selectClayVariant(this, '{{ option.name }}', '{{ value | escape }}', {{ forloop.parentloop.index0 }})">
                            {% if sw_img != blank %}
                              <div class="clay-scent-card-img-wrap">
                                <img src="{{ sw_img | image_url: width: 140 }}" alt="{{ value | escape }}" width="48" height="48" loading="lazy">
                              </div>
                            {% endif %}
                            <span class="clay-scent-card-label">{{ value }}</span>
                          </button>
                        {% endfor %}
                      </div>

                    {% else %}
                      <!-- OTHER PILL BUTTONS -->
                      <div class="clay-option-pills">
                        {% for value in option.values %}
                          <button type="button" class="clay-pill-btn {% if option.selected_value == value %}active{% endif %}" data-option-name="{{ option.name }}" data-option-value="{{ value | escape }}" onclick="selectClayVariant(this, '{{ option.name }}', '{{ value | escape }}', {{ forloop.parentloop.index0 }})">
                            {{ value }}
                          </button>
                        {% endfor %}
                      </div>
                    {% endif %}
                  </div>
                {% endfor %}
              </div>
            {% endunless %}

          {%- when 'buy_buttons' -%}
            <div class="clay-buy-buttons-block" {{ block.shopify_attributes }}>
              {% form 'product', product, id: 'ClayProductForm', class: 'clay-product-form' %}
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" id="ClayVariantIdInput">
                
                <div class="clay-atc-row" style="display: flex; gap: 10px; width: 100%;">
                  <button type="submit" name="add" class="clay-atc-btn" id="ClayAddToCartBtn" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
                    <span id="ClayAddToCartText">
                      {% if product.selected_or_first_available_variant.available %}
                        ADD TO CART
                      {% else %}
                        {{ block.settings.sold_out_text | default: 'SOLD OUT' }}
                      {% endif %}
                    </span>
                  </button>
                </div>
              {% endform %}

              <!-- Sub Trust Pills -->
              <div class="clay-sub-trust-row">
                <span class="clay-trust-pill"><i class="fa-solid fa-shield-halved"></i> 30-Day Guarantee</span>
                <span class="clay-trust-pill"><i class="fa-solid fa-truck-fast"></i> Free Shipping</span>
              </div>
            </div>

          {%- when 'yellow_cta_button' or 'custom_yellow_cta' -%}
            <div class="clay-yellow-cta-block" {{ block.shopify_attributes }}>
              <a href="{{ block.settings.link | default: '#' }}" class="clay-yellow-cta-btn">
                {{ block.settings.button_text | default: 'Try Our Tallow Balm →' }}
              </a>
            </div>

          {%- when 'product_meta' -%}
            <div class="clay-product-meta-list" {{ block.shopify_attributes }}>
              {% if block.settings.show_sku != false %}
                <div class="clay-meta-item">
                  <span class="clay-meta-label">SKU:</span>
                  <span class="clay-meta-val" id="ClayProductSku">{{ product.selected_or_first_available_variant.sku | default: 'N/A' }}</span>
                </div>
              {% endif %}
              {% if block.settings.show_availability != false %}
                <div class="clay-meta-item">
                  <span class="clay-meta-label">Availability:</span>
                  <span class="clay-meta-val clay-in-stock" id="ClayProductAvailability">
                    {% if product.selected_or_first_available_variant.available %}In Stock{% else %}Out of Stock{% endif %}
                  </span>
                </div>
              {% endif %}
              {% if block.settings.show_collections != false %}
                <div class="clay-meta-item">
                  <span class="clay-meta-label">Collections:</span>
                  <span class="clay-meta-val">{{ product.collections | map: 'title' | join: ', ' | default: 'Skincare, Tallow' }}</span>
                </div>
              {% endif %}
            </div>

          {%- when 'customer_photos' -%}
            <div class="clay-customer-photos-section" {{ block.shopify_attributes }}>
              <h4 class="clay-section-subheading">{{ block.settings.heading | default: 'What our Customers Say' }}</h4>
              <div class="clay-customer-photos-grid">
                {% for image in product.images limit: 3 %}
                  <div class="clay-customer-photo-card">
                    <img src="{{ image | image_url: width: 300 }}" alt="Customer Photo {{ forloop.index }}" loading="lazy" width="150" height="200">
                  </div>
                {% else %}
                  <div class="clay-customer-photo-card">
                    <img src="{{ product.featured_image | image_url: width: 300 }}" alt="Customer Photo 1" width="150" height="200">
                  </div>
                {% endfor %}
              </div>
            </div>

          {%- when 'trust_badge' -%}
            <div class="clay-trust-banner-box" {{ block.shopify_attributes }}>
              <div class="clay-trust-heading">{{ block.settings.badge_text | default: 'Guarantee Safe Checkout' }}</div>
              <div class="clay-trust-svg-icons">
                <svg width="45" height="28" viewBox="0 0 38 24" fill="none"><rect width="38" height="24" rx="4" fill="#1A1F71"/><path d="M15.4 16.5L17.2 6.8H19.7L17.9 16.5H15.4ZM24.7 7C24.2 6.8 23.4 6.6 22.4 6.6C19.8 6.6 18 8 18 9.9C18 11.3 19.3 12.1 20.3 12.6C21.3 13.1 21.6 13.4 21.6 13.9C21.6 14.6 20.7 14.9 19.9 14.9C18.7 14.9 18 14.6 17.3 14.3L16.9 16.2C17.6 16.5 18.7 16.8 20 16.8C22.8 16.8 24.6 15.4 24.6 13.4C24.6 10.9 21.2 10.7 21.2 9.7C21.2 9.3 21.6 8.9 22.4 8.9C23.2 8.9 24.1 9.1 24.6 9.4L24.7 7ZM30.7 16.5H32.9L31 6.8H29C28.4 6.8 27.9 7.1 27.7 7.7L23.7 16.5H26.3L26.8 15.1H30.1L30.7 16.5ZM27.5 13.2L28.9 9.3L29.7 13.2H27.5ZM13.8 6.8L11.4 13.4L11.1 12.1C10.6 10.4 9.1 8.5 7.3 7.5L9.5 16.5H12.1L16.1 6.8H13.8Z" fill="white"/></svg>
                <svg width="45" height="28" viewBox="0 0 38 24" fill="none"><rect width="38" height="24" rx="4" fill="#0A0E27"/><circle cx="14" cy="12" r="7" fill="#EB001B"/><circle cx="24" cy="12" r="7" fill="#F79E1B"/><path d="M19 6.8A6.9 6.9 0 0 0 16.5 12A6.9 6.9 0 0 0 19 17.2A6.9 6.9 0 0 0 21.5 12A6.9 6.9 0 0 0 19 6.8Z" fill="#FF5F00"/></svg>
                <svg width="45" height="28" viewBox="0 0 38 24" fill="none"><rect width="38" height="24" rx="4" fill="#006FCF"/><path d="M7 16L10 8H13L16 16H13.5L12.9 14.3H10.1L9.5 16H7ZM10.7 12.5H12.3L11.5 10.2L10.7 12.5Z" fill="white"/><path d="M17 16V8H22C23.5 8 24.5 9 24.5 10.3C24.5 11.3 23.8 12 22.8 12.2L24.8 16H22.3L20.6 12.6H19.2V16H17ZM19.2 11H21.5C22.1 11 22.6 10.7 22.6 10.1C22.6 9.5 22.1 9.2 21.5 9.2H19.2V11Z" fill="white"/><path d="M26 16V8H31.5V9.6H28.2V11.2H31V12.7H28.2V14.4H31.5V16H26Z" fill="white"/></svg>
              </div>
            </div>

          {%- when 'collapsible_tab' -%}
            <div class="clay-accordions-wrapper" {{ block.shopify_attributes }}>
              <details class="clay-accordion-item">
                <summary class="clay-accordion-summary">
                  <span>{{ block.settings.heading | default: 'Collapsible Row' }}</span>
                  <span class="clay-accordion-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                  </span>
                </summary>
                <div class="clay-accordion-content">
                  {% if block.settings.content_source == 'description' %}
                    {{ product.description }}
                  {% else %}
                    {{ block.settings.content }}
                  {% endif %}
                </div>
              </details>
            </div>

        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>



</div>

<!-- Clay Modal for Ask Question -->
<div id="ClayAskModal" class="clay-modal-overlay">
  <div class="clay-modal-card">
    <button type="button" class="clay-modal-close" onclick="closeClayAskModal()">&times;</button>
    <h3>Ask a Question</h3>
    {% form 'contact' %}
      <input type="hidden" name="contact[product]" value="{{ product.title }}">
      <div class="clay-form-group">
        <label>Your Name</label>
        <input type="text" name="contact[name]" required placeholder="Enter your name">
      </div>
      <div class="clay-form-group">
        <label>Your Email</label>
        <input type="email" name="contact[email]" required placeholder="Enter your email">
      </div>
      <div class="clay-form-group">
        <label>Question</label>
        <textarea name="contact[body]" rows="4" required placeholder="What would you like to ask about {{ product.title }}?"></textarea>
      </div>
      <button type="submit" class="clay-atc-btn" style="width:100%;">SEND QUESTION</button>
    {% endform %}
  </div>
</div>

<!-- Clay Lightbox Zoom Modal (Image 2) -->
<div id="ClayZoomModal" class="clay-zoom-modal-overlay" onclick="closeClayZoomModal(event)">
  <button type="button" class="clay-zoom-close-btn" onclick="closeClayZoomModal(event)" aria-label="Close zoom modal">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
  </button>
  <div class="clay-zoom-img-container" onclick="event.stopPropagation()">
    <img id="ClayZoomModalImage" src="" alt="Zoomed Product Image">
  </div>
  <!-- Pill Counter Nav (Image 2: < 3/5 >) -->
  <div class="clay-zoom-counter-pill" onclick="event.stopPropagation()">
    <button type="button" class="clay-zoom-nav-arrow" onclick="prevClayImage()" aria-label="Previous image">&lt;</button>
    <span id="ClayZoomCounterText">1 / {{ product.images.size | default: 1 }}</span>
    <button type="button" class="clay-zoom-nav-arrow" onclick="nextClayImage()" aria-label="Next image">&gt;</button>
  </div>
</div>

<style>
/* ============================================================
   CLAY THEME SINGLE PRODUCT PAGE EXACT STYLING
   ============================================================ */
.clay-product-section {
  font-family: 'Poppins', sans-serif !important;
  color: #1d211e;
  max-width: 1440px;
  margin: 0 auto;
  padding: 60px 40px;
}

.clay-product-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 40px;
  align-items: flex-start;
}

.clay-gallery-wrapper {
  flex: 1 1 500px;
  max-width: 50%;
  position: static;
}

.clay-info-wrapper {
  flex: 1 1 450px;
  max-width: 45%;
}

/* Mobile Responsiveness Styles */
@media screen and (max-width: 991px) {
  .clay-product-section {
    padding-top: 15px;
    padding-bottom: 40px;
  }

  .clay-product-grid {
    flex-direction: column !important;
    gap: 20px !important;
  }

  .clay-gallery-wrapper,
  .clay-info-wrapper {
    max-width: 100% !important;
    width: 100% !important;
    flex: 1 1 100% !important;
  }

  .clay-main-image-box {
    min-height: auto !important;
    max-height: 420px !important;
    width: 100% !important;
