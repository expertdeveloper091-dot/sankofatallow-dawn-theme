<script>
(function () {
  'use strict';

  /* ── Money formatter (no Shopify.formatMoney dependency) ── */
  function formatMoney(cents) {
    if (typeof cents === 'string') cents = cents.replace('.', '');
    cents = parseInt(cents, 10) || 0;
    const val = (cents / 100).toFixed(2);
    return '$' + val.replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  }

  /* ── DOM refs ── */
  const overlay        = document.getElementById('hdr-overlay');
  const mainHeader     = document.getElementById('main-header');

  const sidebar        = document.getElementById('mobile-sidebar');
  const sidebarOpenBtn = document.getElementById('sidebar-open-btn');
  const sidebarCloseBtn= document.getElementById('sidebar-close-btn');

  const searchDrawer   = document.getElementById('search-drawer');
  const searchBtnD     = document.getElementById('search-btn-desktop');
  const searchBtnM     = document.getElementById('search-btn-mobile');
  const searchCloseBtn = document.getElementById('search-close-btn');
  const searchInput    = document.getElementById('search-input');
  const liveResults    = document.getElementById('live-search-results');
  const resultsGrid    = document.getElementById('search-results-grid');

  const cartDrawer     = document.getElementById('cart-drawer');
  const cartBtnD       = document.getElementById('cart-btn-desktop');
  const cartBtnM       = document.getElementById('cart-btn-mobile');
  const cartCloseBtn   = document.getElementById('cart-close-btn');
  const cartEmpty      = document.getElementById('cart-empty');
  const cartItemsList  = document.getElementById('cart-items-list');
  const cartFooter     = document.getElementById('cart-footer');
  const cartProtection = document.getElementById('cart-protection');
  const cartCrossSell  = document.getElementById('cart-cross-sell');
  const cartSubtotal   = document.getElementById('cart-subtotal');
  const badgeDesktop   = document.getElementById('cart-badge-desktop');
  const badgeMobile    = document.getElementById('cart-badge-mobile');
  const btnContinue    = document.getElementById('btn-continue-shop');
  const btnCrossAdd    = document.getElementById('btn-cross-add');
  const timerEl        = document.getElementById('cart-timer-countdown');
  const progressFill   = document.getElementById('cart-progress-fill');
  const progressText   = document.getElementById('cart-progress-text');
  const msGift         = document.getElementById('ms-gift');
  const msDiscount     = document.getElementById('ms-discount');
  const msShipping     = document.getElementById('ms-shipping');

  /* ── Drawer helpers ── */
  function openDrawer(el) {
    el.classList.add('active');
    el.setAttribute('aria-hidden', 'false');
    overlay.classList.add('active');
    document.body.style.overflow = 'hidden';
    document.documentElement.classList.add('drawer-open');
  }
  function closeAll() {
    [sidebar, searchDrawer, cartDrawer].forEach(function(d) {
      d.classList.remove('active');
      d.setAttribute('aria-hidden', 'true');
    });
    if (sidebarOpenBtn) sidebarOpenBtn.setAttribute('aria-expanded', 'false');
    overlay.classList.remove('active');
    document.body.style.overflow = '';
    document.documentElement.classList.remove('drawer-open');
  }

  overlay.addEventListener('click', closeAll);

  /* ── Sidebar ── */
  if (sidebarOpenBtn) sidebarOpenBtn.addEventListener('click', function() {
    openDrawer(sidebar);
    sidebarOpenBtn.setAttribute('aria-expanded', 'true');
  });
  if (sidebarCloseBtn) sidebarCloseBtn.addEventListener('click', closeAll);

  /* ── Sticky scroll ── */
  /* sticky header — setting injected by Liquid output tag (safe inside <script>) */
  var STICKY_TYPE = '{{ section.settings.sticky_header_type }}';
  if (STICKY_TYPE !== 'none') {
    var lastScrollY = window.scrollY;
    window.addEventListener('scroll', function() {
      var currentScrollY = window.scrollY;
      
      if (currentScrollY > 80) {
        mainHeader.classList.add('is-sticky');
        
        if (currentScrollY > lastScrollY && currentScrollY > 150) {
          // Scrolling down - hide header
          mainHeader.classList.add('header-hidden');
        } else {
          // Scrolling up - show header
          mainHeader.classList.remove('header-hidden');
        }
      } else {
        mainHeader.classList.remove('is-sticky');
        mainHeader.classList.remove('header-hidden');
      }
      
      lastScrollY = currentScrollY;
    }, { passive: true });
  }

  /* ── Search ── */
  function openSearch() { openDrawer(searchDrawer); searchInput.focus(); }
  if (searchBtnD)    searchBtnD.addEventListener('click', openSearch);
  if (searchBtnM)    searchBtnM.addEventListener('click', openSearch);
  if (searchCloseBtn) searchCloseBtn.addEventListener('click', closeAll);

  var searchTimer;
  if (searchInput) {
    searchInput.addEventListener('input', function() {
      clearTimeout(searchTimer);
      var q = searchInput.value.trim();
      if (q.length < 2) { liveResults.classList.remove('active'); return; }
      searchTimer = setTimeout(function() {
        fetch('/search/suggest.json?q=' + encodeURIComponent(q) + '&resources[type]=product&resources[limit]=6')
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var products = (data.resources && data.resources.results && data.resources.results.products) || [];
            renderSearchProducts(products);
          })
          .catch(function() {});
      }, 280);
    });
  }

  function renderSearchProducts(products) {
    resultsGrid.innerHTML = '';
    if (!products.length) {
      resultsGrid.innerHTML = '<div class="search-no-results">No products found</div>';
      liveResults.classList.add('active');
      return;
    }
    products.forEach(function(p) {
      var card = document.createElement('a');
      card.href = p.url;
      card.className = 'search-product-card';
      /* Price from predictive search comes as a formatted string in p.price */
      var priceStr = p.price ? p.price : '';
      card.innerHTML =
        '<div class="search-prod-img">' +
          (p.image ? '<img src="' + p.image + '" alt="' + p.title + '" loading="lazy">' : '<i class="fa-solid fa-shirt"></i>') +
        '</div>' +
        '<div>' +
          '<span class="search-prod-title">' + p.title + '</span>' +
          (priceStr ? '<span class="search-prod-price">' + priceStr + '</span>' : '') +
        '</div>';
      resultsGrid.appendChild(card);
    });
    liveResults.classList.add('active');
  }

  /* ── Cart open/close ── */
  window.openCustomCartDrawer = function() {
    if (cartDrawer) {
      openDrawer(cartDrawer);
      fetchCart();
    }
  };
  if (cartBtnD) cartBtnD.addEventListener('click', function() { openCustomCartDrawer(); });
  if (cartBtnM) cartBtnM.addEventListener('click', function() { openCustomCartDrawer(); });
  if (cartCloseBtn) cartCloseBtn.addEventListener('click', closeAll);
  if (btnContinue)  btnContinue.addEventListener('click', closeAll);

  /* ── Cross-sell add to cart ── */
  if (btnCrossAdd) {
    btnCrossAdd.addEventListener('click', function() {
      var vid = btnCrossAdd.getAttribute('data-variant');
      if (!vid) return;
      btnCrossAdd.classList.add('loading');
      btnCrossAdd.textContent = '…';
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: parseInt(vid, 10), quantity: 1 })
      })
      .then(function(r) { return r.json(); })
      .then(function() {
        btnCrossAdd.classList.remove('loading');
        btnCrossAdd.textContent = 'Added ✓';
        fetchCart();
        setTimeout(function() { btnCrossAdd.textContent = 'Add To Cart'; }, 2000);
      })
      .catch(function() {
        btnCrossAdd.classList.remove('loading');
        btnCrossAdd.textContent = 'Add To Cart';
      });
    });
  }

  /* ── Quantity buttons (delegated) ── */
  if (cartItemsList) {
    cartItemsList.addEventListener('click', function(e) {
      var btn = e.target.closest('.qty-btn, .cart-item-remove');
      if (!btn) return;
      var key = btn.getAttribute('data-key');
      var action = btn.getAttribute('data-action');
      var curQty = parseInt(btn.getAttribute('data-qty'), 10) || 0;
      var nextQty;
      if (btn.classList.contains('cart-item-remove')) {
        nextQty = 0;
      } else {
        nextQty = action === 'increase' ? curQty + 1 : Math.max(0, curQty - 1);
      }
      changeCartItem(key, nextQty);
    });
  }

  function changeCartItem(key, qty) {
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ id: key, quantity: qty })
    })
    .then(function(r) { return r.json(); })
    .then(function() { fetchCart(); })
    .catch(function() {});
  }

  /* ── Fetch & render cart ── */
  function fetchCart() {
    fetch('/cart.js')
      .then(function(r) { return r.json(); })
      .then(function(data) { renderCart(data); })
      .catch(function() {});
  }

  function renderCart(data) {
    var count = data.item_count || 0;
    var totalCents = data.total_price || 0;

    /* Update badges */
    if (badgeDesktop) badgeDesktop.textContent = count;
    if (badgeMobile)  badgeMobile.textContent  = count;

    if (count === 0) {
      cartEmpty.style.display = 'flex';
      cartItemsList.style.display = 'none';
      cartFooter.style.display = 'none';
      if (cartProtection) cartProtection.style.display = 'none';
      if (cartCrossSell)  cartCrossSell.style.display  = 'none';
    } else {
      cartEmpty.style.display = 'none';
      cartItemsList.style.display = 'flex';
      cartFooter.style.display = 'block';
      if (cartProtection) cartProtection.style.display = 'block';
      if (cartCrossSell)  cartCrossSell.style.display  = 'block';

      /* Subtotal */
      if (cartSubtotal) cartSubtotal.textContent = formatMoney(totalCents);
      var cartBtnSubtotal = document.querySelector('.cart-btn-subtotal');
      if (cartBtnSubtotal) cartBtnSubtotal.textContent = formatMoney(totalCents);

      /* Milestones */
      updateMilestones(totalCents);

      /* Render items */
      renderItems(data.items || []);
    }
  }

  function renderItems(items) {
    cartItemsList.innerHTML = '';
    items.forEach(function(item) {
      var div = document.createElement('div');
      div.className = 'cart-item';
      div.setAttribute('data-key', item.key);
      var imgHtml = item.image
        ? '<img src="' + item.image + '" alt="' + item.product_title + '" loading="lazy">'
        : '<i class="fa-solid fa-shirt"></i>';
      var variantHtml = (item.variant_title && item.variant_title !== 'Default Title')
        ? '<div class="cart-item-variant">Scent: ' + item.variant_title + '</div>'
        : '';
      div.innerHTML =
        '<div class="cart-item-img">' + imgHtml + '</div>' +
        '<div class="cart-item-details">' +
          '<div class="cart-item-info">' +
            '<div class="cart-item-name">' + item.product_title + '</div>' +
            variantHtml +
            '<div class="cart-qty-row">' +
              '<button class="qty-btn" data-action="decrease" data-key="' + item.key + '" data-qty="' + item.quantity + '" aria-label="Decrease">' +
                '<svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M12 5V7H0L1.19209e-07 5L12 5Z" fill="currentColor"/></svg>' +
              '</button>' +
              '<span class="qty-val">' + item.quantity + '</span>' +
              '<button class="qty-btn" data-action="increase" data-key="' + item.key + '" data-qty="' + item.quantity + '" aria-label="Increase">' +
                '<svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M5 0H7V12H5V0Z" fill="currentColor"/><path d="M12 5V7H0L1.19209e-07 5L12 5Z" fill="currentColor"/></svg>' +
              '</button>' +
            '</div>' +
          '</div>' +
          '<div class="cart-item-right-col">' +
            '<button class="cart-item-remove" data-key="' + item.key + '" data-qty="0" aria-label="Remove item">' +
              '<svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor"><path d="M14 3h-3.53a3.07 3.07 0 00-.6-1.65C9.44.82 8.8.5 8 .5s-1.44.32-1.87.85A3.06 3.06 0 005.53 3H2a.5.5 0 000 1h1.25v10c0 .28.22.5.5.5h8.5a.5.5 0 00.5-.5V4H14a.5.5 0 000-1zM6.91 1.98c.23-.29.58-.48 1.09-.48s.85.19 1.09.48c.2.24.3.6.36 1.02h-2.9c.05-.42.17-.78.36-1.02zm4.84 11.52h-7.5V4h7.5v9.5z" fill="#ff4d4d"/><path d="M6.55 5.25a.5.5 0 00-.5.5v6a.5.5 0 001 0v-6a.5.5 0 00-.5-.5zM9.45 5.25a.5.5 0 00-.5.5v6a.5.5 0 001 0v-6a.5.5 0 00-.5-.5z" fill="#ff4d4d"/></svg>' +
            '</button>' +
            '<div class="cart-item-price">' + formatMoney(item.final_line_price) + '</div>' +
          '</div>' +
        '</div>';
      cartItemsList.appendChild(div);
    });
  }

  /* ── Milestones & progress bar ── */
  var FREE_SHIP_CENTS = 10000; /* $100.00 */
  var DISCOUNT_CENTS  = 7500;  /* $75.00  */
  var GIFT_CENTS      = 5000;  /* $50.00  */

  function updateMilestones(cents) {
    var pct = Math.min(100, Math.round((cents / FREE_SHIP_CENTS) * 100));
    if (progressFill) progressFill.style.width = pct + '%';

    if (progressText) {
      if (cents >= FREE_SHIP_CENTS) {
        progressText.innerHTML = '🎉 You unlocked <strong>Free Shipping</strong>!';
      } else {
        var left = formatMoney(FREE_SHIP_CENTS - cents);
        progressText.innerHTML = 'Add <strong>' + left + '</strong> more for Free Shipping';
      }
    }

    if (msGift)     msGift.classList.toggle('reached',     cents >= GIFT_CENTS);
    if (msDiscount) msDiscount.classList.toggle('reached', cents >= DISCOUNT_CENTS);
    if (msShipping) msShipping.classList.toggle('reached', cents >= FREE_SHIP_CENTS);
  }

  /* ── Urgency countdown (05:00) ── */
  var totalSecs = 300;
  (function tick() {
    if (!timerEl) return;
    if (totalSecs <= 0) { timerEl.textContent = 'EXPIRED'; return; }
    var m = Math.floor(totalSecs / 60);
    var s = totalSecs % 60;
    timerEl.textContent = (m < 10 ? '0' : '') + m + ':' + (s < 10 ? '0' : '') + s;
    totalSecs--;
    setTimeout(tick, 1000);
  })();

  /* ── Dispatch custom event so other scripts can hook ── */
  document.addEventListener('cart:updated', function() { fetchCart(); });

  /* ── Initial cart load (so badge is live on page load) ── */
  fetchCart();

}());
</script>

