<!--
  Custom Premium Pill Header for Shopify Dawn Theme
  Fully dynamic: capsule layout, predictive search (products only), rich cart drawer
  with urgency timer, free-shipping milestones, buyer protection add-on, cross-sell,
  View Cart + Checkout buttons, payment trust badges.
-->

<link rel="stylesheet" href="{{ 'component-list-menu.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-search.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-menu-drawer.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-cart-notification.css' | asset_url }}" media="print" onload="this.media='all'">

{%- if settings.predictive_search_enabled -%}
  <link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

{%- if section.settings.menu_type_desktop == 'mega' -%}
  <link rel="stylesheet" href="{{ 'component-mega-menu.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" media="print" onload="this.media='all'">

<style>
  /* ============================================================
     ROOT VARIABLES
     ============================================================ */
  :root {
    --color-primary: #e7a621;
    --color-primary-hover: #cf9119;
    --font-primary: 'Poppins', sans-serif;
    --shadow-drawer: -10px 0 40px rgba(0,0,0,0.10);
    --header-desktop-height: 80px;
    --header-mobile-height: 70px;
    --radius-pill: 100px;
  }

  /* ============================================================
     DAWN OVERRIDES – make the wrapper invisible so our capsule shows
     ============================================================ */
  sticky-header,
  .header-wrapper,
  .section-header,
  .shopify-section-group-header-group {
    border: none !important;
    border-bottom: none !important;
    box-shadow: none !important;
    background: transparent !important;
    padding: 0 !important;
  }
  .section-header { position: relative; z-index: 1000; }
  .drawer-open .section-header { z-index: 2001 !important; }

  /* ============================================================
     HEADER OUTER CONTAINER  (transparent background, no shadow)
     ============================================================ */
  .header-outer-container {
    width: 100%;
    padding: 18px 2rem;
    box-sizing: border-box;
    background: #FFF8ED !important;
    transition: padding 0.3s ease, transform 0.3s ease;
  }

  /* ============================================================
     HEADER INNER CAPSULE  (white pill, light border, NO shadow)
     ============================================================ */
  .header-inner {
    background: #ffffff;
    border-radius: var(--radius-pill);
    border: 1px solid black;
    height: var(--header-desktop-height);
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 44px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    box-sizing: border-box;
    transition: height 0.3s ease, border-color 0.3s ease;
  }

  /* ============================================================
     CENTERED LOGO
     ============================================================ */
  .logo-container {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    z-index: 10;
    display: flex;
    align-items: center;
  }
  .logo-container img {
    height: 38px;
    width: auto;
    object-fit: contain;
    transition: height 0.3s ease;
    display: block;
  }
  .logo-container .logo-text {
    font-family: var(--font-primary);
    font-weight: 800;
    font-size: 22px;
    color: var(--color-primary);
    white-space: nowrap;
  }

  /* ============================================================
     DESKTOP NAVIGATION  (left)
     ============================================================ */
  .desktop-nav {
    display: flex;
    align-items: center;
    gap: 24px;
    height: 100%;
  }
  .nav-link {
    font-family: var(--font-primary);
    font-size: 14px;
    font-weight: 600;
    color: #111;
    text-decoration: none;
    letter-spacing: 0.3px;
    padding: 3px 0;
    position: relative;
    transition: color 0.2s;
  }
  .nav-link:hover { color: var(--color-primary); }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0;
    width: 100%; height: 2px;
    background: var(--color-primary);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.3s ease;
  }
  .nav-link:hover::after,
  .nav-link.active::after { transform: scaleX(1); transform-origin: left; }

  /* ============================================================
     DESKTOP ACTION ICONS  (right, icon-only – no English text)
     ============================================================ */
  .desktop-actions {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .action-btn {
    font-size: 18px;
    color: #111;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color 0.2s, transform 0.2s;
    text-decoration: none;
  }
  .action-btn:hover { color: var(--color-primary); transform: translateY(-1px); }

  /* Cart badge */
  .cart-badge {
    position: absolute;
    top: -8px; right: -8px;
    background: var(--color-primary);
    color: #fff;
    font-family: var(--font-primary);
    font-size: 10px;
    font-weight: 700;
    min-width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 3px;
    border: 2px solid #fff;
    line-height: 1;
    box-sizing: border-box;
  }

  /* ============================================================
     MOBILE CONTROLS
     ============================================================ */
  .mobile-header-left,
  .mobile-header-right { display: none; }

  .mobile-hamburger {
    width: 42px; height: 42px;
    background: var(--color-primary);
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
  }
  .mobile-hamburger:hover { background: var(--color-primary-hover); }
  .mobile-hamburger span {
    display: block;
    width: 20px; height: 2px;
    background: #fff;
    border-radius: 2px;
  }
  .mobile-cart-btn {
    font-size: 22px;
    color: #111;
    position: relative;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
  }

  /* ============================================================
     STICKY MODIFIER
     ============================================================ */
  .header-outer-container.is-sticky {
    position: fixed;
    top: 0; left: 0; right: 0;
    padding: 10px 2rem;
    z-index: 1000;
    background: transparent !important;
    transform: translateY(0);
    transition: transform 0.3s ease, padding 0.3s ease;
  }
  .header-outer-container.is-sticky.header-hidden {
    transform: translateY(-100%);
  }
  .header-outer-container.is-sticky .header-inner {
    height: 66px;
    border-color: rgba(0,0,0,0.15);
  }
  .header-outer-container.is-sticky .logo-container img { height: 30px; }

  /* ============================================================
     OVERLAY
     ============================================================ */
  .hdr-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    backdrop-filter: blur(3px);
    z-index: 1999;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .hdr-overlay.active { opacity: 1; pointer-events: auto; }

  /* ============================================================
     SHARED CLOSE BUTTON
     ============================================================ */
  .drawer-close {
    font-size: 20px;
    color: #333;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    display: flex;
    align-items: center;
    transition: color 0.2s, transform 0.2s;
    line-height: 1;
  }
  .drawer-close:hover { color: var(--color-primary); transform: rotate(90deg); }

  /* ============================================================
     MOBILE SIDEBAR
     ============================================================ */
  .sidebar {
    position: fixed;
    top: 0; left: 0;
    width: 310px;
    height: 100vh;
    background: #fff;
    z-index: 2000;
    transform: translate3d(-100%, 0, 0);
    box-shadow: 8px 0 30px rgba(0,0,0,0.06);
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
    display: flex;
    flex-direction: column;
  }
  .sidebar.active { transform: translate3d(0, 0, 0); }

  .sidebar-header {
    padding: 22px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid #eee;
  }
  .sidebar-logo img { height: 28px; width: auto; }
  .sidebar-logo .logo-text { font-family: var(--font-primary); font-weight: 800; font-size: 18px; color: var(--color-primary); }

  .sidebar-content { flex: 1; overflow-y: auto; padding: 24px 20px; }
  .sidebar-nav { display: flex; flex-direction: column; gap: 4px; }
  .sidebar-link {
    font-family: var(--font-primary);
    font-size: 15px;
    font-weight: 600;
    color: #111;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 14px;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }
  .sidebar-link:hover,
  .sidebar-link.active { background: #fff4f0; color: var(--color-primary); }
  .sidebar-link i { font-size: 12px; opacity: 0.4; }
  .sidebar-link:hover i,
  .sidebar-link.active i { opacity: 1; }

  .sidebar-account { margin-top: 20px; padding-top: 20px; border-top: 1px solid #eee; }
  .sidebar-footer {
    padding: 20px;
    border-top: 1px solid #eee;
    background: #fafafa;
  }
  .sidebar-socials { display: flex; gap: 16px; justify-content: center; }
  .social-icon {
    font-size: 17px;
    color: #555;
    text-decoration: none;
    transition: color 0.2s, transform 0.2s;
  }
  .social-icon:hover { color: var(--color-primary); transform: translateY(-2px); }

  /* ============================================================
     SEARCH DRAWER  (full-width dropdown from top)
     ============================================================ */
  .search-drawer {
    position: fixed;
    top: 48px; left: 0;
    width: 100%;
    background: #fff;
    z-index: 1020;
    transform: translateY(-110%);
    box-shadow: 0 12px 40px rgba(0,0,0,0.10);
    transition: transform 0.32s cubic-bezier(0.4,0,0.2,1), top 0.3s ease;
    padding: 28px 0 24px;
  }
  .search-drawer.active {
    transform: translateY(0);
  }
  .header-outer-container.is-sticky ~ .search-drawer {
    top: 0;
  }

  .search-container { max-width: 860px; margin: 0 auto; padding: 0 24px; }

  .search-input-wrapper {
    display: flex;
    align-items: center;
    border-bottom: 2px solid #111;
    padding-bottom: 10px;
    gap: 12px;
  }
  .search-input-wrapper .search-icon { font-size: 20px; color: #aaa; flex-shrink: 0; }
  .search-input {
    flex: 1;
    border: none;
    font-family: var(--font-primary);
    font-size: 20px;
    font-weight: 500;
    outline: none;
    color: #111;
    background: transparent;
  }
  .search-input::placeholder { color: #bbb; }
  .search-close-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 22px;
    color: #555;
    display: flex;
    align-items: center;
    transition: color 0.2s, transform 0.2s;
  }
  .search-close-btn:hover { color: var(--color-primary); transform: scale(1.1); }

  /* Live results */
  .live-search-results {
    margin-top: 20px;
    display: none;
    max-height: 380px;
    overflow-y: auto;
  }
  .live-search-results.active { display: block; }
  .results-label {
    font-family: var(--font-primary);
    font-size: 11px;
    font-weight: 700;
    color: #aaa;
    text-transform: uppercase;
    letter-spacing: 0.7px;
    margin-bottom: 14px;
  }
  .search-product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
    gap: 12px;
  }
  .search-product-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 12px;
    border-radius: 12px;
    background: #f7f7f7;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }
  .search-product-card:hover { background: #ededed; transform: translateY(-2px); }
  .search-prod-img {
    width: 48px; height: 48px;
    border-radius: 8px;
    background: #fff;
    overflow: hidden;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .search-prod-img img { width: 100%; height: 100%; object-fit: cover; }
  .search-prod-title {
    font-family: var(--font-primary);
    font-size: 13px;
    font-weight: 600;
    color: #111;
    display: block;
    line-height: 1.3;
    margin-bottom: 2px;
  }
  .search-prod-price {
    font-family: var(--font-primary);
    font-size: 12px;
    font-weight: 700;
    color: var(--color-primary);
    display: block;
  }
  .search-no-results {
    padding: 20px 0;
    text-align: center;
    font-family: var(--font-primary);
    font-size: 14px;
    color: #999;
  }

  /* ============================================================
     CART DRAWER  (rich, EA-style)
     ============================================================ */
  .cart-drawer {
    position: fixed;
    top: 0; right: 0;
    width: 440px;
    max-width: 100vw;
    height: 100vh;
    background: #fff;
    z-index: 2000;
    transform: translateX(100%);
    box-shadow: var(--shadow-drawer);
    transition: transform 0.32s cubic-bezier(0.4,0,0.2,1);
    display: flex;
    flex-direction: column;
    font-family: var(--font-primary);
    border-left: 2px solid #2C2609 !important;
  }
  .cart-drawer.active { transform: translateX(0); }

  /* --- Cart header --- */
  .cart-header {
    padding: 18px 22px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1.5px solid #2C2609 !important;
    background-color: #ffffff;
    flex-shrink: 0;
  }
  .cart-title {
    font-size: 16px;
    font-weight: 800;
    color: #2c2609;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .cart-badge-box {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border: 1.5px solid #2C2609;
    border-radius: 4px;
    background-color: rgb(231 159 41) !important; /* brand gold */
    color: #2c2609;
    font-size: 11px;
    font-weight: 800;
    margin-left: 6px;
    vertical-align: middle;
    box-shadow: 1px 1px 0px 0px #2C2609;
  }
  .drawer-close {
    background: none;
    border: 1.5px solid #2C2609;
    border-radius: 50%;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #2c2609;
    transition: background 0.15s;
  }
  .drawer-close:hover {
    background-color: #fafafa;
  }

  /* --- Trust banner (3 icons) --- */
  .cart-trust-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 16px;
    background: #f7f7f7;
    border-bottom: 1.5px solid #2C2609 !important;
    font-size: 11px;
    font-weight: 700;
    color: #2c2609;
    flex-shrink: 0;
  }
  .cart-trust-bar span {
    display: flex;
    align-items: center;
    gap: 5px;
    white-space: nowrap;
  }
  .cart-trust-bar i { color: #ffa004; font-size: 13px; }

  @media (max-width: 480px) {
    .cart-trust-bar {
      padding: 8px 8px !important;
      font-size: 10px !important;
    }
    .cart-trust-bar span {
      font-size: 9.5px !important;
      white-space: nowrap !important;
      gap: 3px !important;
    }
    .cart-trust-bar i {
      font-size: 11px !important;
    }
  }

  /* --- Urgency timer --- */
  .cart-urgency {
    background: #ff4d4d;
    color: #fff;
    padding: 10px 20px;
    text-align: center;
    font-size: 12px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    flex-shrink: 0;
    border-bottom: 1.5px solid #2C2609 !important;
    animation: urgPulse 2s ease-in-out infinite;
  }
  @keyframes urgPulse {
    0%,100% { background: #ff4d4d; }
    50%      { background: #d63030; }
  }
  #cart-timer-countdown { font-variant-numeric: tabular-nums; }

  /* --- Shipping progress (commented/hidden) --- */
  .cart-progress-wrap {
    display: none;
  }

  /* --- Scrollable drawer body --- */
  .cart-body {
    flex: 1;
    overflow-y: auto;
    padding: 0; /* padding added to inner elements for spacing */
  }

  /* Empty state */
  .cart-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    margin: auto;
    gap: 14px;
    padding: 40px 0;
  }
  .cart-empty i { font-size: 60px; color: #ddd; }
  .cart-empty p { font-size: 15px; font-weight: 500; color: #444; margin: 0; }

  /* Item list */
  .cart-items-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 20px 22px;
  }

  .cart-item {
    display: flex !important;
    gap: 12px !important;
    padding: 14px !important;
    border: 1px solid #2C2609 !important;
    border-radius: 16px !important;
    background-color: #ffffff !important;
    box-shadow: none !important;
    box-sizing: border-box !important;
    align-items: flex-start !important;
    width: 100% !important;
  }
  .cart-item:last-child { margin-bottom: 0; }

  .cart-item-img {
    width: 76px !important;
    height: 76px !important;
    border-radius: 12px !important;
    background: #f9fafb !important;
    overflow: hidden !important;
    flex-shrink: 0 !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    border: 1px solid #e5e7eb !important;
  }
  .cart-item-img img { width: 100% !important; height: 100% !important; object-fit: cover !important; }
  .cart-item-img i { font-size: 28px; color: var(--color-primary); }

  .cart-item-details {
    flex: 1 !important;
    display: flex !important;
    flex-direction: row !important;
    align-items: flex-start !important;
    justify-content: space-between !important;
    min-width: 0 !important;
    gap: 8px !important;
  }
  .cart-item-info {
    flex: 1 !important;
    display: flex !important;
    flex-direction: column !important;
    min-width: 0 !important;
  }
  .cart-item-name {
    font-family: 'Poppins', sans-serif !important;
    font-size: 14px !important;
    font-weight: 700 !important;
    color: #1d211e !important;
    line-height: 1.3 !important;
    white-space: normal !important;
    word-break: break-word !important;
  }
  .cart-item-variant {
    font-family: 'Poppins', sans-serif !important;
    font-size: 12px !important;
    color: #667085 !important;
    margin-top: 3px !important;
    margin-bottom: 8px !important;
    font-weight: 500 !important;
  }
  .cart-item-right-col {
    display: flex !important;
    flex-direction: column !important;
    align-items: flex-end !important;
    justify-content: space-between !important;
    height: 100% !important;
    min-height: 72px !important;
    flex-shrink: 0 !important;
  }
  .cart-item-price {
    font-family: 'Poppins', sans-serif !important;
    font-size: 15px !important;
    font-weight: 700 !important;
    color: #1d211e !important;
    margin-top: auto !important;
    white-space: nowrap !important;
  }

  .cart-qty-row {
    display: flex !important;
    align-items: center !important;
    gap: 0px !important;
    margin-top: 4px !important;
    border: 1px solid #d0d5dd !important;
    border-radius: 20px !important;
    background-color: #ffffff !important;
    width: fit-content !important;
    overflow: hidden !important;
    height: 28px !important;
    box-sizing: border-box !important;
  }
  .qty-btn {
    width: 26px; height: 100%;
    border: none !important;
    border-radius: 0 !important;
    background: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    color: #2C2609;
    transition: background 0.15s;
    flex-shrink: 0;
  }
  .qty-btn:hover { background-color: #fafafa; }
  .qty-val {
    font-size: 12px;
    font-weight: 700;
    color: #2c2609;
    min-width: 22px;
    text-align: center;
    border-left: 1px solid #d0d5dd;
    border-right: 1px solid #d0d5dd;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Remove link */
  .cart-item-remove {
    position: relative !important;
    top: auto !important;
    right: auto !important;
    background: none !important;
    border: none !important;
    cursor: pointer;
    font-size: 0 !important;
    color: #ff4d4d !important;
    transition: color 0.15s;
    padding: 0 !important;
    width: 20px !important;
    height: 20px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
  }
  .cart-item-remove:hover { color: #d63030 !important; }

  /* Hide elements as requested */
  .maison__cart-benefit-text {
    display: none !important;
  }

  .maison__cart-shipping-text {
    display: none !important;
  }

  /* --- Cross-sell --- */
  .cart-cross-sell {
    margin-top: 18px;
    padding: 20px 22px;
    border-top: 1.5px solid #2C2609;
    background-color: #fafafa;
  }
  .cross-sell-label {
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: #2c2609;
    margin-bottom: 12px;
    background-color: #e2e2e2;
    padding: 4px 8px;
    display: inline-block;
    border-radius: 4px;
  }
  .cross-sell-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    border: 1.5px solid #2C2609 !important;
    border-radius: 12px !important;
    background-color: #fffdeb !important;
    box-shadow: 0px 4px 0px 0px #2C2609 !important;
    box-sizing: border-box;
  }
  .cross-sell-img {
    width: 56px; height: 56px;
    border-radius: 8px;
    background: #f5f5f5;
    overflow: hidden;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1.5px solid #2C2609;
  }
  .cross-sell-img img { width: 100%; height: 100%; object-fit: contain; }
  .cross-sell-info { flex: 1; }
  .cross-sell-name { font-size: 12px; font-weight: 800; color: #2c2609; }
  .cross-sell-price { font-size: 12px; font-weight: 700; color: #666666; margin-top: 2px; }
  .btn-cross-add {
    padding: 8px 16px;
    background: rgb(255 159 7) !important;
    color: #ffffff !important;
    border: 1px solid #2C2609 !important;
    border-radius: 7px !important;
    font-size: 11px;
    font-weight: 800;
    font-family: inherit;
    cursor: pointer;
    transition: transform 0.1s ease, box-shadow 0.1s ease;
    white-space: nowrap;
    flex-shrink: 0;
    position: relative;
    top: 0;
  }
  .btn-cross-add:hover { background: #e08b00 !important; }
  .btn-cross-add:active {
    top: 2px;
    box-shadow: none;
  }
  .btn-cross-add.loading { opacity: 0.6; pointer-events: none; }

  /* --- Cart footer --- */
  .cart-footer {
    padding: 18px 22px;
    border-top: 1.5px solid #2C2609 !important;
    background: #ffffff;
    flex-shrink: 0;
    display: none;
  }
  .cart-subtotal-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
    font-family: inherit;
  }
  .cart-subtotal-row .subtotal-label {
    font-size: 13px;
    font-weight: 800;
    color: #2c2609;
    text-transform: uppercase;
  }
  .cart-subtotal-row .subtotal-value {
    font-size: 16px;
    font-weight: 800;
    color: #2c2609;
  }

  .maison__cart-price-wrapper {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .totals__total-value-compare {
    text-decoration: line-through;
    color: #98a2b3;
    font-size: 13px;
  }

  /* View Cart + Checkout buttons */
  .cart-cta-row {
    display: flex;
    gap: 10px;
    margin-bottom: 14px;
  }
  .btn-checkout-wrap { flex: 1; }
  .btn-checkout-wrap form { margin: 0; }
  .btn-checkout {
    width: 100% !important;
    padding: 16px 18px !important;
    border-radius: 14px !important;
    color: #ffffff !important;
    background: #ffa004 !important;
    border: none !important;
    font-family: 'Poppins', sans-serif !important;
    font-size: 14px !important;
    font-weight: 700 !important;
    cursor: pointer;
    transition: transform 0.15s ease, background-color 0.2s ease, box-shadow 0.2s ease !important;
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    gap: 8px;
    letter-spacing: 0.2px;
    box-shadow: 0 4px 14px rgba(255, 160, 4, 0.35) !important;
    position: relative;
    top: 0;
  }
  .btn-checkout:hover {
    background-color: #e59000 !important;
  }
  .cart-btn-price-lock {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 15px;
    font-weight: 800;
  }
  @media (max-width: 480px) {
    .btn-checkout {
      padding: 14px 12px !important;
      font-size: 12px !important;
      border-radius: 12px !important;
    }
    .cart-btn-price-lock {
      font-size: 13px !important;
    }
  }

  .cart-payment-icons {
    display: flex !important;
    justify-content: center !important;
    align-items: center !important;
    gap: 6px !important;
    flex-wrap: wrap !important;
    margin-top: 15px !important;
    border-top: 1px dashed #e5e7eb !important;
    padding-top: 12px !important;
  }
  .btn-checkout:active {
    top: 4px;
    box-shadow: none !important;
  }

  /* Payment icons */
  .cart-payment-icons {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    margin-top: 15px;
  }

  /* Continue shopping link (empty state) */
  .btn-continue-shop {
    padding: 12px 28px;
    border-radius: 50px;
    background: var(--color-primary);
    color: #fff;
    border: none;
    font-family: var(--font-primary);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }
  .btn-continue-shop:hover { background: var(--color-primary-hover); }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 1100px) {
    .header-outer-container { padding: 16px 24px; }
    .header-inner { padding: 0 28px; }
    .desktop-nav { gap: 18px; }
    .desktop-actions { gap: 16px; }
  }

  @media (max-width: 990px) {
    .header-outer-container { padding: 12px 1.5rem; }
    .header-outer-container.is-sticky { padding: 10px 1.5rem; }
    .header-inner { height: var(--header-mobile-height); border-radius: 50px; padding: 0 16px; }
    .desktop-nav, .desktop-actions { display: none; }
    .mobile-header-left, .mobile-header-right { display: flex; align-items: center; }
    .mobile-header-right { gap: 14px; }
    .logo-container { max-width: 45%; }
    .logo-container img { height: 28px !important; max-height: 28px; max-width: 100%; }
  }

  @media (max-width: 480px) {
    .cart-drawer { width: 100vw; }
  }
</style>

{%- style -%}
  .section-header {
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-header {
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }
{%- endstyle -%}

<!-- ============================================================
     HEADER CAPSULE
     ============================================================ -->
<div class="header-outer-container" id="main-header">
  <div class="header-inner">

    <!-- Desktop Nav (Left) -->
    <nav class="desktop-nav" aria-label="Main navigation">
      {%- for link in section.settings.menu.links -%}
        <a href="{{ link.url }}" class="nav-link{% if link.active %} active{% endif %}">{{ link.title }}</a>
      {%- endfor -%}
    </nav>

    <!-- Mobile Hamburger (Left) -->
    <div class="mobile-header-left">
      <button class="mobile-hamburger" id="sidebar-open-btn" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>

    <!-- Centered Logo -->
    <div class="logo-container">
      <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        {%- if settings.logo != blank -%}
          {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
          {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
          {{ settings.logo | image_url: width: 500 | image_tag:
            style: 'height: 38px; width: auto;',
            class: 'header__heading-logo',
            widths: '50, 100, 150, 200, 250, 300, 400, 500',
            height: logo_height,
            width: settings.logo_width,
            alt: logo_alt
          }}
        {%- else -%}
          <span class="logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    <!-- Desktop Actions (Right) — icon-only, no English labels -->
    <div class="desktop-actions">
      <button class="action-btn" id="search-btn-desktop" aria-label="Search">
        <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
      </button>
      {%- if shop.customer_accounts_enabled -%}
        <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
           class="action-btn" aria-label="{{ 'customer.account.title' | t }}">
          {%- if section.settings.enable_customer_avatar and customer -%}
            <i class="fa-solid fa-circle-user" aria-hidden="true"></i>
          {%- else -%}
            <i class="fa-regular fa-circle-user" aria-hidden="true"></i>
          {%- endif -%}
        </a>
      {%- endif -%}
      <button class="action-btn" id="cart-btn-desktop" aria-label="Cart">
        <i class="fa-solid fa-bag-shopping" aria-hidden="true"></i>
        <span class="cart-badge" id="cart-badge-desktop">{{ cart.item_count }}</span>
      </button>
    </div>

    <!-- Mobile Actions (Right) -->
    <div class="mobile-header-right">
      <button class="mobile-cart-btn" id="search-btn-mobile" aria-label="Search" style="font-size:19px;">
        <i class="fa-solid fa-magnifying-glass"></i>
      </button>
      <button class="mobile-cart-btn" id="cart-btn-mobile" aria-label="Cart">
        <i class="fa-solid fa-bag-shopping"></i>
        <span class="cart-badge" id="cart-badge-mobile">{{ cart.item_count }}</span>
      </button>
    </div>

  </div>
</div>

<!-- Global Overlay -->
<div class="hdr-overlay" id="hdr-overlay"></div>

<!-- ============================================================
     MOBILE SIDEBAR
     ============================================================ -->
<aside class="sidebar" id="mobile-sidebar" aria-label="Navigation drawer" aria-hidden="true">
  <div class="sidebar-header">
    <div class="sidebar-logo">
      {%- if settings.logo != blank -%}
        <img src="{{ settings.logo | image_url: width: 260 }}" alt="{{ shop.name }}" style="height:28px;width:auto;">
      {%- else -%}
        <span class="logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </div>
    <button class="drawer-close" id="sidebar-close-btn" aria-label="Close menu">
      <i class="fa-solid fa-xmark"></i>
    </button>
  </div>

  <div class="sidebar-content">
    <nav class="sidebar-nav" aria-label="Mobile navigation">
      {%- for link in section.settings.menu.links -%}
        <a href="{{ link.url }}" class="sidebar-link{% if link.active %} active{% endif %}">
          {{ link.title }}
          <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
        </a>
      {%- endfor -%}
    </nav>
    {%- if shop.customer_accounts_enabled -%}
      <div class="sidebar-account">
        <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="sidebar-link">
          <span><i class="fa-regular fa-circle-user" style="margin-right:8px;" aria-hidden="true"></i>{{ 'customer.account.title' | t }}</span>
          <i class="fa-solid fa-chevron-right" style="opacity:1;" aria-hidden="true"></i>
        </a>
      </div>
    {%- endif -%}
  </div>

  <div class="sidebar-footer">
    <div class="sidebar-socials">
      {%- if settings.social_facebook_link != blank -%}
        <a href="{{ settings.social_facebook_link }}" class="social-icon" target="_blank" rel="noopener" aria-label="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
      {%- endif -%}
      {%- if settings.social_instagram_link != blank -%}
        <a href="{{ settings.social_instagram_link }}" class="social-icon" target="_blank" rel="noopener" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
      {%- endif -%}
      {%- if settings.social_twitter_link != blank -%}
        <a href="{{ settings.social_twitter_link }}" class="social-icon" target="_blank" rel="noopener" aria-label="Twitter / X"><i class="fa-brands fa-x-twitter"></i></a>
      {%- endif -%}
      {%- if settings.social_tiktok_link != blank -%}
        <a href="{{ settings.social_tiktok_link }}" class="social-icon" target="_blank" rel="noopener" aria-label="TikTok"><i class="fa-brands fa-tiktok"></i></a>
      {%- endif -%}
      {%- if settings.social_pinterest_link != blank -%}
        <a href="{{ settings.social_pinterest_link }}" class="social-icon" target="_blank" rel="noopener" aria-label="Pinterest"><i class="fa-brands fa-pinterest-p"></i></a>
      {%- endif -%}
    </div>
  </div>
</aside>

<!-- ============================================================
     SEARCH DRAWER
     ============================================================ -->
<div class="search-drawer" id="search-drawer" aria-label="Search">
  <div class="search-container">
    <form action="{{ routes.search_url }}" method="get" role="search" class="search-input-wrapper">
      <input type="hidden" name="type" value="product">
      <i class="fa-solid fa-magnifying-glass search-icon" aria-hidden="true"></i>
      <input
        type="text"
        name="q"
        id="search-input"
        class="search-input"
        placeholder="{{ 'general.search.placeholder' | t | default: 'Search products…' }}"
        autocomplete="off"
        aria-label="Search products"
      >
      <button type="button" class="search-close-btn" id="search-close-btn" aria-label="Close search">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </form>

    <div class="live-search-results" id="live-search-results" aria-live="polite">
      <div class="results-label">Suggestions</div>
      <div class="search-product-grid" id="search-results-grid"></div>
    </div>
  </div>
</div>

<!-- ============================================================
     CART DRAWER  (EA Sticky Add to Cart style)
     ============================================================ -->
<aside class="cart-drawer" id="cart-drawer" aria-label="Shopping cart" aria-hidden="true">

  <!-- Header -->
  <div class="cart-header">
    <span class="cart-title">MY CART <span class="cart-badge-box" id="cart-badge-desktop">{{ cart.item_count }}</span></span>
    <button class="drawer-close" id="cart-close-btn" aria-label="Close cart">
      <i class="fa-solid fa-xmark"></i>
    </button>
  </div>

  <!-- Trust bar -->
  {%- if section.settings.show_trust_bar != false -%}
    <div class="cart-trust-bar">
      <span><i class="fa-solid fa-award"></i> {{ section.settings.trust_text_1 | default: "15-day money-back guarantee" }}</span>
      <span><i class="fa-solid fa-shield-halved"></i> {{ section.settings.trust_text_2 | default: "100% Secure Checkout" }}</span>
    </div>
  {%- endif -%}

  <!-- Urgency timer (Red Banner) -->
  {%- if section.settings.show_urgency_timer != false -%}
    <div class="cart-urgency">
      <i class="fa-solid fa-clock"></i>
      <span class="urgency-timer-text">{{ section.settings.urgency_timer_text | default: "Hurry! Your cart expires in" }}</span>
      <strong id="cart-timer-countdown">04:26</strong>
    </div>
  {%- endif -%}

  <!-- Scrollable body -->
  <div class="cart-body" id="cart-body">

    <!-- Empty state (Matching Image 1) -->
    <div class="cart-empty" id="cart-empty" {% if cart.item_count > 0 %}style="display:none"{% endif %}>
      <h2 class="cart-empty-title">{{ section.settings.empty_cart_title | default: "YOUR CART IS EMPTY" }}</h2>
      <button class="btn-continue-shop" id="btn-continue-shop">{{ section.settings.empty_cart_btn_text | default: "Continue shopping" }}</button>
      {%- if section.settings.show_login_link != false -%}
        <div class="cart-empty-login">
          <strong>HAVE AN ACCOUNT?</strong><br>
          <a href="{{ routes.account_login_url }}" class="cart-login-link">Log in</a> to check out faster.
        </div>
      {%- endif -%}
    </div>

    <!-- Items (SSR bootstrap – JS will re-render on open) -->
    <div class="cart-items-list" id="cart-items-list" {% if cart.item_count == 0 %}style="display:none"{% endif %}>
      {%- for item in cart.items -%}
        <div class="cart-item" data-key="{{ item.key }}">
          <div class="cart-item-img">
            {%- if item.image != blank -%}
              <img src="{{ item.image | image_url: width: 140 }}" alt="{{ item.title | escape }}" loading="lazy">
            {%- else -%}
              <i class="fa-solid fa-shirt"></i>
            {%- endif -%}
          </div>
          <div class="cart-item-details">
            <div class="cart-item-info">
              <div class="cart-item-name">{{ item.product.title }}</div>
              {%- unless item.product.has_only_default_variant -%}
                <div class="cart-item-variant">Scent: {{ item.variant.title }}</div>
              {%- endunless -%}
              <div class="cart-qty-row">
                <button class="qty-btn" data-action="decrease" data-key="{{ item.key }}" data-qty="{{ item.quantity }}" aria-label="Decrease quantity">
                  <svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M12 5V7H0L1.19209e-07 5L12 5Z" fill="currentColor"/></svg>
                </button>
                <span class="qty-val">{{ item.quantity }}</span>
                <button class="qty-btn" data-action="increase" data-key="{{ item.key }}" data-qty="{{ item.quantity }}" aria-label="Increase quantity">
                  <svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M5 0H7V12H5V0Z" fill="currentColor"/><path d="M12 5V7H0L1.19209e-07 5L12 5Z" fill="currentColor"/></svg>
                </button>
              </div>
            </div>
            <div class="cart-item-right-col">
              <button class="cart-item-remove" data-key="{{ item.key }}" data-qty="0" aria-label="Remove item">
                <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor"><path d="M14 3h-3.53a3.07 3.07 0 00-.6-1.65C9.44.82 8.8.5 8 .5s-1.44.32-1.87.85A3.06 3.06 0 005.53 3H2a.5.5 0 000 1h1.25v10c0 .28.22.5.5.5h8.5a.5.5 0 00.5-.5V4H14a.5.5 0 000-1zM6.91 1.98c.23-.29.58-.48 1.09-.48s.85.19 1.09.48c.2.24.3.6.36 1.02h-2.9c.05-.42.17-.78.36-1.02zm4.84 11.52h-7.5V4h7.5v9.5z" fill="#ff4d4d"/><path d="M6.55 5.25a.5.5 0 00-.5.5v6a.5.5 0 001 0v-6a.5.5 0 00-.5-.5zM9.45 5.25a.5.5 0 00-.5.5v6a.5.5 0 001 0v-6a.5.5 0 00-.5-.5z" fill="#ff4d4d"/></svg>
              </button>
              <div class="cart-item-price">{{ item.final_line_price | money }}</div>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

    <!-- Cross-sell -->
    {%- assign cross_product = all_products[section.settings.cross_sell_product] -%}
    <div class="cart-cross-sell" id="cart-cross-sell"
      {% if cart.item_count == 0 or cross_product == blank %}style="display:none"{% endif %}>
      <div class="cross-sell-label">{{ section.settings.cross_sell_heading | default: "73% of people also got..." }}</div>
      {%- if cross_product != blank -%}
        {%- assign cs_variant = cross_product.first_available_variant -%}
        <div class="cross-sell-card">
          <div class="cross-sell-img">
            {%- if cross_product.featured_image != blank -%}
              <img src="{{ cross_product.featured_image | image_url: width: 110 }}" alt="{{ cross_product.title }}" loading="lazy">
            {%- else -%}
              <i class="fa-solid fa-shirt"></i>
            {%- endif -%}
          </div>
          <div class="cross-sell-info">
            <div class="cross-sell-name">{{ cross_product.title }}</div>
            <div class="cross-sell-price">{{ cross_product.price | money }}</div>
          </div>
          <button class="btn-cross-add" id="btn-cross-add" data-variant="{{ cs_variant.id }}">
            + Add
          </button>
        </div>
      {%- endif -%}
    </div>

  </div><!-- /.cart-body -->

  <!-- Footer -->
  <div class="cart-footer" id="cart-footer" {% if cart.item_count > 0 %}style="display:block"{% endif %}>
    <div class="maison__cart-shipping-text">
      <span class="bold">Shipping to <span id="locationinfop" class="bold">PK 🇵🇰</span></span>
      <span style="color: #12b76a; font-weight: 600;">FREE</span>
    </div>

    <div class="cart-subtotal-row">
      <span class="subtotal-label">Estimated total</span>
      <div class="maison__cart-price-wrapper">
        {%- if cart.original_total_price > cart.total_price -%}
          <span class="totals__total-value-compare">{{ cart.original_total_price | money }} EUR</span>
        {%- endif -%}
        <span class="subtotal-value bold" id="cart-subtotal">{{ cart.total_price | money }} EUR</span>
      </div>
    </div>

    <div class="cart-cta-row">
      <div class="btn-checkout-wrap" style="width: 100%;">
        <form action="{{ routes.cart_url }}" method="post">
          <button type="submit" id="CartDrawer-Checkout" name="checkout" class="btn-checkout">
            <span>{{ section.settings.checkout_btn_text | default: "Continue to Secure Checkout" }} •</span>
            <span class="cart-btn-price-lock">
              <span class="cart-btn-subtotal">{{ cart.total_price | money }}</span>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-left: 2px;"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </span>
          </button>
        </form>
      </div>
    </div>

    <div class="maison__cart-benefit-text">
      <div class="maison__cart-benefit-text-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="rgb(231 159 41)" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span style="color: #383633; font-size: 12px;">30-day money-back guarantee</span>
      </div>
      
      <div class="maison__cart-benefit-text-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="rgb(231 159 41)" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        <span style="color: #383633; font-size: 12px;">Secure Checkout</span>
      </div>
    </div>

