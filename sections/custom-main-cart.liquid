<!-- sections/custom-main-cart.liquid -->
{{ 'https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css' | stylesheet_tag }}

{%- style -%}
  .custom-main-cart-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | default: 40 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 60 }}px;
    background-color: {{ section.settings.bg_color | default: '#ffffff' }};
    font-family: 'Poppins', sans-serif;
  }

  .cm-cart-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    box-sizing: border-box;
  }

  /* Top Notice Bar */
  .cm-cart-notice-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 700;
    color: #111111;
    margin-bottom: 30px;
  }

  .cm-notice-dot {
    width: 8px;
    height: 8px;
    background-color: #e63946;
    border-radius: 50%;
    display: inline-block;
    box-shadow: 0 0 0 3px rgba(230, 57, 70, 0.2);
    animation: cmPulse 1.8s infinite;
  }

  @keyframes cmPulse {
    0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(230, 57, 70, 0.7); }
    70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(230, 57, 70, 0); }
    100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(230, 57, 70, 0); }
  }

  /* Header */
  .cm-cart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
  }

  .cm-cart-title {
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 900;
    text-transform: uppercase;
    color: #111111;
    margin: 0;
    line-height: 1.1;
  }

  .cm-continue-link {
    font-size: 14px;
    font-weight: 600;
    color: #555555;
    text-decoration: underline;
    transition: color 0.2s;
  }

  .cm-continue-link:hover {
    color: #111111;
  }

  /* Table Header */
  .cm-cart-table-head {
    display: grid;
    grid-template-columns: 2.5fr 1fr 1fr;
    padding: 12px 0;
    border-bottom: 1px solid #e5e5e5;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #888888;
    text-transform: uppercase;
  }

  .cm-th-total {
    text-align: right;
  }

  .cm-th-qty {
    text-align: center;
  }

  /* Items List */
  .cm-cart-items-list {
    display: flex;
    flex-direction: column;
  }

  .cm-cart-item {
    display: grid;
    grid-template-columns: 2.5fr 1fr 1fr;
    align-items: center;
    padding: 24px 0;
    border-bottom: 1px solid #e5e5e5;
  }

  /* Item Info */
  .cm-item-info-col {
    display: flex;
    gap: 16px;
    align-items: center;
  }

  .cm-item-img-wrap {
    width: 90px;
    height: 90px;
    flex-shrink: 0;
    background-color: #faf8f5;
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
    box-sizing: border-box;
  }

  .cm-item-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .cm-item-details {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cm-item-vendor {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #777777;
  }

  .cm-item-title {
    font-size: 14px;
    font-weight: 800;
    text-transform: uppercase;
    color: #111111;
    text-decoration: none;
    line-height: 1.3;
  }

  .cm-item-title:hover {
    color: #fe9d01;
  }

  .cm-item-unit-price {
    font-size: 13px;
    font-weight: 700;
    color: #333333;
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .cm-item-compare-price {
    text-decoration: line-through;
    color: #888888;
    font-weight: 500;
  }

  .cm-item-property {
    font-size: 12px;
    color: #666666;
  }

  /* Quantity & Remove */
  .cm-item-qty-col {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .cm-qty-pill {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border: 1px solid #d0d5dd;
    border-radius: 20px;
    width: 100px;
    height: 38px;
    padding: 0 10px;
    background: #ffffff;
    box-sizing: border-box;
  }

  .cm-qty-btn {
    background: none;
    border: none;
    font-size: 16px;
    font-weight: 600;
    color: #111111;
    cursor: pointer;
    padding: 0;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cm-qty-input {
    width: 30px;
    text-align: center;
    border: none;
    font-size: 14px;
    font-weight: 700;
    color: #111111;
    outline: none;
    background: transparent;
  }

  .cm-item-remove-btn {
    background: none;
    border: none;
    color: #666666;
    font-size: 15px;
    cursor: pointer;
    transition: color 0.2s;
    padding: 6px;
  }

  .cm-item-remove-btn:hover {
    color: #e63946;
  }

  /* Item Total */
  .cm-item-total-col {
    text-align: right;
    font-size: 15px;
    font-weight: 800;
    color: #111111;
  }

  /* Bottom Section (Instructions + Summary) */
  .cm-cart-bottom-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 50px;
    margin-top: 40px;
    align-items: start;
  }

  /* Notes */
  .cm-instructions-box h3 {
    font-size: 15px;
    font-weight: 800;
    color: #111111;
    margin: 0 0 12px 0;
  }

  .cm-instructions-textarea {
    width: 100%;
    min-height: 120px;
    padding: 12px;
    border: 1px solid #d0d5dd;
    border-radius: 8px;
    font-family: inherit;
    font-size: 13.5px;
    color: #111111;
    box-sizing: border-box;
    outline: none;
    resize: vertical;
  }

  .cm-instructions-textarea:focus {
    border-color: #111111;
  }

  /* Summary Box */
  .cm-summary-box {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
  }

  .cm-total-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 8px;
  }

  .cm-total-label {
    font-size: 14px;
    font-weight: 900;
    text-transform: uppercase;
    color: #111111;
    letter-spacing: 0.04em;
  }

  .cm-total-amount {
    font-size: 20px;
    font-weight: 900;
    color: #111111;
  }

  .cm-taxes-note {
    font-size: 12.5px;
    color: #666666;
    margin-bottom: 24px;
  }

  /* Checkout Button (3D Offset Shadow) */
  .cm-checkout-btn {
    width: 100%;
    max-width: 360px;
    height: 52px;
    background-color: {{ section.settings.btn_bg | default: '#fe9d01' }};
    color: #000000;
    border: 2px solid #111111;
    border-radius: 14px;
    box-shadow: 0 4px 0 0 #111111;
    font-size: 15px;
    font-weight: 900;
    font-family: inherit;
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
  }

  .cm-checkout-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 0 0 #111111;
  }

  .cm-checkout-btn:active {
    transform: translateY(2px);
    box-shadow: 0 2px 0 0 #111111;
  }

  /* Dynamic Checkout Buttons */
  .cm-additional-checkout-buttons {
    width: 100%;
    max-width: 360px;
    margin-bottom: 16px;
  }

  .cm-terms-notice {
    font-size: 11px;
    line-height: 1.5;
    color: #666666;
    max-width: 360px;
  }

  .cm-terms-notice a {
    color: #111111;
    text-decoration: underline;
  }

  /* Empty Cart State */
  .cm-cart-empty-wrapper {
    text-align: center;
    padding: 60px 20px;
  }

  .cm-empty-title {
    font-size: 28px;
    font-weight: 900;
    text-transform: uppercase;
    margin-bottom: 16px;
    color: #111111;
  }

  .cm-empty-btn {
    display: inline-block;
    padding: 14px 32px;
    background-color: #fe9d01;
    color: #000000;
    border: 2px solid #111111;
    border-radius: 14px;
    box-shadow: 0 4px 0 0 #111111;
    font-size: 14px;
    font-weight: 800;
    text-decoration: none;
    transition: transform 0.15s;
  }

  .cm-empty-btn:hover {
    transform: translateY(-2px);
  }

  /* Responsive Mobile Styling */
  @media (max-width: 768px) {
    .cm-cart-table-head {
      display: none;
    }

    .cm-cart-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }

    .cm-cart-item {
      grid-template-columns: 1fr;
      gap: 16px;
      padding: 20px 0;
      position: relative;
    }

    .cm-item-info-col {
      align-items: flex-start;
    }

    .cm-item-qty-col {
      justify-content: space-between;
      width: 100%;
    }

    .cm-item-total-col {
      text-align: left;
      font-size: 16px;
    }

    .cm-cart-bottom-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .cm-summary-box {
      align-items: stretch;
      text-align: left;
    }

    .cm-total-row {
      justify-content: space-between;
    }

    .cm-checkout-btn,
    .cm-additional-checkout-buttons,
    .cm-terms-notice {
      max-width: 100%;
    }
  }
{%- endstyle -%}

<div class="custom-main-cart-{{ section.id }}">
  <div class="cm-cart-container">

    <!-- Top Urgency Notice -->
    {%- if section.settings.show_urgency_notice -%}
      <div class="cm-cart-notice-bar">
        <span class="cm-notice-dot"></span>
        <span><strong>{{ section.settings.urgency_count | default: '6' }} People</strong> are checking out now</span>
      </div>
    {%- endif -%}

    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post" id="CustomMainCartForm">

        <!-- Page Header -->
        <div class="cm-cart-header">
          <h1 class="cm-cart-title">YOUR CART</h1>
          <a href="{{ routes.all_products_collection_url }}" class="cm-continue-link">Continue shopping</a>
        </div>

        <!-- Table Header (Desktop) -->
        <div class="cm-cart-table-head">
          <span>PRODUCT</span>
          <span class="cm-th-qty">QUANTITY</span>
          <span class="cm-th-total">TOTAL</span>
        </div>

        <!-- Cart Items List -->
        <div class="cm-cart-items-list">
          {%- for item in cart.items -%}
            <div class="cm-cart-item" data-key="{{ item.key }}">
              
              <!-- Column 1: Image & Details -->
              <div class="cm-item-info-col">
                <div class="cm-item-img-wrap">
                  {%- if item.image != blank -%}
                    <img src="{{ item.image | image_url: width: 240 }}" alt="{{ item.title | escape }}" loading="lazy">
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </div>

                <div class="cm-item-details">
                  <div class="cm-item-vendor">{{ item.product.vendor | uppercase }}</div>
                  <a href="{{ item.url }}" class="cm-item-title">{{ item.product.title }}</a>
                  
                  <div class="cm-item-unit-price">
                    <span>{{ item.price | money }}</span>
                    {%- if item.original_price > item.price -%}
                      <span class="cm-item-compare-price">{{ item.original_price | money }}</span>
                    {%- endif -%}
                  </div>

                  {%- unless item.product.has_only_default_variant -%}
                    <div class="cm-item-property">
                      {%- for option in item.options_with_values -%}
                        <span>{{ option.name }}: {{ option.value }}</span>{%- unless forloop.last -%}, {%- endunless -%}
                      {%- endfor -%}
                    </div>
                  {%- endunless -%}
                </div>
              </div>

              <!-- Column 2: Quantity & Remove -->
              <div class="cm-item-qty-col">
                <div class="cm-qty-pill">
                  <button type="button" class="cm-qty-btn" data-action="decrease" data-key="{{ item.key }}" data-qty="{{ item.quantity }}">&minus;</button>
                  <input type="number" class="cm-qty-input" value="{{ item.quantity }}" readonly>
                  <button type="button" class="cm-qty-btn" data-action="increase" data-key="{{ item.key }}" data-qty="{{ item.quantity }}">+</button>
                </div>

                <button type="button" class="cm-item-remove-btn" data-action="remove" data-key="{{ item.key }}" aria-label="Remove item">
                  <i class="fa-regular fa-trash-can"></i>
                </button>
              </div>

              <!-- Column 3: Total Price -->
              <div class="cm-item-total-col">
                {{ item.final_line_price | money }}
              </div>

            </div>
          {%- endfor -%}
        </div>

        <!-- Bottom Grid: Instructions & Checkout Summary -->
        <div class="cm-cart-bottom-grid">
          
          <!-- Special Instructions -->
          <div class="cm-instructions-box">
            <h3>Order special instructions</h3>
            <textarea name="note" class="cm-instructions-textarea" placeholder="Special instructions for order...">{{ cart.note }}</textarea>
          </div>

          <!-- Summary Box -->
          <div class="cm-summary-box">
            <div class="cm-total-row">
              <span class="cm-total-label">ESTIMATED TOTAL</span>
              <span class="cm-total-amount">{{ cart.total_price | money }} {{ cart.currency.iso_code }}</span>
            </div>

            <div class="cm-taxes-note">
              Taxes, Discounts and shipping calculated at checkout
            </div>

            <button type="submit" name="checkout" class="cm-checkout-btn">
              Check out
            </button>

            {%- if additional_checkout_buttons -%}
              <div class="cm-additional-checkout-buttons">
                {{ content_for_additional_checkout_buttons }}
              </div>
            {%- endif -%}

            <div class="cm-terms-notice">
              By continuing, I agree to the <a href="#">terms & conditions</a> and authorize charging my payment method.
            </div>
          </div>

        </div>

      </form>

    {%- else -%}
      <!-- Empty Cart State -->
      <div class="cm-cart-empty-wrapper">
        <h1 class="cm-empty-title">YOUR CART IS EMPTY</h1>
        <a href="{{ routes.all_products_collection_url }}" class="cm-empty-btn">Continue shopping</a>
      </div>
    {%- endif -%}

  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const container = document.querySelector('.custom-main-cart-{{ section.id }}');
  if (!container) return;

  function updateCartItem(key, qty) {
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ id: key, quantity: qty })
    })
    .then(r => r.json())
    .then(() => {
      window.location.reload();
    })
    .catch(() => {
      window.location.reload();
    });
  }

  container.addEventListener('click', function (e) {
    const btn = e.target.closest('.cm-qty-btn, .cm-item-remove-btn');
    if (!btn) return;

    const key = btn.getAttribute('data-key');
    const action = btn.getAttribute('data-action');
    const curQty = parseInt(btn.getAttribute('data-qty'), 10) || 0;

    if (action === 'remove') {
      updateCartItem(key, 0);
    } else if (action === 'increase') {
      updateCartItem(key, curQty + 1);
    } else if (action === 'decrease') {
      updateCartItem(key, Math.max(0, curQty - 1));
    }
  });

  const noteTextarea = container.querySelector('.cm-instructions-textarea');
  if (noteTextarea) {
    noteTextarea.addEventListener('change', function () {
      fetch('/cart/update.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ note: noteTextarea.value })
      });
    });
  }
});
</script>

{% schema %}
{
  "name": "Custom Cart Page",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_urgency_notice",
      "label": "Show Urgency Notice Bar",
      "default": true
    },
    {
      "type": "text",
      "id": "urgency_count",
      "label": "Urgency People Count",
      "default": "6"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Checkout Button Background",
      "default": "#fe9d01"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Custom Cart Page"
    }
  ]
}
{% endschema %}
