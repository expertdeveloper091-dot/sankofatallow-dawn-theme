<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

{%- assign step_count = 0 -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'step' -%}
    {%- assign step_count = step_count | plus: 1 -%}
  {%- endif -%}
{%- endfor -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ========================
     SECTION ROOT
  ======================== */
  .hiw-{{ section.id }},
  .hiw-{{ section.id }} * {
    box-sizing: border-box;
  }
  .hiw-{{ section.id }} {
    width: 100%;
    font-family: 'Poppins', sans-serif;
    background-color: {{ section.settings.bg_color }};
    border-bottom:2px solid;
  }

  /* ========================
     OUTER WRAP — heading + steps
  ======================== */
  .hiw-{{ section.id }} .hiw__outer {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 4rem;
  }

  /* ========================
     HEADING — left aligned
  ======================== */
  .hiw-{{ section.id }} .hiw__heading {
    margin-bottom: 3.2rem;
  }
  .hiw-{{ section.id }} .hiw__title {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(2.8rem, 4vw, 5rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    line-height: 1.05;
    color: {{ section.settings.text_color }};
    margin: 0;
  }

  /* ========================
     STEPS GRID
     grid: item | arrow | item | arrow | item
  ======================== */
  .hiw-{{ section.id }} .hiw__row {
    display: grid;
    grid-template-columns: minmax(0,1fr) {% for i in (2..step_count) %} 30px minmax(0,1fr){% endfor %};
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  /* ========================
     STEP ITEM
     border-left = the side accent line
  ======================== */
  .hiw-{{ section.id }} .hiw__item {
    position: relative;
    padding-left: 16px;
    border-left: 2px solid {{ section.settings.accent_color }};
    display: flex;
    flex-direction: column;
  }

  /* ========================
     STEP TAG — extends outside the border-left
     margin-left: -16px pulls it to the left of the border
  ======================== */
  .hiw-{{ section.id }} .hiw__tag {
    position: relative;
    width: fit-content;
    height: 40px;
    margin-left: -16px;
    margin-bottom: 13px;
    padding: 0 15px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background-color: {{ section.settings.accent_color }};
    color: {{ section.settings.tag_text_color }};
    font-size: 1.2rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: 1;
    border-radius: 0;
  }
  .hiw-{{ section.id }} .hiw__tag i {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: {{ section.settings.tag_text_color }};
    font-size: 1.2rem;
    font-weight: 900;
    margin: 0;
    padding: 0;
  }
  .hiw-{{ section.id }} .hiw__tag span {
    color: {{ section.settings.tag_text_color }};
    font-size: 1.2rem;
    font-weight: 900;
    line-height: normal;
    display: inline-block;
  }

  /* ========================
     CARD — dashed border, cream bg
  ======================== */
  .hiw-{{ section.id }} .hiw__card {
    min-height: 500px;
    padding: 22px 14px 22px;
    border: 1.3px dashed {{ section.settings.card_border }};
    background: {{ section.settings.card_bg }};
    text-align: center;
    display: flex;
    flex-direction: column;
  }

  .hiw-{{ section.id }} .hiw__card h3 {
    margin: 0 auto 13px;
    max-width: 285px;
    color: {{ section.settings.text_color }};
    font-size: 1.7rem;
    line-height: 1.18;
    font-weight: 900;
    letter-spacing: 0;
    font-family: 'Poppins', sans-serif;
  }

  .hiw-{{ section.id }} .hiw__card p {
    margin: 0 auto 38px;
    max-width: 270px;
    color: {{ section.settings.text_color }};
    font-size: 1.2rem;
    line-height: 1.35;
    font-weight: 500;
    font-family: 'Poppins', sans-serif;
  }

  .hiw-{{ section.id }} .hiw__card img {
    width: 100%;
    height: 297px;
    display: block;
    object-fit: cover;
    margin-top: auto;
  }

  /* ========================
     ARROW — icon between steps
  ======================== */
  .hiw-{{ section.id }} .hiw__arrow {
    width: 30px;
    height: 30px;
    margin-top: 288px; /* visually center with the 500px card */
    display: flex;
    align-items: center;
    justify-content: center;
    align-self: flex-start;
  }
  .hiw-{{ section.id }} .hiw__arrow-svg {
    display: block;
    width: 28px;
    height: 28px;
  }

  /* ========================
     RESPONSIVE — Laptop
  ======================== */
  @media screen and (max-width: 1190px) {
    .hiw-{{ section.id }} .hiw__outer { padding: 0 2rem; }
    .hiw-{{ section.id }} .hiw__row {
      grid-template-columns: minmax(0,1fr) 28px minmax(0,1fr) 28px minmax(0,1fr);
      gap: 12px;
    }
    .hiw-{{ section.id }} .hiw__card img { height: 260px; }
  }

  /* ========================
     RESPONSIVE — Tablet
  ======================== */
  @media screen and (max-width: 900px) {
    .hiw-{{ section.id }} .hiw__outer { padding: 0 1.5rem; }
    .hiw-{{ section.id }} .hiw__row {
      grid-template-columns: 1fr;
      max-width: 620px;
      margin: 0 auto;
      gap: 18px;
    }
    .hiw-{{ section.id }} .hiw__card { min-height: auto; }
    .hiw-{{ section.id }} .hiw__card h3 {
      max-width: 100%;
      font-size: 1.8rem;
    }
    .hiw-{{ section.id }} .hiw__card p {
      max-width: 480px;
      margin-bottom: 25px;
      font-size: 1.2rem;
      line-height: 1.45;
    }
    .hiw-{{ section.id }} .hiw__card img { height: 300px; }
    .hiw-{{ section.id }} .hiw__arrow {
      width: 100%;
      height: 26px;
      margin: -3px 0;
      padding-left: 16px;
    }
    .hiw-{{ section.id }} .hiw__arrow-svg {
      transform: rotate(90deg);
      width: 28px;
      height: 28px;
    }
  }

  /* ========================
     RESPONSIVE — Mobile
  ======================== */
  @media screen and (max-width: 600px) {
    .hiw-{{ section.id }} .hiw__row { max-width: 100%; gap: 16px; }
    .hiw-{{ section.id }} .hiw__tag { height: 34px; padding: 0 13px; }
    .hiw-{{ section.id }} .hiw__card { padding: 18px 12px 16px; }
    .hiw-{{ section.id }} .hiw__card h3 { font-size: 1.6rem; line-height: 1.25; }
    .hiw-{{ section.id }} .hiw__card p {
      max-width: 100%;
      margin-bottom: 20px;
      font-size: 1.1rem;
    }
    .hiw-{{ section.id }} .hiw__card img { height: 230px; }
  }

  @media screen and (max-width: 420px) {
    .hiw-{{ section.id }} .hiw__item { padding-left: 9px; }
    .hiw-{{ section.id }} .hiw__tag { margin-left: -9px; height: 32px; padding: 0 11px; }
    .hiw-{{ section.id }} .hiw__card h3 { font-size: 1.5rem; }
    .hiw-{{ section.id }} .hiw__card p { font-size: 1.05rem; }
    .hiw-{{ section.id }} .hiw__card img { height: 200px; }
  }
{%- endstyle -%}

<div class="hiw-{{ section.id }} section-{{ section.id }}-padding">
  <div class="hiw__outer">

    <!-- HEADING -->
    <div class="hiw__heading">
      <h2 class="hiw__title">{{ section.settings.heading }}</h2>
    </div>

    <!-- STEPS GRID -->
    <div class="hiw__row">
      {%- assign current_step_index = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'step' -%}
          {%- assign current_step_index = current_step_index | plus: 1 -%}
          {%- if current_step_index > 1 -%}
            <!-- ARROW -->
            <div class="hiw__arrow">
              <svg width="32" height="33" viewBox="0 0 32 33" fill="none" xmlns="http://www.w3.org/2000/svg" class="hiw__arrow-svg">
                <path d="M30.8569 16.5L15.9997 31.3571V22.7857H1.14258V10.2143H15.9997V1.64285L30.8569 16.5Z" fill="{{ section.settings.accent_color }}"/>
                <path d="M30.8569 16.5L15.9997 31.3571V22.7857H1.14258V10.2143H15.9997V1.64285L30.8569 16.5Z" stroke="{{ section.settings.text_color }}" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          {%- endif -%}

          <!-- ======= STEP ======= -->
          <div class="hiw__item" {{ block.shopify_attributes }}>
            <div class="hiw__tag">
              <i class="fa-solid fa-check"></i>
              <span>STEP {{ current_step_index }}</span>
            </div>
            <div class="hiw__card">
              <h3>{{ block.settings.title }}</h3>
              {{ block.settings.description }}
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 700 | image_tag:
                  loading: 'lazy',
                  alt: block.settings.title
                }}
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div><!-- /hiw__row -->
  </div>
</div>

{% schema %}
{
  "name": "How It Works",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#FAF9F5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#2C2609"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent (border-left + tag + arrow)",
      "default": "#e7a621"
    },
    {
      "type": "color",
      "id": "tag_text_color",
      "label": "Tag text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#fffaf1"
    },
    {
      "type": "color",
      "id": "card_border",
      "label": "Card dashed border",
      "default": "#2C2609"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "How It Works"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Step Title"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Step Description</p>"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How It Works",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Carefully Selected Ingredients",
            "description": "<p>We source high-quality natural ingredients chosen for their nourishing properties.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Handcrafted in Small Batches",
            "description": "<p>Every jar is carefully blended in small batches to maintain quality and consistency.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Daily Skin Nourishment",
            "description": "<p>Massage onto clean skin for long-lasting hydration and healthy-looking skin.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
