      "default": "#2c2609"
    },
    {
      "type": "color",
      "id": "button_shadow_color",
      "label": "Button Shadow Color",
      "default": "#2c2609"
    },
    {
      "type": "header",
      "content": "Spacing Settings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
