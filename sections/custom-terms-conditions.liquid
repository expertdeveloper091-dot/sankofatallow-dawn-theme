<!-- sections/custom-terms-conditions.liquid -->
{%- style -%}
  .custom-policy-page-{{ section.id }} {
    background-color: {{ section.settings.bg_color | default: '#FAF7EF' }};
    padding-top: {{ section.settings.padding_top | default: 50 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 70 }}px;
    font-family: 'Poppins', sans-serif;
    color: #111111;
  }

  .cp-container {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 20px;
    box-sizing: border-box;
  }

  .cp-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .cp-tag {
    display: inline-block;
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #e63946;
    margin-bottom: 8px;
  }

  .cp-title {
    font-size: clamp(30px, 4vw, 44px);
    font-weight: 900;
    text-transform: uppercase;
    color: #111111;
    margin: 0 0 12px 0;
    line-height: 1.1;
  }

  .cp-subtitle {
    font-size: 15px;
    color: #555555;
    margin: 0;
  }

  /* Main Body Card */
  .cp-body-card {
    background: #ffffff;
    border: 2px solid #111111;
    border-radius: 16px;
    padding: 40px;
    box-shadow: 0 6px 0 0 #111111;
    box-sizing: border-box;
  }

  .cp-section-block {
    margin-bottom: 32px;
  }

  .cp-section-block:last-child {
    margin-bottom: 0;
  }

  .cp-block-heading {
    font-size: 19px;
    font-weight: 800;
    text-transform: uppercase;
    color: #111111;
    margin: 0 0 14px 0;
  }

  .cp-block-text {
    font-size: 14.5px;
    line-height: 1.7;
    color: #444444;
  }

  .cp-block-text p {
    margin: 0 0 1em 0;
  }
  .cp-block-text p:last-child {
    margin: 0;
  }

  .cp-block-text ul {
    margin: 12px 0 16px 20px;
    padding: 0;
  }

  .cp-block-text li {
    font-size: 14px;
    line-height: 1.7;
    color: #444444;
    margin-bottom: 6px;
  }

  @media (max-width: 768px) {
    .cp-body-card {
      padding: 24px;
    }
  }
{%- endstyle -%}

<div class="custom-policy-page-{{ section.id }}">
  <div class="cp-container">
    
    <div class="cp-header">
      {%- if section.settings.tag_text != blank -%}
        <span class="cp-tag">{{ section.settings.tag_text }}</span>
      {%- endif -%}
      
      {%- if section.settings.title != blank -%}
        <h1 class="cp-title">{{ section.settings.title }}</h1>
      {%- endif -%}
      
      {%- if section.settings.subtitle != blank -%}
        <p class="cp-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <!-- Main Content Card -->
    <div class="cp-body-card">
      {%- assign policy_blocks = section.blocks | where: "type", "policy_section" -%}
      {%- if policy_blocks.size > 0 -%}
        {%- for block in policy_blocks -%}
          <div class="cp-section-block" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h2 class="cp-block-heading">{{ block.settings.heading }}</h2>
            {%- endif -%}
            
            {%- if block.settings.content != blank -%}
              <div class="cp-block-text">
                {{ block.settings.content }}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="cp-section-block">
          <h2 class="cp-block-heading">Terms & Conditions Details</h2>
          <div class="cp-block-text">
            <p>Please add policy section blocks in Theme Customizer.</p>
          </div>
        </div>
      {%- endif -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Terms & Conditions Page",
  "settings": [
    {
      "type": "text",
      "id": "tag_text",
      "label": "Sub-tag Text",
      "default": "Sankofa Tallow"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Main Title",
      "default": "Terms & Conditions"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Rules and guidelines governing the use of our store and purchase of our skincare products."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FAF7EF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Top",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 70
    }
  ],
  "blocks": [
    {
      "type": "policy_section",
      "name": "Policy Section Block",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Section Heading",
          "default": "1. Overview"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Section Content",
          "default": "<p>Content goes here.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Terms & Conditions Page"
    }
  ]
}
{% endschema %}
