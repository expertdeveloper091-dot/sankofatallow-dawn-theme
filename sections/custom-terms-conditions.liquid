<!-- sections/custom-terms-conditions.liquid -->
{{ 'https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css' | stylesheet_tag }}

{%- style -%}
  .custom-policy-page-{{ section.id }} {
    background-color: {{ section.settings.bg_color | default: '#FAF7EF' }};
    padding-top: {{ section.settings.padding_top | default: 50 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 70 }}px;
    font-family: 'Poppins', sans-serif;
    color: #111111;
  }

  .cp-container {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 20px;
    box-sizing: border-box;
  }

  .cp-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .cp-tag {
    display: inline-block;
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #e63946;
    margin-bottom: 8px;
  }

  .cp-title {
    font-size: clamp(30px, 4vw, 44px);
    font-weight: 900;
    text-transform: uppercase;
    color: #111111;
    margin: 0 0 12px 0;
    line-height: 1.1;
  }

  .cp-subtitle {
    font-size: 15px;
    color: #555555;
    margin: 0;
  }

  /* Main Body Card */
  .cp-body-card {
    background: #ffffff;
    border: 2px solid #111111;
    border-radius: 16px;
    padding: 40px;
    box-shadow: 0 6px 0 0 #111111;
    box-sizing: border-box;
  }

  .cp-section-block {
    margin-bottom: 32px;
  }

  .cp-section-block:last-child {
    margin-bottom: 0;
  }

  .cp-block-heading {
    font-size: 19px;
    font-weight: 800;
    text-transform: uppercase;
    color: #111111;
    margin: 0 0 14px 0;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .cp-block-heading i {
    color: #fe9d01;
  }

  .cp-block-text {
    font-size: 14.5px;
    line-height: 1.7;
    color: #444444;
  }

  .cp-block-text p {
    margin: 0 0 1em 0;
  }
  .cp-block-text p:last-child {
    margin: 0;
  }

  .cp-block-list {
    margin: 12px 0 16px 20px;
    padding: 0;
  }

  .cp-block-list li {
    font-size: 14px;
    line-height: 1.7;
    color: #444444;
    margin-bottom: 6px;
  }

  @media (max-width: 768px) {
    .cp-body-card {
      padding: 24px;
    }
  }
{%- endstyle -%}

<div class="custom-policy-page-{{ section.id }}">
  <div class="cp-container">
    
    <div class="cp-header">
      <span class="cp-tag">House of Sankofa</span>
      <h1 class="cp-title">Terms & Conditions</h1>
      <p class="cp-subtitle">Rules and guidelines governing the use of our store and purchase of our skincare products.</p>
    </div>

    <!-- Main Content Card -->
    <div class="cp-body-card">
      
      <div class="cp-section-block">
        <h2 class="cp-block-heading"><i class="fa-solid fa-file-contract"></i> 1. Overview</h2>
        <div class="cp-block-text">
          <p>This website is operated by <strong>House of Sankofa</strong>. Throughout the site, the terms "we", "us" and "our" refer to House of Sankofa. House of Sankofa offers this website, including all information, tools and services available from this site to you, the user, conditioned upon your acceptance of all terms, conditions, policies and notices stated here.</p>
          <p>By visiting our site and/or purchasing something from us, you engage in our "Service" and agree to be bound by the following Terms & Conditions.</p>
        </div>
      </div>

      <div class="cp-section-block">
        <h2 class="cp-block-heading"><i class="fa-solid fa-store"></i> 2. Online Store Terms</h2>
        <div class="cp-block-text">
          <p>By agreeing to these Terms & Conditions, you represent that you are at least the age of majority in your state or province of residence. You may not use our products for any illegal or unauthorized purpose nor may you, in the use of the Service, violate any laws in your jurisdiction.</p>
        </div>
      </div>

      <div class="cp-section-block">
        <h2 class="cp-block-heading"><i class="fa-solid fa-jar"></i> 3. Skincare Product Information</h2>
        <div class="cp-block-text">
          <p>All <strong>House of Sankofa</strong> products are handcrafted using 100% natural, grass-fed tallow and organic botanicals. Because our products are made from natural raw ingredients, natural variations in scent, color, and texture may occur between batches.</p>
          <p>Our skincare products are for external cosmetic use only. If irritation occurs, discontinue use immediately and consult a physician.</p>
        </div>
      </div>

      <div class="cp-section-block">
        <h2 class="cp-block-heading"><i class="fa-solid fa-credit-card"></i> 4. Modifications to Prices and Services</h2>
        <div class="cp-block-text">
          <p>Prices for our products are subject to change without notice. We reserve the right at any time to modify or discontinue the Service (or any part or content thereof) without notice at any time.</p>
          <p>We reserve the right to refuse any order you place with us. We may, in our sole discretion, limit or cancel quantities purchased per person, per household or per order.</p>
        </div>
      </div>

      <div class="cp-section-block">
        <h2 class="cp-block-heading"><i class="fa-solid fa-copyright"></i> 5. Intellectual Property</h2>
        <div class="cp-block-text">
          <p>All content included on this site, such as text, graphics, logos, images, digital downloads, and product designs, is the property of House of Sankofa and protected by international copyright and trademark laws.</p>
        </div>
      </div>

      <div class="cp-section-block">
        <h2 class="cp-block-heading"><i class="fa-solid fa-gavel"></i> 6. Governing Law & Contact</h2>
        <div class="cp-block-text">
          <p>These Terms & Conditions and any separate agreements shall be governed by and construed in accordance with applicable laws.</p>
          <p>Questions about the Terms & Conditions should be sent to us at <strong>legal@houseofsankofa.com</strong>.</p>
        </div>
      </div>

    </div>

  </div>
</div>

{% schema %}
{
  "name": "Terms & Conditions Page",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FAF7EF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Top",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 70
    }
  ],
  "presets": [
    {
      "name": "Terms & Conditions Page"
    }
  ]
}
{% endschema %}
