          "type": "faq_item",
          "settings": {
            "category_id": "product-ingredients",
            "question": "What ingredients are in your Tallow Balm?",
            "answer": "<p><br/>Our Tallow Balm is made with just five carefully selected, non-toxic ingredients that deeply nourish and protect your skin. Every ingredient is chosen for its purpose—nothing unnecessary, just clean and effective skincare.<br/><br/></p>"
          }
        },
        "faq_item_mXAzmT": {
          "type": "faq_item",
          "settings": {
            "category_id": "product-ingredients",
            "question": "Is your tallow grass-fed and grass-finished?",
            "answer": "<p>Yes. We source premium-quality grass-fed, grass-finished beef tallow from trusted farms to ensure maximum purity and skin-loving nutrients.<br/><br/></p>"
          }
        },
