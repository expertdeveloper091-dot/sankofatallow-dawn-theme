{
  "sections": {
    "main": {
      "type": "rb-main-product",
      "settings": {
        "show_vendor": true,
        "show_save_badge": true,
        "show_sold_count": true,
        "sold_count": 15,
        "sold_text": "sold in last 15 hours"
      },
      "blocks": {
        "delivery_box": {
          "type": "delivery_box",
          "settings": {
            "show_row1": true,
            "row1_text": "<p><strong>Estimate delivery times:</strong> <strong>3-5 days International.</strong></p>",
            "show_row2": true,
            "row2_text": "<p>Use code <strong>\"WELCOME15\"</strong> for discount 15% on your first order.</p>",
            "show_row3": true,
            "row3_text": "<p><strong>Free shipping & returns:</strong> On all orders over $150.</p>"
          }
        },
        "live_visitors": {
          "type": "live_visitors",
          "settings": {
            "min_count": 14,
            "max_count": 35,
            "suffix_text": "peoples are viewing this right now"
          }
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {}
        },
        "ask_question": {
          "type": "ask_question",
          "settings": {
            "link_text": "Ask a question",
            "contact_type": "whatsapp",
            "contact_value": ""
          }
        },
        "stock_countdown": {
          "type": "stock_countdown",
          "settings": {
            "use_real_inventory": true,
            "low_stock_threshold": 10,
            "prefix_text": "Hurry up! Only",
            "display_qty": 1,
            "suffix_text": "items left in stock",
            "bar_percent": 8,
            "sold_out_text": "This product is currently sold out"
          }
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "atc_text": "Add to Cart",
            "sold_out_text": "Sold Out",
            "show_buy_now": true,
            "buy_now_text": "Buy it now",
            "show_wishlist": true,
            "show_compare": true
          }
        },
        "accordion_desc": {
          "type": "accordion",
          "settings": {
            "heading": "Description",
            "content_source": "description"
          }
        },
        "accordion_shipping": {
          "type": "accordion",
          "settings": {
            "heading": "Shipping and Returns",
            "content_source": "custom",
            "content": "<p>Orders dispatched within 1–2 business days. Free shipping over $150.</p>"
          }
        },
        "product_meta": {
          "type": "product_meta",
          "settings": {
            "show_sku": true,
            "sku_label": "Sku",
            "show_availability": true,
            "avail_label": "Available",
            "in_stock_label": "Instock",
            "out_of_stock_label": "Out of Stock",
            "show_collections": true,
            "collections_label": "Collections",
            "show_type": true,
            "type_label": "Type"
          }
        },
        "trust_badge": {
          "type": "trust_badge",
          "settings": {
            "badge_text": "Guaranteed Safe Checkout"
          }
        },
        "fake_orders": {
          "type": "fake_orders",
          "settings": {
            "enable": true,
            "show_delay": 3,
            "cycle_interval": 10
          }
        }
      },
      "block_order": [
        "delivery_box",
        "live_visitors",
        "variant_picker",
        "ask_question",
        "stock_countdown",
        "buy_buttons",
        "accordion_desc",
        "accordion_shipping",
        "product_meta",
        "trust_badge",
        "fake_orders"
      ]
    },
    "related-products": {
      "type": "rb-product-recommendations",
      "settings": {
        "heading": "You May Also Like"
      }
    },
    "recently-viewed": {
      "type": "rb-recently-viewed",
      "settings": {
        "heading": "Recently Viewed Products"
      }
    }
  },
  "order": [
    "main",
    "related-products",
    "recently-viewed"
  ]
}
