{
  "sections": {
    "main": {
      "type": "rb-main-product",
      "settings": {
        "section_width": "default",
        "enable_sticky_content": true,
        "enable_skeleton_loading": false,
        "desktop_media_width": 50,
        "desktop_layout": "thumbnail_left",
        "image_zoom": "lightbox",
        "enable_video_looping": false,
        "enable_video_autoplay": true,
        "enable_sticky_atc": true,
        "enable_fbt": true,
        "show_vendor": true,
        "show_save_badge": true,
        "show_sold_count": true,
        "sold_count": 15,
        "sold_text": "sold in last 15 hours"
      },
      "blocks": {
        "product_badges": {
          "type": "product_badges",
          "settings": {}
        },
        "product_title": {
          "type": "product_title",
          "settings": {}
        },
        "review_and_sold": {
          "type": "review_and_sold",
          "settings": {}
        },
        "price": {
          "type": "price",
          "settings": {}
        },
        "short_description": {
          "type": "short_description",
          "settings": {}
        },
        "delivery_return": {
          "type": "delivery_return",
          "settings": {
            "show_row1": true,
            "row1_text": "<p><strong>Estimate delivery times:</strong> <strong>3-5 days International.</strong></p>",
            "show_row2": true,
            "row2_text": "<p>Use code <strong>\"WELCOME15\"</strong> for discount 15% on your first order.</p>",
            "show_row3": true,
            "row3_text": "<p><strong>Free shipping & returns:</strong> On all orders over $150.</p>"
          }
        },
        "live_view": {
          "type": "live_view",
          "settings": {
            "min_count": 14,
            "max_count": 35,
            "suffix_text": "peoples are viewing this right now"
          }
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {}
        },
        "stock_countdown": {
          "type": "stock_countdown",
          "settings": {
            "use_real_inventory": true,
            "low_stock_threshold": 10,
            "prefix_text": "Hurry up! Only",
            "display_qty": 1,
            "suffix_text": "items left in stock",
            "bar_percent": 8
          }
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "atc_text": "Add to Cart",
            "sold_out_text": "Sold Out",
            "show_buy_now": true,
            "buy_now_text": "Buy it now",
            "show_wishlist": true,
            "show_compare": true
          }
        },
        "collapsible_desc": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Collapsible row – Description",
            "content_source": "description"
          }
        },
        "collapsible_shipping": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Collapsible row – Shipping and...",
            "content_source": "custom",
            "content": "<p>Orders dispatched within 1–2 business days. Free shipping over $150.</p>"
          }
        },
        "collapsible_returns": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Collapsible row – Return Policies",
            "content_source": "custom",
            "content": "<p>Returns accepted within 7 days of delivery.</p>"
          }
        },
        "product_meta": {
          "type": "product_meta",
          "settings": {
            "show_sku": true,
            "show_availability": true,
            "show_collections": true,
            "show_type": true
          }
        },
        "trust_badge": {
          "type": "trust_badge",
          "settings": {
            "badge_text": "Guaranteed Safe Checkout"
          }
        }
      },
      "block_order": [
        "product_badges",
        "product_title",
        "review_and_sold",
        "price",
        "short_description",
        "delivery_return",
        "live_view",
        "variant_picker",
        "stock_countdown",
        "buy_buttons",
        "collapsible_desc",
        "collapsible_shipping",
        "collapsible_returns",
        "product_meta",
        "trust_badge"
      ]
    },
    "related-products": {
      "type": "rb-product-recommendations",
      "settings": {
        "heading": "You May Also Like"
      }
    },
    "recently-viewed": {
      "type": "rb-recently-viewed",
      "settings": {
        "heading": "Recently Viewed Products"
      }
    }
  },
  "order": [
    "main",
    "related-products",
    "recently-viewed"
  ]
}
