{% comment %}
  rb-sticky-atc.liquid
  Sticky Add to Cart bar — Clay theme style
  Each product option shown as a SEPARATE dropdown
{% endcomment %}

<div class="rb-sticky-bar" id="RBStickyBar" aria-label="Quick Add to Cart">
  <div class="rb-sticky-inner">

    {% comment %} Product Image + Title {% endcomment %}
    <div class="rb-sticky-product">
      <img class="rb-sticky-img"
        src="{{ product.featured_image | img_url: '80x80', crop: 'center' }}"
        alt="{{ product.title | escape }}"
        width="46"
        height="46">
      <span class="rb-sticky-title">{{ product.title }}</span>
    </div>

    {% comment %} Separate dropdown for EACH option {% endcomment %}
    {% unless product.has_only_default_variant %}
      {% for option in product.options_with_values %}
        <select
          class="rb-sticky-variant-select"
          id="RBStickyOption{{ option.position }}"
          data-option-position="{{ option.position }}"
          aria-label="{{ option.name }}">
          {% for value in option.values %}
            <option value="{{ value }}" {% if option.selected_value == value %}selected{% endif %}>
              {{ option.name }}: {{ value }}
            </option>
          {% endfor %}
        </select>
      {% endfor %}
    {% else %}
      <span class="rb-sticky-price">{{ product.selected_or_first_available_variant.price | money }}</span>
    {% endunless %}

    {% comment %} Hidden price shown after options {% endcomment %}
    {% unless product.has_only_default_variant %}
      <span class="rb-sticky-price" id="RBStickyPrice">{{ product.selected_or_first_available_variant.price | money }}</span>
    {% endunless %}

    {% comment %} Qty Stepper {% endcomment %}
    <div class="rb-sticky-qty">
      <button type="button" class="rb-sticky-qty-btn" id="RBStickyQtyMinus">−</button>
      <input type="number" class="rb-sticky-qty-input" id="RBStickyQtyInput" value="1" min="1" aria-label="Quantity">
      <button type="button" class="rb-sticky-qty-btn" id="RBStickyQtyPlus">+</button>
    </div>

    {% comment %} Add to Cart {% endcomment %}
    <button type="button" class="rb-sticky-atc" id="RBStickyAtcBtn">
      Add to Cart
    </button>

  </div>
</div>
