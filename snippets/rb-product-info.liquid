{% comment %}
  rb-product-info.liquid
  Clay Theme Design — Exact Visual Replication
  Namespace: .rb-product-info
{% endcomment %}
<div class="rb-product-info">

  <!-- Save Badge Row -->
  {% if product.compare_at_price_max > product.price %}
    {% assign save_pct = product.compare_at_price_max | minus: product.price | times: 100 | divided_by: product.compare_at_price_max %}
    <div class="rb-badges-row">
      <span class="rb-badge-save">-{{ save_pct }}%</span>
    </div>
  {% endif %}

  <!-- Vendor -->
  {% if product.vendor != blank %}
    <div class="rb-product-vendor">{{ product.vendor }}</div>
  {% endif %}

  <!-- Product Title -->
  <h1 class="rb-product-title">{{ product.title }}</h1>

  <!-- Rating + Sold Row -->
  <div class="rb-rating-row">
    <span class="rb-stars">★★★★★</span>
    <span class="rb-rating-count">9 reviews</span>
    <span class="rb-sold-badge">
      🔥 12 sold in last 20 hours
    </span>
  </div>

  <!-- Price Row -->
  <div class="rb-product-price-box">
    <span class="rb-price-current">{{ product.selected_or_first_available_variant.price | money }}</span>
    {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
      <span class="rb-price-compare">{{ product.selected_or_first_available_variant.compare_at_price | money }}</span>
    {% endif %}
  </div>

  <!-- Delivery Box -->
  <div class="rb-delivery-box">
    <div class="rb-delivery-item">
      <div class="rb-delivery-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
      </div>
      <div class="rb-delivery-text">
        <strong>Estimate delivery time:</strong> Delivery within <strong>3–7 working days.</strong> You'll be updated along the way.
      </div>
    </div>
    <div class="rb-delivery-item">
      <div class="rb-delivery-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      </div>
      <div class="rb-delivery-text">
        <strong>Cash on Delivery (COD) only.</strong> Please <strong>check your parcel before payment.</strong>
      </div>
    </div>
    <div class="rb-delivery-item">
      <div class="rb-delivery-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
      </div>
      <div class="rb-delivery-text">
        <strong>Shipping charges:</strong> Flat <strong>Rs.199</strong> on all orders — <strong>FREE shipping above Rs.10,000.</strong>
      </div>
    </div>
  </div>

  <!-- Live Visitors Bar -->
  <div class="rb-live-view">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
    <span id="RBLiveCounter">10</span> peoples are viewing this right now
  </div>

  <!-- Ask Question + Share Row -->
  <div class="rb-addons-row">
    <button type="button" class="rb-addon-link" id="RBAskBtn">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      Ask a question
    </button>
    <button type="button" class="rb-addon-link" onclick="navigator.clipboard.writeText(window.location.href); alert('Link copied!');">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
      Share
    </button>
  </div>

  <!-- Variant Picker Placeholder (Reuse existing Sankofa theme variant picker) -->
  {% unless product.has_only_default_variant %}
    <div class="rb-variant-picker">
      {% for option in product.options_with_values %}
        <div class="rb-option-group">
          <label class="rb-option-label">{{ option.name }}: <strong>{{ option.selected_value }}</strong></label>
          <div class="rb-option-pills">
            {% for value in option.values %}
              <button type="button" class="rb-pill-btn {% if option.selected_value == value %}rb-active{% endif %}">{{ value }}</button>
            {% endfor %}
          </div>
        </div>
      {% endfor %}
    </div>
  {% endunless %}

  <!-- Buy Buttons -->
  {% render 'rb-buy-buttons', product: product %}

  <!-- Product Meta Table -->
  {% render 'rb-product-meta', product: product %}

  <!-- Trust Badge -->
  {% render 'rb-trust-badge' %}

  <!-- Accordions -->
  {% render 'rb-product-accordion', product: product %}

</div>
