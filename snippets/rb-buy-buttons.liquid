{% comment %}
  rb-buy-buttons.liquid
  Clay Theme Design — ATC + Buy Now + Icon Buttons
{% endcomment %}

<div class="rb-buy-buttons">
  {% form 'product', product, class: 'rb-product-form', id: 'rb-product-form' %}
    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

    <!-- ATC Row: Qty + Add to Cart + Icons -->
    <div class="rb-atc-row">
      <!-- Quantity -->
      <div class="rb-qty-pill">
        <button type="button" class="rb-qty-btn" id="RBQtyMinus">−</button>
        <input class="rb-qty-input" type="number" name="quantity" value="1" min="1" id="RBQtyInput" />
        <button type="button" class="rb-qty-btn" id="RBQtyPlus">+</button>
      </div>

      <!-- Add to Cart -->
      <button type="submit" class="rb-atc-button" id="RBAtcButton">
        {%- if product.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
      </button>

      <!-- Wishlist Icon -->
      <button type="button" class="rb-icon-btn" title="Add to Wishlist">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </button>

      <!-- Compare Icon -->
      <button type="button" class="rb-icon-btn" title="Compare">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
      </button>
    </div>

    <!-- Buy Now Button -->
    <button type="button" class="rb-buy-now-button" id="RBBuyNow">Buy it now</button>

  {% endform %}
</div>
