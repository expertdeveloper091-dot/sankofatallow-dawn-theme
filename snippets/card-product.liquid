{% comment %}
  Renders a luxury product card for collection, search, related products, recommendations.
  Supports OS 2.0 dynamic settings, Fragrance as a custom dropdown, Size as pill buttons, variant switching & AJAX Add-to-Cart with Cart Drawer.
{% endcomment %}
{%- unless skip_styles -%}
  {{ 'component-card.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

{%- if card_product and card_product != empty -%}
  {%- liquid
    assign selected_variant = card_product.selected_or_first_available_variant
    assign product_form_id = 'quick-add-' | append: section_id | append: card_product.id
    
    assign short_desc = card_product.metafields.custom.short_description | default: card_product.metafields.descriptors.subtitle
    if short_desc == blank
      assign short_desc = card_product.description | strip_html | truncatewords: 22
    endif

    assign rating_val = card_product.metafields.reviews.rating.value.rating | default: card_product.metafields.reviews.rating.value | default: card_product.metafields.loox.avg_rating | default: card_product.metafields.judgeme.badge
    assign rating_count = card_product.metafields.reviews.rating_count | default: card_product.metafields.loox.num_reviews
  -%}

  <product-component class="ml-product-component-wrap" view-event-payload="{{ card_product | standard_event_data: 'view', context: product_view_context | escape }}">
    <article class="ml-product-card" itemscope itemtype="http://schema.org/Product">
      
      <div class="ml-product-card__main">
        <!-- IMAGE CONTAINER -->
        <div class="ml-product-card__media-wrap">
          {%- if card_product.featured_media -%}
            <a href="{{ card_product.url }}" class="ml-product-card__media-link" aria-label="{{ card_product.title | escape }}">
              <img
                src="{{ card_product.featured_media | image_url: width: 600 }}"
                alt="{{ card_product.featured_media.alt | default: card_product.title | escape }}"
                loading="lazy"
                width="600"
                height="600"
                class="ml-product-card__img ml-product-card__img--primary"
              >
            </a>
          {%- else -%}
            <div class="ml-product-card__placeholder">
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}

          <!-- DYNAMIC BADGES -->
          <div class="ml-product-card__badges">
            {%- if card_product.available == false -%}
              <span class="ml-badge ml-badge--soldout">{{ 'products.product.sold_out' | t | default: 'Out of Stock' }}</span>
            {%- elsif card_product.compare_at_price > card_product.price -%}
              {%- assign savings = card_product.compare_at_price | minus: card_product.price | times: 100.0 | divided_by: card_product.compare_at_price | round -%}
              <span class="ml-badge ml-badge--sale">-{{ savings }}% OFF</span>
            {%- elsif card_product.tags contains 'bestseller' or card_product.tags contains 'Best Seller' -%}
              <span class="ml-badge ml-badge--bestseller">Best Seller</span>
            {%- elsif card_product.tags contains 'new' or card_product.tags contains 'New' -%}
              <span class="ml-badge ml-badge--new">New</span>
            {%- elsif card_product.tags contains 'hot' or card_product.tags contains 'Hot' -%}
              <span class="ml-badge ml-badge--hot">Hot</span>
            {%- endif -%}
          </div>
        </div>

        <!-- CONTENT CONTAINER -->
        <div class="ml-product-card__content">
          <!-- TITLE -->
          <h3 class="ml-product-card__title" itemprop="name">
            <a href="{{ card_product.url }}">{{ card_product.title }}</a>
          </h3>

          <!-- DESCRIPTION -->
          {%- if short_desc != blank -%}
            <div class="ml-product-card__description">
              <p>{{ short_desc }}</p>
            </div>
          {%- endif -%}

          <!-- REVIEWS (Conditional - strictly hide if ratings do not exist) -->
          {%- if rating_val != blank -%}
            <div class="ml-product-card__rating">
              <div class="ml-rating-stars">
                {%- for i in (1..5) -%}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="#E79F29">
                    <path d="M12 .587l3.668 7.431 8.2 1.192-5.934 5.787 1.4 8.168L12 18.896l-7.334 3.857 1.4-8.168L.132 9.21l8.2-1.192z"/>
                  </svg>
                {%- endfor -%}
                <span class="ml-rating-val">{{ rating_val }}</span>
                {%- if rating_count != blank -%}
                  <span class="ml-rating-cnt">({{ rating_count }})</span>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}

          <!-- DYNAMIC OPTION RENDERING: DROPDOWN FOR FRAGRANCE, PILLS FOR SIZE -->
          {%- if card_product.has_only_default_variant == false -%}
            <div class="ml-product-card__options-group">
              {%- for option in card_product.options_with_values -%}
                {%- assign opt_name_lower = option.name | downcase -%}
                {%- assign is_dropdown = false -%}
                {%- if opt_name_lower contains 'fragrance' or opt_name_lower contains 'scent' or opt_name_lower contains 'flavor' or option.values.size > 3 -%}
                  {%- assign is_dropdown = true -%}
                {%- endif -%}

                <div class="ml-option-row" data-option-position="option{{ option.position }}">
                  <span class="ml-variant-title">SELECT {{ option.name | uppercase }}</span>

                  {%- if is_dropdown -%}
                    <!-- FRAGRANCE / MULTI-OPTION DROPDOWN SELECT -->
                    <div class="ml-option-select-box">
                      <select
                        id="Option-{{ section_id }}-{{ card_product.id }}-{{ option.position }}"
                        class="ml-card-option-select"
                        data-option-position="option{{ option.position }}"
                      >
                        {%- for value in option.values -%}
                          {%- assign is_opt_selected = false -%}
                          {%- assign pos_idx = option.position | minus: 1 -%}
                          {%- if selected_variant and selected_variant.options[pos_idx] == value -%}
                            {%- assign is_opt_selected = true -%}
                          {%- elsif selected_variant == blank and forloop.first -%}
                            {%- assign is_opt_selected = true -%}
                          {%- endif -%}

                          <option value="{{ value | escape }}" {% if is_opt_selected %}selected="selected"{% endif %}>
                            {{ value }}
                          </option>
                        {%- endfor -%}
                      </select>
                      <svg class="ml-option-select-caret" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <polyline points="6 9 12 15 18 9"></polyline>
                      </svg>
                    </div>
                  {%- else -%}
                    <!-- SIZE / PILL BUTTONS -->
                    <div class="ml-variant-pills-list">
                      {%- for value in option.values -%}
                        {%- assign is_opt_selected = false -%}
                        {%- assign pos_idx = option.position | minus: 1 -%}
                        {%- if selected_variant and selected_variant.options[pos_idx] == value -%}
                          {%- assign is_opt_selected = true -%}
                        {%- elsif selected_variant == blank and forloop.first -%}
                          {%- assign is_opt_selected = true -%}
                        {%- endif -%}

                        <button
                          type="button"
                          class="ml-variant-pill-btn{% if is_opt_selected %} is-selected{% endif %}"
                          data-option-position="option{{ option.position }}"
                          data-value="{{ value | escape }}"
                        >
                          {{ value }}
                        </button>
                      {%- endfor -%}
                    </div>
                  {%- endif -%}
                </div>
              {%- endfor -%}
            </div>

            <!-- JSON MAP OF VARIANTS -->
            <script type="application/json" class="ml-variants-json">
              [
                {%- for variant in card_product.variants -%}
                  {
                    "id": {{ variant.id }},
                    "title": {{ variant.title | json }},
                    "option1": {{ variant.option1 | json }},
                    "option2": {{ variant.option2 | json }},
                    "option3": {{ variant.option3 | json }},
                    "price": {{ variant.price }},
                    "price_formatted": {{ variant.price | money | json }},
                    "compare_at_price": {{ variant.compare_at_price | default: 0 }},
                    "compare_at_price_formatted": {% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money | json }}{% else %}null{% endif %},
                    "available": {{ variant.available | json }},
                    "featured_image": {% if variant.featured_image %}{{ variant.featured_image.src | image_url: width: 600 | json }}{% else %}null{% endif %}
                  }{% unless forloop.last %},{% endunless %}
                {%- endfor -%}
              ]
            </script>
          {%- endif -%}

          <!-- PRICE CONTAINER -->
          <div class="ml-product-card__price-wrap">
            <span class="ml-card-price ml-card-price--current">{{ selected_variant.price | money }}</span>
            <span class="ml-card-price ml-card-price--old"{% unless selected_variant.compare_at_price > selected_variant.price %} style="display:none;"{% endunless %}>
              {%- if selected_variant.compare_at_price > selected_variant.price -%}
                {{ selected_variant.compare_at_price | money }}
              {%- endif -%}
            </span>
            {%- assign pct = 0 -%}
            {%- if selected_variant.compare_at_price > selected_variant.price -%}
              {%- assign pct = selected_variant.compare_at_price | minus: selected_variant.price | times: 100.0 | divided_by: selected_variant.compare_at_price | round -%}
            {%- endif -%}
            <span class="ml-card-price-badge"{% if pct == 0 %} style="display:none;"{% endif %}>-{{ pct }}%</span>
          </div>
        </div>
      </div>

      <!-- SPLIT FOOTER BUTTONS (LEARN MORE + ADD TO CART) -->
      <div class="ml-product-card__footer">
        <!-- LEARN MORE BUTTON -->
        <a href="{{ card_product.url }}" class="ml-card-btn ml-card-btn--learn">
          <span>Learn More</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>

        <!-- NATIVE PRODUCT FORM FOR AJAX ATC WITH SPINNER & CART DRAWER -->
        <product-form data-section-id="{{ section_id }}" class="ml-card-form-wrap">
          {%- form 'product',
            card_product,
            id: product_form_id,
            class: 'form ml-card-atc-form',
            novalidate: 'novalidate',
            data-type: 'add-to-cart-form'
          -%}
            <input
              type="hidden"
              name="id"
              value="{{ selected_variant.id }}"
              class="product-variant-id"
              {% if selected_variant.available == false %}disabled{% endif %}
            >
            <input type="hidden" name="quantity" value="1">

            <button
              id="{{ product_form_id }}-submit"
              type="submit"
              name="add"
              class="ml-card-btn ml-card-btn--atc"
              aria-haspopup="dialog"
              aria-labelledby="{{ product_form_id }}-submit"
              aria-live="polite"
              data-sold-out-message="true"
              {% if selected_variant.available == false %}disabled{% endif %}
            >
              <span class="ml-atc-text">
                {%- if selected_variant.available -%}
                  Add To Cart
                {%- else -%}
                  Out Of Stock
                {%- endif -%}
              </span>
              <svg class="ml-cart-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="9" cy="21" r="1"></circle>
                <circle cx="20" cy="21" r="1"></circle>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
              </svg>
              <div class="ml-btn-spinner" style="display:none;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="animation: spin 0.8s linear infinite;">
                  <circle cx="12" cy="12" r="10" stroke-opacity="0.25"></circle>
                  <path d="M12 2 a10 10 0 0 1 10 10" stroke-linecap="round"></path>
                </svg>
              </div>
            </button>
          {%- endform -%}
        </product-form>
      </div>
    </article>
  </product-component>
{%- else -%}
  <div class="ml-product-card ml-product-card--placeholder">
    <div class="ml-product-card__main">
      <div class="ml-product-card__media-wrap">
        {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
      <div class="ml-product-card__content">
        <h3 class="ml-product-card__title">Sample Product Title</h3>
        <div class="ml-product-card__price-wrap">
          <span class="ml-card-price ml-card-price--current">$19.99</span>
        </div>
      </div>
    </div>
  </div>
{%- endif -%}

<style>
  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
</style>

<script>
  if (typeof mlCardProductInit === 'undefined') {
    window.mlCardProductInit = true;

    window.mlUpdateCardVariant = function(card) {
      if (!card) return;

      const jsonScript = card.querySelector('.ml-variants-json');
      if (!jsonScript) return;

      // Get selected values for option1, option2, option3 (supporting dropdown OR pill)
      let opt1 = null;
      const opt1Select = card.querySelector('.ml-card-option-select[data-option-position="option1"]');
      const opt1Pill = card.querySelector('[data-option-position="option1"] .is-selected');
      if (opt1Select) opt1 = opt1Select.value;
      else if (opt1Pill) opt1 = opt1Pill.getAttribute('data-value');

      let opt2 = null;
      const opt2Select = card.querySelector('.ml-card-option-select[data-option-position="option2"]');
      const opt2Pill = card.querySelector('[data-option-position="option2"] .is-selected');
      if (opt2Select) opt2 = opt2Select.value;
      else if (opt2Pill) opt2 = opt2Pill.getAttribute('data-value');

      let opt3 = null;
      const opt3Select = card.querySelector('.ml-card-option-select[data-option-position="option3"]');
      const opt3Pill = card.querySelector('[data-option-position="option3"] .is-selected');
      if (opt3Select) opt3 = opt3Select.value;
      else if (opt3Pill) opt3 = opt3Pill.getAttribute('data-value');

      try {
        const variants = JSON.parse(jsonScript.textContent);
        const match = variants.find(v => {
          let isMatch = true;
          if (opt1 && v.option1 !== opt1) isMatch = false;
          if (opt2 && v.option2 !== opt2) isMatch = false;
          if (opt3 && v.option3 !== opt3) isMatch = false;
          return isMatch;
        });

        if (match) {
          // Update variant ID input
          const inputId = card.querySelector('.product-variant-id');
          if (inputId) inputId.value = match.id;

          // Update current price
          const priceCurr = card.querySelector('.ml-card-price--current');
          if (priceCurr) priceCurr.textContent = match.price_formatted;

          // Update old price & badge
          const priceOld = card.querySelector('.ml-card-price--old');
          const badge = card.querySelector('.ml-card-price-badge');
          if (match.compare_at_price > match.price) {
            if (priceOld) {
              priceOld.textContent = match.compare_at_price_formatted;
              priceOld.style.display = 'inline-block';
            }
            if (badge) {
              const savings = Math.round(((match.compare_at_price - match.price) / match.compare_at_price) * 100);
              badge.textContent = '-' + savings + '%';
              badge.style.display = 'inline-block';
            }
          } else {
            if (priceOld) priceOld.style.display = 'none';
            if (badge) badge.style.display = 'none';
          }

          // Update ATC button state
          const atcBtn = card.querySelector('.ml-card-btn--atc');
          const atcText = card.querySelector('.ml-atc-text');
          if (atcBtn) {
            if (match.available) {
              atcBtn.removeAttribute('disabled');
              if (atcText) atcText.textContent = 'Add To Cart';
            } else {
              atcBtn.setAttribute('disabled', 'disabled');
              if (atcText) atcText.textContent = 'Out Of Stock';
            }
          }

          // Update product image if variant featured image exists
          const img = card.querySelector('.ml-product-card__img--primary');
          if (img && match.featured_image) {
            img.src = match.featured_image;
          }
        }
      } catch (err) {
        console.error('Error updating card variant:', err);
      }
    };

    // PILL CLICK HANDLER
    document.addEventListener('click', function(e) {
      const pill = e.target.closest('.ml-variant-pill-btn');
      if (!pill) return;

      const card = pill.closest('.ml-product-card');
      if (!card) return;

      const optionRow = pill.closest('.ml-option-row');
      if (!optionRow) return;

      optionRow.querySelectorAll('.ml-variant-pill-btn').forEach(btn => btn.classList.remove('is-selected'));
      pill.classList.add('is-selected');

      window.mlUpdateCardVariant(card);
    });

    // DROPDOWN CHANGE HANDLER
    document.addEventListener('change', function(e) {
      const select = e.target.closest('.ml-card-option-select');
      if (!select) return;

      const card = select.closest('.ml-product-card');
      if (!card) return;

      window.mlUpdateCardVariant(card);
    });

    // AJAX ADD TO CART + SPINNER + OPEN CART DRAWER
    document.addEventListener('submit', function(e) {
      const form = e.target.closest('.ml-card-atc-form');
      if (!form) return;

      e.preventDefault();

      const btn = form.querySelector('.ml-card-btn--atc');
      const text = form.querySelector('.ml-atc-text');
      const icon = form.querySelector('.ml-cart-icon');
      const spinner = form.querySelector('.ml-btn-spinner');

      // Set loading state
      if (btn) btn.disabled = true;
      if (text) text.style.display = 'none';
      if (icon) icon.style.display = 'none';
      if (spinner) spinner.style.display = 'inline-block';

      const formData = new FormData(form);

      fetch((window.Shopify ? window.Shopify.routes.root : '/') + 'cart/add.js', {
        method: 'POST',
        body: formData,
        headers: {
          'X-Requested-With': 'XMLHttpRequest'
        }
      })
      .then(res => res.json())
      .then(data => {
        // Fetch updated cart sections
        const sectionsUrl = window.location.pathname + '?sections=cart-drawer,cart-icon-bubble';
        return fetch(sectionsUrl).then(res => res.json()).then(sections => ({ data, sections }));
      })
      .then(({ data, sections }) => {
        // Update Cart Drawer HTML
        const drawer = document.querySelector('cart-drawer');
        if (drawer && sections['cart-drawer']) {
          const doc = new DOMParser().parseFromString(sections['cart-drawer'], 'text/html');
          const newDrawer = doc.querySelector('cart-drawer');
          if (newDrawer) {
            drawer.innerHTML = newDrawer.innerHTML;
          }
          drawer.classList.remove('is-empty');
        }

        // Update Cart Icon Bubble Count
        const bubble = document.getElementById('cart-icon-bubble');
        if (bubble && sections['cart-icon-bubble']) {
          const doc = new DOMParser().parseFromString(sections['cart-icon-bubble'], 'text/html');
          const newBubble = doc.querySelector('#cart-icon-bubble');
          if (newBubble) {
            bubble.innerHTML = newBubble.innerHTML;
          }
        }

        // Publish PubSub event if available
        if (window.PUB_SUB_EVENTS && window.publish) {
          window.publish(window.PUB_SUB_EVENTS.cartUpdate, { source: 'card-product', cartData: data });
        }

        // Open Cart Drawer
        if (drawer) {
          if (typeof drawer.open === 'function') {
            drawer.open(btn);
          } else {
            drawer.classList.add('animate', 'active');
            document.body.classList.add('overflow-hidden');
          }
        }
      })
      .catch(err => {
        console.error('Error adding to cart:', err);
      })
      .finally(() => {
        // Reset loading state
        if (btn) btn.disabled = false;
        if (text) text.style.display = 'inline-block';
        if (icon) icon.style.display = 'inline-block';
        if (spinner) spinner.style.display = 'none';
      });
    });
  }
</script>
