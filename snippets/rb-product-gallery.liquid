{% comment %}
  Renders Clay Design System Product Gallery
  Namespace: .rb-product-gallery
{% endcomment %}
<div class="rb-product-gallery">
  <div class="rb-gallery-container">
    <!-- Vertical Thumbnail Strip -->
    <div class="rb-thumbnail-strip">
      {% for image in product.images %}
        <div class="rb-thumb-item {% if forloop.first %}rb-active{% endif %}" onclick="RBProduct.changeGalleryImage(this, '{{ image | image_url: width: 1000 }}')">
          <img src="{{ image | image_url: width: 150 }}" alt="{{ image.alt | escape }}" loading="lazy" width="70" height="70">
        </div>
      {% endfor %}
    </div>

    <!-- Main Featured Image Container -->
    <div class="rb-main-image-box">
      {% assign featured_img = product.featured_image | default: product.images.first %}
      <img id="RBMainFeaturedImage" src="{{ featured_img | image_url: width: 1000 }}" alt="{{ featured_img.alt | escape }}" width="600" height="600">
      <button class="rb-zoom-btn" type="button" aria-label="Zoom image">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line><line x1="11" y1="8" x2="11" y2="14"></line><line x1="8" y1="11" x2="14" y2="11"></line></svg>
      </button>
    </div>
  </div>
</div>
